@model IEnumerable<PhieuSuaChua>
@{
    ViewData["Title"] = "Điều phối kỹ thuật";
    var userRole = ViewBag.UserRole as string ?? "Technician";
    var userId = ViewBag.UserId as string;
    
    var columns = new[]
    {
        new { Id = "pending", Title = "Chờ kiểm tra", Color = "warning", Icon = "clock" },
        new { Id = "repairing", Title = "Đang sửa", Color = "info", Icon = "tools" },
        new { Id = "waiting_parts", Title = "Chờ linh kiện", Color = "warning", Icon = "pause-circle" },
        new { Id = "done", Title = "Hoàn thành", Color = "success", Icon = "check-circle" }
    };
}

<div class="mb-3 d-flex justify-content-between align-items-center flex-wrap gap-2">
    <div>
        <h2 class="fw-bold mb-0">
            @(userRole == "Technician" ? "Việc của tôi" : "Điều phối kỹ thuật")
        </h2>
        <p class="text-muted small mb-0">
            @(userRole == "Technician" 
                ? "Danh sách các thiết bị được phân công." 
                : "Quản lý tiến độ sửa chữa toàn cửa hàng.")
        </p>
    </div>
    <button class="btn btn-sm btn-outline-secondary" onclick="requestNotificationPermission()" id="btnEnableNotif" style="display:none;">
        <i class="bi bi-bell me-1"></i>Bật thông báo
    </button>
</div>

<!-- ═══ PERSONAL DASHBOARD ══════════════════════════════════════════════════ -->
<div class="row g-3 mb-4" id="personalDashboard">
    <div class="col-6 col-md-3">
        <div class="card border-0 shadow-sm rounded-4 h-100">
            <div class="card-body d-flex align-items-center gap-3 p-3">
                <div class="rounded-3 p-2" style="background:#eff6ff;">
                    <i class="bi bi-check2-circle text-primary fs-4"></i>
                </div>
                <div>
                    <div class="fw-bolder fs-4 lh-1" id="statDoneToday">—</div>
                    <div class="text-muted small mt-1">Xong hôm nay</div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="card border-0 shadow-sm rounded-4 h-100">
            <div class="card-body d-flex align-items-center gap-3 p-3">
                <div class="rounded-3 p-2" style="background:#fef3c7;">
                    <i class="bi bi-wrench-adjustable text-warning fs-4"></i>
                </div>
                <div>
                    <div class="fw-bolder fs-4 lh-1" id="statInProgress">—</div>
                    <div class="text-muted small mt-1">Đang sửa</div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="card border-0 shadow-sm rounded-4 h-100">
            <div class="card-body d-flex align-items-center gap-3 p-3">
                <div class="rounded-3 p-2" style="background:#f0fdf4;">
                    <i class="bi bi-stopwatch text-success fs-4"></i>
                </div>
                <div>
                    <div class="fw-bolder fs-4 lh-1" id="statAvgTime">—</div>
                    <div class="text-muted small mt-1">TG trung bình</div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="card border-0 shadow-sm rounded-4 h-100">
            <div class="card-body d-flex align-items-center gap-3 p-3">
                <div class="rounded-3 p-2" style="background:#fdf4ff;">
                    <i class="bi bi-graph-up-arrow text-purple fs-4" style="color:#7c3aed;"></i>
                </div>
                <div>
                    <div class="fw-bolder fs-4 lh-1" id="statOnTime">—</div>
                    <div class="text-muted small mt-1">Đúng hạn</div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- ═══ KANBAN BOARD ═════════════════════════════════════════════════════════ -->
<div class="kanban-board-wrapper mt-2">
    <div class="d-flex flex-nowrap gap-4 overflow-auto pb-4 kanban-container">
        @foreach (var column in columns)
        {
            var colTickets = Model?.Where(t => t.TrangThai == column.Id).ToList() ?? new List<PhieuSuaChua>();
            
            <div class="kanban-column" data-status="@column.Id">
                <div class="card bg-layout border-0 shadow-none h-100 rounded-4">
                    <!-- Column Header -->
                    <div class="card-header border-0 bg-transparent px-3 pt-3 pb-2 d-flex justify-content-between align-items-center">
                        <div class="d-flex align-items-center gap-2">
                            <div class="icon-shape icon-sm bg-@column.Color bg-opacity-10 text-@column.Color rounded-circle d-flex align-items-center justify-content-center" style="width: 32px; height: 32px;">
                                <i class="bi bi-@column.Icon"></i>
                            </div>
                            <h6 class="mb-0 fw-bold text-dark">@column.Title</h6>
                        </div>
                        <span class="badge bg-white text-dark shadow-sm rounded-pill px-2 py-1 border fw-semibold column-count">@colTickets.Count</span>
                    </div>

                    <!-- Column Body (Scrollable) -->
                    <div class="card-body px-2 py-2 overflow-y-auto" style="max-height: calc(100vh - 280px);">
                        @if (colTickets.Any())
                        {
                            @foreach (var ticket in colTickets)
                            {
                                <div class="card mb-3 ticket-card border-0 rounded-3 shadow-sm ticket-hover"
                                     data-ticket-id="@ticket.Id"
                                     data-received-at="@ticket.NgayNhan.ToString("o")"
                                     data-assignee-id="@(ticket.KyThuatVienId ?? "")"
                                     draggable="true"
                                     style="cursor: pointer;"
                                     onclick="window.location.href='@Url.Action("ChiTiet", new { id = ticket.Id })'">
                                    <div class="card-body p-3">
                                        <!-- Tags & Menu -->
                                        <div class="d-flex justify-content-between align-items-center mb-2">
                                            <span class="badge bg-primary bg-opacity-10 text-primary rounded-pill px-2 fw-semibold small ticket-badge d-inline-flex align-items-center justify-content-center text-nowrap flex-shrink-0" style="min-width: 90px; height: 26px;">@ticket.Id</span>
                                            <button class="btn btn-sm text-muted p-0 border-0 btn-menu"
                                                    type="button"
                                                    onclick="event.stopPropagation(); openQuickNote('@ticket.Id', this)"
                                                    title="Ghi chú nhanh">
                                                <i class="bi bi-pencil-square"></i>
                                            </button>
                                        </div>

                                        <!-- Title -->
                                        <h6 class="card-title fw-bold text-dark mb-1 fs-6">@ticket.TenThietBi</h6>
                                        
                                        <!-- Description -->
                                        <p class="card-text small text-muted mb-3 description-clamp" title="@ticket.MoTaLoi">
                                            @ticket.MoTaLoi
                                        </p>

                                        <!-- Quick Note Box (hidden by default) -->
                                        <div class="quick-note-box d-none mt-1 mb-2" id="qn-@ticket.Id">
                                            <textarea class="form-control form-control-sm mb-2"
                                                      rows="2"
                                                      placeholder="Ghi chú nhanh..."
                                                      onclick="event.stopPropagation()"
                                                      id="qn-text-@ticket.Id"
                                                      style="resize:none; font-size:0.82rem;"></textarea>
                                            <div class="d-flex gap-1">
                                                <button class="btn btn-sm btn-primary flex-grow-1"
                                                        onclick="event.stopPropagation(); saveQuickNote('@ticket.Id')">
                                                    <i class="bi bi-check2 me-1"></i>Lưu
                                                </button>
                                                <button class="btn btn-sm btn-outline-secondary"
                                                        onclick="event.stopPropagation(); closeQuickNote('@ticket.Id')">
                                                    <i class="bi bi-x"></i>
                                                </button>
                                            </div>
                                        </div>

                                        <!-- Footer Info -->
                                        <div class="d-flex justify-content-between align-items-center mt-auto pt-2 border-top border-light gap-2">
                                            <div class="d-flex align-items-center text-muted small fw-medium text-nowrap flex-shrink-0">
                                                <i class="bi bi-calendar4 me-1"></i> @ticket.NgayNhan.ToString("dd/MMM")
                                            </div>
                                            @if (userRole != "Technician" && ticket.KyThuatVien != null)
                                            {
                                                <!-- Assignee Avatar -->
                                                <div class="avatar-group">
                                                    <div class="avatar avatar-xs rounded-circle bg-info bg-opacity-10 text-info fw-bold d-flex align-items-center justify-content-center" title="@ticket.KyThuatVien.TenDayDu" style="width: 24px; height: 24px; font-size: 10px;">
                                                        @ticket.KyThuatVien.TenDayDu.Substring(0, 1).ToUpper()
                                                    </div>
                                                </div>
                                            }
                                        </div>
                                        
                                        @if (userRole == "Technician" && ticket.TrangThai == "pending" && string.IsNullOrEmpty(ticket.KyThuatVienId))
                                        {
                                            <button class="btn btn-sm btn-primary mt-3 w-100 rounded-pill shadow-sm fw-bold action-btn d-flex align-items-center justify-content-center text-nowrap" style="height: 38px;"
                                                    onclick="event.stopPropagation(); ganChoToi('@ticket.Id')">
                                                Bắt đầu sửa <i class="bi bi-arrow-right ms-2"></i>
                                            </button>
                                        }
                                    </div>
                                </div>
                            }
                        }
                        else
                        {
                            <!-- Empty State -->
                            <div class="d-flex flex-column align-items-center justify-content-center text-muted p-4 empty-state" style="min-height:120px;">
                                <i class="bi bi-inbox fs-2 mb-2 text-secondary opacity-50"></i>
                                <span class="fw-medium text-secondary small">Trống</span>
                            </div>
                        }
                    </div>
                </div>
            </div>
        }
    </div>
</div>

<style>
    /* Premium Kanban Styling */
    .bg-layout {
        background-color: #f4f6f8;
    }
    
    .kanban-container {
        padding-bottom: 2rem;
    }

    .kanban-column {
        min-width: 320px;
        width: 320px;
        flex-shrink: 0;
    }

    /* Scrollbar Styling for Webkit */
    .kanban-container::-webkit-scrollbar,
    .overflow-y-auto::-webkit-scrollbar {
        height: 6px;
        width: 6px;
    }
    
    .kanban-container::-webkit-scrollbar-track,
    .overflow-y-auto::-webkit-scrollbar-track {
        background: transparent;
    }
    
    .kanban-container::-webkit-scrollbar-thumb,
    .overflow-y-auto::-webkit-scrollbar-thumb {
        background: #ced4da;
        border-radius: 10px;
    }
    
    .kanban-container::-webkit-scrollbar-thumb:hover,
    .overflow-y-auto::-webkit-scrollbar-thumb:hover {
        background: #adb5bd;
    }

    /* Cards */
    .ticket-card {
        transition: all 0.2s cubic-bezier(0.165, 0.84, 0.44, 1);
        border: 1px solid rgba(0,0,0,0.05) !important;
        min-height: 160px;
    }

    .ticket-card .card-body {
        display: flex;
        flex-direction: column;
    }

    .ticket-hover:hover {
        transform: translateY(-4px);
        box-shadow: 0 10px 20px rgba(0,0,0,0.08) !important;
    }

    /* Text Clamping */
    .description-clamp {
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
        text-overflow: ellipsis;
        line-height: 1.4;
        min-height: 2.8em;
    }

    .ticket-badge {
        letter-spacing: 0.5px;
        font-family: inherit;
    }

    /* Button hover */
    .action-btn {
        transition: background-color 0.2s, transform 0.2s;
    }
    .action-btn:hover {
        transform: translateY(-1px);
    }
    
    .btn-menu {
        opacity: 0.5;
        transition: opacity 0.2s;
    }
    .ticket-card:hover .btn-menu {
        opacity: 1;
    }
</style>

@Html.AntiForgeryToken()

@section Styles {
    <link rel="stylesheet" href="~/css/technician.css" asp-append-version="true" />
}

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/@@microsoft/signalr@latest/dist/browser/signalr.min.js"></script>
    <script src="~/js/technician.js" asp-append-version="true"></script>
    <script>
        // Set user ID on body for filter "Mine only"
        document.body.dataset.userId = '@ViewBag.UserId';

        // Pulse badge + card flash CSS
        const pulseStyle = document.createElement('style');
        pulseStyle.textContent = `
            .new-card-flash { animation: cardFlash 2s ease; }
            .pulse-badge { animation: pulseBadge 0.5s ease 3; }
            @@keyframes cardFlash {
                0%   { box-shadow: 0 0 0 0 rgba(59,130,246,0.5); background: #eff6ff; }
                50%  { box-shadow: 0 0 0 8px rgba(59,130,246,0); }
                100% { box-shadow: none; background: #fff; }
            }
            @@keyframes pulseBadge {
                0%, 100% { transform: scale(1); }
                50%       { transform: scale(1.4); }
            }
            .quick-note-box textarea:focus { box-shadow: 0 0 0 2px rgba(59,130,246,0.25); }
        `;
        document.head.appendChild(pulseStyle);

        // ══ Browser notification permission ══
        if (Notification.permission === 'default') {
            const btn = document.getElementById('btnEnableNotif');
            if (btn) btn.style.display = '';
        }
        function requestNotificationPermission() {
            Notification.requestPermission().then(perm => {
                if (perm === 'granted') {
                    toastr.success('Sẽ nhận thông báo máy tính khi có phiếu mới!', 'Đã bật thông báo');
                    document.getElementById('btnEnableNotif').style.display = 'none';
                } else {
                    toastr.warning('Thông báo máy tính bị tắt. Bạn vẫn nhận được popup trên web.');
                }
            });
        }

        // ═══════════════════════════════════════════════════════
        // PERSONAL DASHBOARD — compute from Kanban DOM
        // ═══════════════════════════════════════════════════════
        document.addEventListener('DOMContentLoaded', function() {
            computeDashboard();
        });

        function computeDashboard() {
            const now = Date.now();
            const today = new Date(); today.setHours(0,0,0,0);
            const myId  = document.body.dataset.userId || '';

            // Count cards in each column
            const doneCards     = document.querySelectorAll('.kanban-column[data-status="done"] .ticket-card');
            const repairCards   = document.querySelectorAll('.kanban-column[data-status="repairing"] .ticket-card');
            const allDoneCards  = document.querySelectorAll('.kanban-column[data-status="done"] .ticket-card, .kanban-column[data-status="delivered"] .ticket-card');

            // Done today (mine or all if manager)
            let doneToday = 0;
            doneCards.forEach(card => {
                const assigneeId = card.dataset.assigneeId || '';
                const isMine = !myId || assigneeId === myId;
                if (isMine) doneToday++;
            });

            // In progress (mine)
            let inProgress = 0;
            repairCards.forEach(card => {
                const assigneeId = card.dataset.assigneeId || '';
                const isMine = !myId || assigneeId === myId;
                if (isMine) inProgress++;
            });

            // Average time (from received_at for done cards)
            let totalMs = 0, counted = 0;
            allDoneCards.forEach(card => {
                const received = new Date(card.dataset.receivedAt || '').getTime();
                if (!isNaN(received)) { totalMs += (now - received); counted++; }
            });
            const avgH = counted > 0 ? (totalMs / counted / 3600000).toFixed(1) : null;

            // On-time rate (done within 24h)
            let onTime = 0;
            allDoneCards.forEach(card => {
                const received = new Date(card.dataset.receivedAt || '').getTime();
                if (!isNaN(received) && (now - received) <= 86400000) onTime++;
            });
            const onTimePct = counted > 0 ? Math.round((onTime / counted) * 100) : null;

            setText('statDoneToday', doneToday);
            setText('statInProgress', inProgress);
            setText('statAvgTime', avgH ? avgH + 'h' : 'N/A');
            setText('statOnTime',  onTimePct !== null ? onTimePct + '%' : 'N/A');
        }

        function setText(id, val) {
            const el = document.getElementById(id);
            if (el) el.textContent = val;
        }

        // ═══════════════════════════════════════════════════════
        // QUICK NOTE BOX
        // ═══════════════════════════════════════════════════════
        function openQuickNote(ticketId, btn) {
            // Close any other open note boxes first
            document.querySelectorAll('.quick-note-box:not(.d-none)').forEach(box => {
                if (box.id !== 'qn-' + ticketId) box.classList.add('d-none');
            });
            const box = document.getElementById('qn-' + ticketId);
            if (!box) return;

            const isOpen = !box.classList.contains('d-none');
            box.classList.toggle('d-none', isOpen);
            if (!isOpen) {
                // Focus textarea
                const ta = document.getElementById('qn-text-' + ticketId);
                if (ta) { ta.focus(); }
                // Change icon
                const icon = btn.querySelector('i');
                if (icon) icon.className = 'bi bi-x-lg';
            } else {
                const icon = btn.querySelector('i');
                if (icon) icon.className = 'bi bi-pencil-square';
            }
        }

        function closeQuickNote(ticketId) {
            const box = document.getElementById('qn-' + ticketId);
            if (box) box.classList.add('d-none');
        }

        async function saveQuickNote(ticketId) {
            const ta = document.getElementById('qn-text-' + ticketId);
            const text = ta?.value?.trim();
            if (!text) { toastr.warning('Vui lòng nhập ghi chú.'); return; }

            try {
                const res = await fetch('/KyThuat/AddNote', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]')?.value || ''
                    },
                    body: JSON.stringify({ PhieuSuaChuaId: ticketId, Content: text, UserName: '' })
                });
                const data = await res.json();
                if (data.success) {
                    toastr.success('Đã lưu ghi chú nhanh!', '', { timeOut: 2000 });
                    if (ta) ta.value = '';
                    closeQuickNote(ticketId);
                    // Show a preview label on the card
                    const card = document.querySelector(`.ticket-card[data-ticket-id="${ticketId}"]`);
                    if (card) {
                        const existingNote = card.querySelector('.quick-note-preview');
                        if (!existingNote) {
                            const noteEl = document.createElement('p');
                            noteEl.className = 'quick-note-preview small text-info-emphasis bg-info-subtle rounded px-2 py-1 mt-2 mb-0';
                            noteEl.innerHTML = `<i class="bi bi-chat-left-text me-1"></i>${escapeHtml(text.substring(0, 60))}${text.length > 60 ? '...' : ''}`;
                            card.querySelector('.card-body')?.appendChild(noteEl);
                        } else {
                            existingNote.innerHTML = `<i class="bi bi-chat-left-text me-1"></i>${escapeHtml(text.substring(0, 60))}${text.length > 60 ? '...' : ''}`;
                        }
                    }
                } else {
                    toastr.error(data.message || 'Không lưu được.');
                }
            } catch(e) {
                toastr.error('Lỗi kết nối.');
            }
        }

        function escapeHtml(t) { const d = document.createElement('div'); d.textContent = t; return d.innerHTML; }
    </script>
}

