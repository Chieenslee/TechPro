@{
    ViewData["Title"] = "TechPro POS - Master Admin";
    Layout = "_Layout";
}

<div class="container-fluid py-5 px-3 px-md-5 font-inter bg-slate-50" style="background-color: #f8fafc; min-height: calc(100vh - 64px);">
    <div class="d-flex flex-column align-items-center justify-content-center h-100" style="min-height: 60vh;">
        <div class="text-center mb-5">
            <div class="bg-indigo-50 text-indigo-600 rounded-circle d-inline-flex align-items-center justify-content-center mb-4 shadow-sm" style="width: 100px; height: 100px;">
                <i class="bi bi-globe" style="font-size: 3rem;"></i>
            </div>
            <h2 class="fw-bolder text-slate-800 mb-2">Trung Tâm Chỉ Huy Chuỗi TechPro (System Admin)</h2>
            <p class="text-slate-500 fs-5 mx-auto" style="max-width: 600px;">
                Quyền hạn cấp tối cao cấp toàn mạng lưới (Head Office).
            </p>
        </div>

        <div class="row g-4 w-100 justify-content-center" style="max-width: 1000px;">
            <div class="col-md-4">
                <a href="/SysAdmin/Chain" class="card border-0 shadow-sm rounded-4 h-100 text-decoration-none hover-lift bg-white text-slate-800">
                    <div class="card-body p-4 text-center">
                        <div class="bg-primary-subtle text-primary rounded-circle d-inline-flex align-items-center justify-content-center mb-3" style="width: 60px; height: 60px;">
                            <i class="bi bi-diagram-3-fill" style="font-size: 1.5rem;"></i>
                        </div>
                        <h5 class="fw-bold mb-2">Thống Kê Vĩ Mô</h5>
                        <p class="text-slate-500 small mb-0">Quản trị xuyên suốt tất cả các Chi Nhánh (Cửa Hàng), xem xét tổng doanh số toàn quốc.</p>
                    </div>
                </a>
            </div>

            <div class="col-md-4">
                <a href="/SysAdmin/Chain?tab=staff" class="card border-0 shadow-sm rounded-4 h-100 text-decoration-none hover-lift bg-white text-slate-800">
                    <div class="card-body p-4 text-center">
                        <div class="bg-warning-subtle text-warning-emphasis rounded-circle d-inline-flex align-items-center justify-content-center mb-3" style="width: 60px; height: 60px;">
                            <i class="bi bi-people-fill" style="font-size: 1.5rem;"></i>
                        </div>
                        <h5 class="fw-bold mb-2">Giám Sát Tổ Chức</h5>
                        <p class="text-slate-500 small mb-0">Quản lý User nhân viên theo Role (Thợ, Quản lý, Lễ Tân), bổ nhiệm và theo dõi tài khoản Login.</p>
                    </div>
                </a>
            </div>
            
            <div class="col-md-4">
                <a href="/SysAdmin/Chain?tab=inventory" class="card border-0 shadow-sm rounded-4 h-100 text-decoration-none hover-lift bg-white text-slate-800">
                    <div class="card-body p-4 text-center">
                        <div class="bg-success-subtle text-success rounded-circle d-inline-flex align-items-center justify-content-center mb-3" style="width: 60px; height: 60px;">
                            <i class="bi bi-box-seam" style="font-size: 1.5rem;"></i>
                        </div>
                        <h5 class="fw-bold mb-2">Kho tổng & Cảnh báo</h5>
                        <p class="text-slate-500 small mb-0">Xem tồn kho toàn hệ thống, cảnh báo linh kiện sắp hết và đồng bộ giá chuẩn.</p>
                    </div>
                </a>
            </div>
        </div>
        
    </div>
</div>

@section Styles {
    <style>
        @@import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap');
        .font-inter { font-family: 'Inter', system-ui, -apple-system, sans-serif; }
        .bg-slate-50 { background-color: #f8fafc; }
        .text-slate-500 { color: #64748b; }
        .text-slate-800 { color: #1e293b; }
        
        .hover-lift {
            transition: all 0.3s ease;
            display: block;
        }
        .hover-lift:hover {
            transform: translateY(-8px);
            box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.1), 0 8px 10px -6px rgba(0, 0, 0, 0.1) !important;
        }
        .hover-lift:hover .rounded-circle {
            transform: scale(1.1);
            transition: transform 0.3s ease;
        }
    </style>
}
