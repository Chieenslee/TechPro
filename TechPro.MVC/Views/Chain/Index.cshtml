@model TechPro.Models.ViewModels.ChainDashboardViewModel
@{
    ViewData["Title"] = "Tổng quan chuỗi";
}

@{
    var headerTitle = Model.ActiveTab switch
    {
        "overview" => "Tổng quan chuỗi",
        "stores" => "Quản lý cửa hàng",
        "staff" => "Nhân sự hệ thống",
        "inventory" => "Kho tổng & Giá chuẩn",
        _ => "Tổng quan chuỗi"
    };
    
    var headerDesc = Model.ActiveTab switch
    {
        "overview" => "Số liệu thời gian thực toàn hệ thống.",
        "stores" => "Danh sách chi nhánh và hiệu suất.",
        "staff" => "Quản lý tài khoản và điều chuyển nhân sự.",
        "inventory" => "Kiểm soát danh mục hàng hóa và chính sách giá.",
        _ => "Số liệu thời gian thực toàn hệ thống."
    };
}

<div class="mb-4">
    <div class="d-flex justify-content-between align-items-center">
        <div>
            <h2 class="fw-bold">@headerTitle</h2>
            <p class="text-muted mb-0">@headerDesc</p>
        </div>
        @if (Model.ActiveTab == "stores")
        {
            <button class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#addStoreModal">
                <i class="bi bi-plus-circle me-2"></i>Tạo cửa hàng mới
            </button>
        }
        @if (Model.ActiveTab == "staff")
        {
            <button class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#addStaffModal">
                <i class="bi bi-person-plus me-2"></i>Thêm nhân viên
            </button>
        }
    </div>
</div>

@if (Model.ActiveTab == "overview")
{
    var thisMonthStoreRevenues = ViewBag.ThisMonthStoreRevenues as IEnumerable<TechPro.Models.DTOs.StoreRevenueDto> ?? new List<TechPro.Models.DTOs.StoreRevenueDto>();
    var topStores = Model.Stores
        .Select(s => new
        {
            Store = s,
            Revenue = thisMonthStoreRevenues.FirstOrDefault(r => r.TenantId == s.Id)?.Revenue ?? 0m
        })
        .OrderByDescending(x => x.Revenue)
        .Take(5)
        .ToList();
    <!-- Overview Stats -->
    <div class="row g-4 mb-4">
        <div class="col-md-4">
            <div class="card border-0 shadow-sm">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-start">
                        <div>
                            <p class="text-muted small mb-1">Doanh thu toàn chuỗi</p>
                            <h3 class="fw-bold mb-0">@Model.TotalRevenue.ToString("N0") ₫</h3>
                        </div>
                        <div class="bg-primary bg-opacity-10 p-3 rounded">
                            <i class="bi bi-currency-dollar text-primary fs-4"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card border-0 shadow-sm">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-start">
                        <div>
                            <p class="text-muted small mb-1">Nhân sự toàn hệ thống</p>
                            <h3 class="fw-bold mb-0">@Model.TotalStaff</h3>
                        </div>
                        <div class="bg-purple bg-opacity-10 p-3 rounded">
                            <i class="bi bi-people text-purple fs-4"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card border-0 shadow-sm">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-start">
                        <div>
                            <p class="text-muted small mb-1">Cửa hàng Active</p>
                            <h3 class="fw-bold mb-0">@Model.ActiveStoresCount <span class="text-muted small fw-normal">/ @Model.Stores.Count</span></h3>
                        </div>
                        <div class="bg-success bg-opacity-10 p-3 rounded">
                            <i class="bi bi-shop text-success fs-4"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-4 mb-4">
        <div class="col-lg-8">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center mb-2">
                        <h5 class="fw-semibold mb-0">Doanh thu theo cửa hàng (Tháng này)</h5>
                        <a class="btn btn-sm btn-outline-primary" href="/SysAdmin/Chain?tab=stores">
                            <i class="bi bi-arrow-right-short"></i> Xem cửa hàng
                        </a>
                    </div>
                    <div style="position: relative; height: 350px;">
                        <canvas id="storeRevenueChart"></canvas>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-lg-4">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body">
                    <h5 class="fw-semibold mb-3">Top cửa hàng</h5>
                    @if (topStores.Any())
                    {
                        <div class="list-group list-group-flush">
                            @foreach (var x in topStores)
                            {
                                <div class="list-group-item px-0 d-flex justify-content-between align-items-center">
                                    <div class="d-flex align-items-center gap-2">
                                        <span class="badge bg-primary bg-opacity-10 text-primary">@x.Store.Id</span>
                                        <div class="fw-semibold">@x.Store.TenCuaHang</div>
                                    </div>
                                    <div class="fw-bold text-success">@x.Revenue.ToString("N0") ₫</div>
                                </div>
                            }
                        </div>
                    }
                    else
                    {
                        <div class="text-muted small">Chưa có dữ liệu doanh thu.</div>
                    }
                    <div class="mt-3 small text-muted">
                        Mẹo: Doanh thu được tính theo phiếu <span class="fw-semibold">Done/Delivered</span>.
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Alerts -->
    <div class="card border-0 shadow-sm">
        <div class="card-body">
            <h5 class="fw-semibold mb-4">Cảnh báo hệ thống</h5>
            <div id="systemAlerts">
                <div class="text-muted small">Đang tải cảnh báo...</div>
            </div>
        </div>
    </div>
}
else if (Model.ActiveTab == "stores")
{
    <!-- Store Management -->
    <div class="row g-4">
        @{
            var thisMonthStoreRevenues = ViewBag.ThisMonthStoreRevenues as IEnumerable<TechPro.Models.DTOs.StoreRevenueDto> ?? new List<TechPro.Models.DTOs.StoreRevenueDto>();
        }
        @foreach (var store in Model.Stores)
        {
            var storeStaff = Model.Users.Count(u => u.TenantId == store.Id);
            var storeTickets = store.PhieuSuaChuas?.Count ?? 0;
            var thisMonthRevenue = thisMonthStoreRevenues.FirstOrDefault(sr => sr.TenantId == store.Id);
            var storeRevenue = thisMonthRevenue?.Revenue ?? 0m;
            
            <div class="col-md-4">
                <div class="card border-0 shadow-sm h-100">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-start mb-3">
                            <div class="bg-light p-3 rounded">
                                <i class="bi bi-shop text-primary fs-4"></i>
                            </div>
                            <span class="badge @(store.TrangThai == "active" ? "bg-success" : "bg-secondary")">@store.TrangThai</span>
                        </div>
                        <h4 class="fw-bold mb-2">@store.TenCuaHang</h4>
                        <p class="text-muted small mb-3">
                            <i class="bi bi-geo-alt"></i> @(store.DiaChi ?? "Chưa có địa chỉ")
                        </p>
                        <div class="row g-2 mb-3">
                            <div class="col-6">
                                <p class="text-muted small mb-0">Doanh thu tháng</p>
                                <p class="fw-bold mb-0">@storeRevenue.ToString("N0") ₫</p>
                            </div>
                            <div class="col-6">
                                <p class="text-muted small mb-0">Nhân sự</p>
                                <p class="fw-bold mb-0">@storeStaff</p>
                            </div>
                            <div class="col-6">
                                <p class="text-muted small mb-0">Tổng phiếu</p>
                                <p class="fw-bold mb-0">@storeTickets</p>
                            </div>
                            <div class="col-6">
                                <p class="text-muted small mb-0">Hotline</p>
                                <p class="fw-bold mb-0 small">@(store.Hotline ?? "N/A")</p>
                            </div>
                        </div>
                        <div class="d-flex gap-2">
                            <a href="@Url.Action("ChiTietCuaHang", new { id = store.Id })" class="btn btn-sm btn-outline-primary flex-grow-1">
                                <i class="bi bi-eye me-1"></i>Chi tiết
                            </a>
                            <button class="btn btn-sm btn-outline-secondary" onclick="editStore('@store.Id')">
                                <i class="bi bi-pencil"></i>
                            </button>
                            <button class="btn btn-sm btn-outline-danger" onclick="deleteStore('@store.Id', '@store.TenCuaHang')">
                                <i class="bi bi-trash"></i>
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
}
else if (Model.ActiveTab == "staff")
{
    <!-- Staff Management -->
    <div class="card border-0 shadow-sm">
        <div class="card-header bg-light">
            <div class="row align-items-center">
                <div class="col-md-6">
                    <h5 class="mb-0">Danh sách nhân sự</h5>
                </div>
                <div class="col-md-6">
                    <input type="text" class="form-control form-control-sm" id="staffSearch" placeholder="Tìm kiếm nhân viên..." />
                </div>
            </div>
        </div>
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-hover">
                    <thead>
                        <tr>
                            <th>Nhân viên</th>
                            <th>Vai trò</th>
                            <th>Chi nhánh hiện tại</th>
                            <th>Trạng thái</th>
                            <th class="text-center">Hành động</th>
                        </tr>
                    </thead>
                    <tbody>
                        @{
                            var usersWithRoles = ViewBag.UsersWithRoles as IEnumerable<TechPro.Models.DTOs.UserWithRoleDto> ?? new List<TechPro.Models.DTOs.UserWithRoleDto>();
                        }
                        @foreach (var item in usersWithRoles)
                        {
                            var user = item.User;
                            var userRole = item.Role ?? "N/A";
                            
                            <tr>
                                <td>
                                    <div class="d-flex align-items-center gap-3">
                                        <div class="bg-light rounded-circle d-flex align-items-center justify-content-center" style="width: 40px; height: 40px;">
                                            <i class="bi bi-person"></i>
                                        </div>
                                        <div>
                                            <p class="fw-bold mb-0">@user.TenDayDu</p>
                                            <p class="text-muted small mb-0">@user.Email</p>
                                        </div>
                                    </div>
                                </td>
                                <td>
                                    <span class="badge @(userRole == "SystemAdmin" ? "bg-dark" : userRole == "StoreAdmin" ? "bg-primary" : "bg-info")">
                                        @userRole
                                    </span>
                                </td>
                                <td>@(user.CuaHang?.TenCuaHang ?? "Head Office")</td>
                                <td>
                                    <span class="badge bg-success">Active</span>
                                </td>
                                <td class="text-center">
                                    @if (userRole != "SystemAdmin")
                                    {
                                        <div class="d-flex gap-2 justify-content-center">
                                            <button class="btn btn-sm btn-outline-primary" onclick="transferStaff('@user.Id', '@user.TenDayDu')" title="Điều chuyển">
                                                <i class="bi bi-arrow-left-right"></i>
                                            </button>
                                            <button class="btn btn-sm btn-outline-danger" onclick="deleteStaff('@user.Id', '@user.TenDayDu')" title="Xóa">
                                                <i class="bi bi-trash"></i>
                                            </button>
                                        </div>
                                    }
                                    else
                                    {
                                        <span class="text-muted small">-</span>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
}
else if (Model.ActiveTab == "inventory")
{
    <!-- Inventory Management -->
    <div class="card border-0 shadow-sm">
        <div class="card-header bg-light">
            <div class="row align-items-center">
                <div class="col-md-6">
                    <h5 class="mb-0">Kho tổng & Giá chuẩn</h5>
                </div>
                <div class="col-md-6">
                    <input type="text" class="form-control form-control-sm" id="inventorySearch" placeholder="Tìm kiếm linh kiện..." />
                </div>
            </div>
        </div>
        <div class="card-body">
            <div class="alert alert-info d-flex align-items-center gap-2 mb-4">
                <i class="bi bi-info-circle"></i>
                <small>Thay đổi giá tại đây sẽ áp dụng cho toàn hệ thống sau khi bấm "Đồng bộ".</small>
            </div>
            <div class="table-responsive">
                <table class="table table-hover">
                    <thead>
                        <tr>
                            <th>Mã SKU</th>
                            <th>Tên linh kiện</th>
                            <th>Danh mục</th>
                            <th class="text-end">Giá niêm yết (VNĐ)</th>
                            <th class="text-center">Tồn kho tổng</th>
                            <th class="text-center">Hành động</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model.InventoryItems)
                        {
                            <tr>
                                <td class="font-monospace small">@item.Id</td>
                                <td class="fw-medium">@item.TenLinhKien</td>
                                <td>@(item.DanhMuc ?? "N/A")</td>
                                <td>
                                    <div class="input-group input-group-sm">
                                        <input type="number" class="form-control text-end price-input" 
                                               data-part-id="@item.Id" 
                                               value="@item.GiaBan" 
                                               min="0" step="1000" />
                                        <span class="input-group-text">₫</span>
                                    </div>
                                </td>
                                <td class="text-center">
                                    <span class="badge @(item.SoLuongTon < 5 ? "bg-danger" : item.SoLuongTon < 20 ? "bg-warning" : "bg-success")">
                                        @item.SoLuongTon
                                    </span>
                                </td>
                                <td class="text-center">
                                    <button class="btn btn-sm btn-primary" onclick="updatePrice('@item.Id', this)">
                                        <i class="bi bi-check-circle me-1"></i>Đồng bộ
                                    </button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
}

<!-- Add Store Modal -->
<div class="modal fade" id="addStoreModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Tạo cửa hàng mới</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <form id="addStoreForm">
                @Html.AntiForgeryToken()
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label">Tên cửa hàng *</label>
                        <input type="text" class="form-control" name="TenCuaHang" required />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Địa chỉ</label>
                        <input type="text" class="form-control" name="DiaChi" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Hotline</label>
                        <input type="text" class="form-control" name="Hotline" />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Email quản lý</label>
                        <input type="email" class="form-control" name="AdminEmail" />
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Hủy</button>
                    <button type="submit" class="btn btn-primary">Tạo cửa hàng</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Add Staff Modal -->
<div class="modal fade" id="addStaffModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Thêm nhân viên mới</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <form id="addStaffForm">
                @Html.AntiForgeryToken()
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label">Họ và tên *</label>
                        <input type="text" class="form-control" name="tenDayDu" required />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Email *</label>
                        <input type="email" class="form-control" name="email" required />
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Vai trò *</label>
                        <select class="form-select" name="role" required>
                            <option value="StoreAdmin">Quản lý cửa hàng</option>
                            <option value="Support">Nhân viên tiếp nhận</option>
                            <option value="Technician">Kỹ thuật viên</option>
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Cửa hàng *</label>
                        <select class="form-select" name="tenantId" required>
                            @foreach (var store in Model.Stores)
                            {
                                <option value="@store.Id">@store.TenCuaHang</option>
                            }
                        </select>
                    </div>
                    <div class="alert alert-info">
                        <i class="bi bi-info-circle me-2"></i>
                        <small>Mật khẩu mặc định: <strong>TechPro@123</strong> (Khuyến nghị đổi sau khi đăng nhập)</small>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Hủy</button>
                    <button type="submit" class="btn btn-primary">Tạo nhân viên</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- Transfer Staff Modal -->
<div class="modal fade" id="transferStaffModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Điều chuyển nhân viên</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <form id="transferStaffForm">
                @Html.AntiForgeryToken()
                <input type="hidden" id="transferUserId" name="userId" />
                <div class="modal-body">
                    <p class="mb-3">Điều chuyển <strong id="transferStaffName"></strong> đến:</p>
                    <div class="mb-3">
                        <label class="form-label">Cửa hàng đích *</label>
                        <select class="form-select" id="transferTargetStore" name="targetTenantId" required>
                            @foreach (var store in Model.Stores)
                            {
                                <option value="@store.Id">@store.TenCuaHang</option>
                            }
                        </select>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Hủy</button>
                    <button type="submit" class="btn btn-primary">Xác nhận điều chuyển</button>
                </div>
            </form>
        </div>
    </div>
</div>



@section Scripts {
    <script>
        // Store Revenue Chart
        @if (Model.ActiveTab == "overview")
        {
            <text>
            document.addEventListener('DOMContentLoaded', function() {
                @{
                    var thisMonthStoreRevenuesJson = ViewBag.ThisMonthStoreRevenues as IEnumerable<TechPro.Models.DTOs.StoreRevenueDto> ?? new List<TechPro.Models.DTOs.StoreRevenueDto>();
                }
                const stores = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Stores.Select(s => new { Name = s.TenCuaHang, Revenue = thisMonthStoreRevenuesJson.FirstOrDefault(r => r.TenantId == s.Id)?.Revenue ?? 0m })));
                const ctx = document.getElementById('storeRevenueChart');
                if (ctx) {
                    new Chart(ctx.getContext('2d'), {
                        type: 'bar',
                        data: {
                            labels: stores.map(s => s.Name || s.name),
                            datasets: [{
                                label: 'Doanh thu (VNĐ)',
                                data: stores.map(s => s.Revenue || s.revenue || 0),
                                backgroundColor: 'rgba(59, 130, 246, 0.5)',
                                borderColor: 'rgba(59, 130, 246, 1)',
                                borderWidth: 2,
                                borderRadius: 8
                            }]
                        },
                        options: {
                            responsive: true,
                            maintainAspectRatio: false,
                            plugins: {
                                legend: { display: false },
                                tooltip: {
                                    callbacks: {
                                        label: function(context) {
                                            return (context.parsed.y / 1000000).toFixed(1) + 'M ₫';
                                        }
                                    }
                                }
                            },
                            scales: {
                                y: {
                                    beginAtZero: true,
                                    ticks: {
                                        callback: function(value) {
                                            return (value / 1000000).toFixed(0) + 'M';
                                        }
                                    }
                                }
                            }
                        }
                    });
                }
            });
            </text>
        }

        // Add Store
        $('#addStoreForm').on('submit', function(e) {
            e.preventDefault();
            const formData = new FormData(this);
            $.ajax({
                url: '/Chain/TaoCuaHang',
                type: 'POST',
                data: formData,
                processData: false,
                contentType: false,
                headers: {
                    'RequestVerificationToken': $('input[name="__RequestVerificationToken"]').val()
                },
                success: function(response) {
                    if (response.success) {
                        toastr.success(response.message);
                        $('#addStoreModal').modal('hide');
                        setTimeout(() => location.reload(), 1000);
                    } else {
                        toastr.error(response.message);
                    }
                }
            });
        });

        // Add Staff
        $('#addStaffForm').on('submit', function(e) {
            e.preventDefault();
            const data = {
                email: $('[name="email"]').val(),
                tenDayDu: $('[name="tenDayDu"]').val(),
                role: $('[name="role"]').val(),
                tenantId: $('[name="tenantId"]').val()
            };
            $.ajax({
                url: '/Chain/TaoNhanVien',
                type: 'POST',
                data: data,
                headers: {
                    'RequestVerificationToken': $('input[name="__RequestVerificationToken"]').val()
                },
                success: function(response) {
                    if (response.success) {
                        toastr.success(response.message);
                        $('#addStaffModal').modal('hide');
                        setTimeout(() => location.reload(), 1000);
                    } else {
                        toastr.error(response.message);
                    }
                }
            });
        });

        // Transfer Staff
        function transferStaff(userId, userName) {
            $('#transferUserId').val(userId);
            $('#transferStaffName').text(userName);
            $('#transferStaffModal').modal('show');
        }

        $('#transferStaffForm').on('submit', function(e) {
            e.preventDefault();
            $.ajax({
                url: '/Chain/DieuChuyenNhanVien',
                type: 'POST',
                data: {
                    userId: $('#transferUserId').val(),
                    targetTenantId: $('#transferTargetStore').val()
                },
                headers: {
                    'RequestVerificationToken': $('input[name="__RequestVerificationToken"]').val()
                },
                success: function(response) {
                    if (response.success) {
                        toastr.success(response.message);
                        $('#transferStaffModal').modal('hide');
                        setTimeout(() => location.reload(), 1000);
                    } else {
                        toastr.error(response.message);
                    }
                }
            });
        });

        // Delete Staff
        function deleteStaff(userId, userName) {
            if (!confirm(`Xác nhận xóa nhân viên "${userName}"?`)) return;
            $.ajax({
                url: '/Chain/XoaNhanVien',
                type: 'POST',
                data: { userId: userId },
                headers: {
                    'RequestVerificationToken': $('input[name="__RequestVerificationToken"]').val()
                },
                success: function(response) {
                    if (response.success) {
                        toastr.success(response.message);
                        setTimeout(() => location.reload(), 1000);
                    } else {
                        toastr.error(response.message);
                    }
                }
            });
        }

        // Update Price
        function updatePrice(partId, btn) {
            const row = $(btn).closest('tr');
            const priceInput = row.find('.price-input');
            const newPrice = parseFloat(priceInput.val());
            
            if (isNaN(newPrice) || newPrice < 0) {
                toastr.error('Giá không hợp lệ');
                return;
            }

            $.ajax({
                url: '/Chain/CapNhatGiaChuan',
                type: 'POST',
                data: { partId: partId, giaBan: newPrice },
                headers: {
                    'RequestVerificationToken': $('input[name="__RequestVerificationToken"]').val()
                },
                success: function(response) {
                    if (response.success) {
                        toastr.success(response.message);
                    } else {
                        toastr.error(response.message);
                    }
                }
            });
        }

        // Delete Store
        function deleteStore(storeId, storeName) {
            if (!confirm(`Xác nhận xóa cửa hàng "${storeName}"?`)) return;
            $.ajax({
                url: '/Chain/XoaCuaHang',
                type: 'POST',
                data: { id: storeId },
                headers: {
                    'RequestVerificationToken': $('input[name="__RequestVerificationToken"]').val()
                },
                success: function(response) {
                    if (response.success) {
                        toastr.success(response.message);
                        setTimeout(() => location.reload(), 1000);
                    } else {
                        toastr.error(response.message);
                    }
                }
            });
        }

        // Edit Store
        function editStore(storeId) {
            // TODO: Implement edit store modal
            toastr.info('Tính năng đang phát triển');
        }

        // Search filters
        $('#staffSearch').on('input', function() {
            const search = $(this).val().toLowerCase();
            $('tbody tr').each(function() {
                const text = $(this).text().toLowerCase();
                $(this).toggle(text.includes(search));
            });
        });

        $('#inventorySearch').on('input', function() {
            const search = $(this).val().toLowerCase();
            $('tbody tr').each(function() {
                const text = $(this).text().toLowerCase();
                $(this).toggle(text.includes(search));
            });
        });

        // Overview alerts (low stock)
        @if (Model.ActiveTab == "overview")
        {
            <text>
            document.addEventListener('DOMContentLoaded', function() {
                try {
                    const payload = @Html.Raw(ViewBag.LowStockJson ?? "{\"success\":false,\"data\":[]}");
                    const items = payload?.data || payload?.Data || [];
                    const host = document.getElementById('systemAlerts');
                    if (!host) return;

                    if (!items.length) {
                        host.innerHTML = `<div class="alert alert-success bg-success-subtle border-0 py-2 px-3 small mb-0">
                            <strong>Ổn định.</strong> Không có linh kiện dưới ngưỡng cảnh báo.
                        </div>`;
                        return;
                    }

                    const top = items.slice(0, 6);
                    host.innerHTML = `
                        <div class="alert alert-warning bg-warning-subtle border-0 py-2 px-3 small mb-2">
                            <strong>Tồn kho thấp.</strong> Có <b>${items.length}</b> linh kiện ≤ ngưỡng. Dưới đây là một số mục.
                        </div>
                        <ul class="list-group list-group-flush small">
                            ${top.map(x => `
                                <li class="list-group-item px-0 d-flex justify-content-between align-items-center">
                                    <span class="text-truncate me-3"><span class="fw-semibold">${x.id}</span> — ${x.tenLinhKien || x.TenLinhKien || 'N/A'}</span>
                                    <span class="badge bg-danger bg-opacity-10 text-danger">Còn ${x.soLuongTon ?? x.SoLuongTon ?? 0}</span>
                                </li>
                            `).join('')}
                        </ul>
                    `;
                } catch(e) {
                    const host = document.getElementById('systemAlerts');
                    if (host) host.innerHTML = `<div class="text-muted small">Không tải được cảnh báo.</div>`;
                }
            });
            </text>
        }
    </script>
}
