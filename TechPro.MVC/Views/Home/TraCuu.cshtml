@model PhieuSuaChua
@{
    ViewData["Title"] = "Tra cứu trạng thái sửa chữa";
    Layout = null;
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - TechPro Care</title>
    
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body { 
            font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, "Helvetica Neue", Arial, sans-serif; 
            background: linear-gradient(135deg, #f5f7fa 0%, #c3cfe2 100%);
            min-height: 100vh;
        }
        
        /* Animations */
        @@keyframes fadeInUp {
            from {
                opacity: 0;
                transform: translateY(30px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }
        
        @@keyframes slideInRight {
            from {
                opacity: 0;
                transform: translateX(30px);
            }
            to {
                opacity: 1;
                transform: translateX(0);
            }
        }
        
        @@keyframes pulse {
            0%, 100% { transform: scale(1); }
            50% { transform: scale(1.05); }
        }
        
        @@keyframes shimmer {
            0% { background-position: -1000px 0; }
            100% { background-position: 1000px 0; }
        }
        
        .animate-fade-in-up {
            animation: fadeInUp 0.6s ease-out forwards;
        }
        
        .animate-slide-in-right {
            animation: slideInRight 0.6s ease-out forwards;
        }
        
        .animate-pulse-slow {
            animation: pulse 2s ease-in-out infinite;
        }
        
        /* Sticky Header */
        .sticky-header {
            background: rgba(255, 255, 255, 0.95);
            backdrop-filter: blur(10px);
            border-bottom: 1px solid rgba(226, 232, 240, 0.8);
            box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.05);
        }
        
        /* Device Info Card */
        .device-card {
            background: white;
            border-radius: 24px;
            padding: 2rem;
            box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.1), 0 10px 10px -5px rgba(0, 0, 0, 0.04);
            position: relative;
            overflow: hidden;
            transition: transform 0.3s, box-shadow 0.3s;
        }
        
        .device-card:hover {
            transform: translateY(-4px);
            box-shadow: 0 25px 30px -5px rgba(0, 0, 0, 0.15), 0 15px 15px -5px rgba(0, 0, 0, 0.06);
        }
        
        .device-card::before {
            content: '';
            position: absolute;
            top: 0;
            right: 0;
            width: 300px;
            height: 300px;
            background: linear-gradient(135deg, rgba(13, 110, 253, 0.1) 0%, rgba(79, 70, 229, 0.1) 100%);
            border-radius: 50%;
            transform: translate(30%, -30%);
        }
        
        .device-card::after {
            content: '';
            position: absolute;
            bottom: 0;
            left: 0;
            width: 200px;
            height: 200px;
            background: linear-gradient(135deg, rgba(139, 92, 246, 0.1) 0%, rgba(255, 255, 255, 0.1) 100%);
            border-radius: 50%;
            transform: translate(-30%, 30%);
        }
        
        .status-badge {
            background: linear-gradient(135deg, #0d6efd 0%, #0a58ca 100%);
            color: white;
            padding: 1rem 1.5rem;
            border-radius: 16px;
            box-shadow: 0 10px 15px -3px rgba(13, 110, 253, 0.3);
            position: relative;
            z-index: 10;
        }
        
        .status-badge.orange {
            background: linear-gradient(135deg, #fd7e14 0%, #dc6502 100%);
            box-shadow: 0 10px 15px -3px rgba(253, 126, 20, 0.3);
        }
        
        .status-badge.green {
            background: linear-gradient(135deg, #198754 0%, #146c43 100%);
            box-shadow: 0 10px 15px -3px rgba(25, 135, 84, 0.3);
        }
        
        .status-indicator {
            width: 12px;
            height: 12px;
            border-radius: 50%;
            background: white;
            position: relative;
        }
        
        .status-indicator::after {
            content: '';
            position: absolute;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
            width: 100%;
            height: 100%;
            border-radius: 50%;
            background: inherit;
            animation: pulse 2s ease-in-out infinite;
        }
        
        /* Timeline Card */
        .timeline-card {
            background: white;
            border-radius: 24px;
            padding: 2rem;
            box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.1), 0 10px 10px -5px rgba(0, 0, 0, 0.04);
            position: relative;
        }
        
        .timeline-progress {
            position: absolute;
            top: 60px;
            left: 40px;
            right: 40px;
            height: 4px;
            background: #e2e8f0;
            border-radius: 2px;
            z-index: 1;
        }
        
        .timeline-progress-fill {
            height: 100%;
            background: linear-gradient(90deg, #0d6efd 0%, #4f46e5 100%);
            border-radius: 2px;
            transition: width 1s ease-out;
            box-shadow: 0 0 10px rgba(13, 110, 253, 0.5);
        }
        
        .timeline-step {
            position: relative;
            z-index: 2;
            text-align: center;
        }
        
        .step-icon {
            width: 56px;
            height: 56px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 1rem;
            font-size: 1.5rem;
            transition: all 0.3s;
            border: 4px solid;
        }
        
        .step-icon.completed {
            background: white;
            border-color: #0d6efd;
            color: #0d6efd;
            box-shadow: 0 4px 12px rgba(13, 110, 253, 0.3);
        }
        
        .step-icon.current {
            background: linear-gradient(135deg, #0d6efd 0%, #4f46e5 100%);
            border-color: #0d6efd;
            color: white;
            box-shadow: 0 8px 20px rgba(13, 110, 253, 0.4);
            transform: scale(1.1);
            animation: pulse 2s ease-in-out infinite;
        }
        
        .step-icon.pending {
            background: white;
            border-color: #e2e8f0;
            color: #cbd5e1;
        }
        
        .step-icon.warning {
            background: white;
            border-color: #fd7e14;
            color: #fd7e14;
            box-shadow: 0 4px 12px rgba(253, 126, 20, 0.3);
        }
        
        /* Info Cards */
        .info-card {
            background: white;
            border-radius: 20px;
            padding: 1.5rem;
            box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.1);
            transition: transform 0.3s, box-shadow 0.3s;
            height: 100%;
        }
        
        .info-card:hover {
            transform: translateY(-2px);
            box-shadow: 0 15px 20px -3px rgba(0, 0, 0, 0.15);
        }
        
        .quote-card {
            background: linear-gradient(135deg, #fff7ed 0%, #ffedd5 100%);
            border: 2px solid #fd7e14;
            border-radius: 20px;
            padding: 1.5rem;
            position: relative;
            overflow: hidden;
        }
        
        .quote-card::before {
            content: '';
            position: absolute;
            top: -50%;
            right: -50%;
            width: 200%;
            height: 200%;
            background: linear-gradient(45deg, transparent, rgba(255, 255, 255, 0.3), transparent);
            animation: shimmer 3s infinite;
        }
        
        .btn-confirm {
            background: linear-gradient(135deg, #0d6efd 0%, #4f46e5 100%);
            color: white;
            padding: 1rem 2rem;
            border-radius: 12px;
            border: none;
            font-weight: 600;
            box-shadow: 0 10px 15px -3px rgba(13, 110, 253, 0.3);
            transition: all 0.3s;
        }
        
        .btn-confirm:hover {
            transform: translateY(-2px);
            box-shadow: 0 15px 20px -3px rgba(13, 110, 253, 0.4);
        }
        
        .btn-confirm:active {
            transform: translateY(0);
        }
        
        /* Responsive */
        @@media (max-width: 768px) {
            .device-card, .timeline-card, .info-card {
                padding: 1.5rem;
                border-radius: 16px;
            }
            
            .timeline-progress {
                display: none;
            }
        }
    </style>
</head>
<body>
    <!-- Sticky Header -->
    <div class="sticky-top sticky-header px-4 py-3">
        <div class="container-fluid">
            <div class="d-flex align-items-center justify-content-between">
                <a href="/" class="d-flex align-items-center gap-2 text-decoration-none text-dark fw-medium">
                    <i class="bi bi-chevron-left fs-5"></i>
                    <span class="d-none d-sm-inline">Quay lại tra cứu</span>
                    <span class="d-sm-none">Quay lại</span>
                </a>
                <div class="badge bg-primary px-3 py-2 rounded-pill fw-bold">
                    Mã phiếu: @Model?.Id
                </div>
            </div>
        </div>
    </div>
    
    @if (Model != null)
    {
        var currentIndex = Model.TrangThai switch
        {
            "pending" => 0,
            "waiting_parts" => 2,
            "repairing" => 3,
            "done" => 4,
            "delivered" => 5,
            _ => 0
        };
        
        var isWaitingQuote = Model.TrangThai == "waiting_parts";
        var statusClass = Model.TrangThai == "done" ? "green" : isWaitingQuote ? "orange" : "";
        var statusText = Model.TrangThai == "done" ? "Hoàn tất sửa chữa" : 
                        Model.TrangThai == "waiting_parts" ? "Chờ xác nhận" :
                        Model.TrangThai == "repairing" ? "Đang sửa chữa" : "Đang xử lý";
        
        <div class="container-fluid py-5">
            <div class="container">
                <!-- Device Info Card -->
                <div class="device-card mb-4 animate-fade-in-up" style="animation-delay: 0.1s;">
                    <div class="d-flex flex-column flex-md-row justify-content-between align-items-start align-items-md-center gap-4 position-relative" style="z-index: 10;">
                        <div class="flex-grow-1">
                            <div class="d-flex align-items-center gap-3 mb-3">
                                <span class="badge bg-light text-dark px-3 py-2 d-flex align-items-center gap-2">
                                    <i class="bi bi-phone"></i>
                                    <span class="text-uppercase fw-bold small">Thiết bị</span>
                                </span>
                                <span class="text-muted font-monospace small">@Model.SerialNumber</span>
                            </div>
                            <h1 class="display-5 fw-bold text-dark mb-3">@Model.TenThietBi</h1>
                            <p class="text-muted d-flex align-items-center gap-2 mb-0">
                                <i class="bi bi-clock"></i>
                                <span>Thời gian tiếp nhận: @Model.NgayNhan.ToString("dd/MM/yyyy HH:mm")</span>
                            </p>
                        </div>
                        
                        <!-- Status Badge -->
                        <div class="status-badge @statusClass d-flex align-items-center gap-3">
                            <div class="status-indicator"></div>
                            <div>
                                <div class="small text-uppercase fw-bold opacity-75">Trạng thái hiện tại</div>
                                <div class="fw-bold fs-5">@statusText</div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Timeline Card -->
                <div class="timeline-card mb-4 animate-fade-in-up" style="animation-delay: 0.2s;">
                    <h3 class="fs-5 fw-bold text-dark mb-4 d-flex align-items-center gap-2">
                        <i class="bi bi-check-circle text-primary"></i>
                        Tiến độ xử lý
                    </h3>
                    
                    <div class="position-relative">
                        <div class="timeline-progress">
                            <div class="timeline-progress-fill" style="width: @((currentIndex / 4.0) * 100)%;"></div>
                        </div>
                        
                        <div class="row g-4">
                            @{
                                var steps = new[]
                                {
                                    new { Id = "received", Label = "Tiếp nhận", Desc = "Đã nhận máy", Icon = "bi-file-text", Status = currentIndex >= 0 ? "completed" : "pending" },
                                    new { Id = "checking", Label = "Kiểm tra", Desc = "Đang chẩn đoán", Icon = "bi-phone", Status = currentIndex >= 1 ? "completed" : "pending" },
                                    new { Id = "waiting_quote", Label = "Báo giá", Desc = "Chờ xác nhận", Icon = "bi-exclamation-triangle", Status = currentIndex == 2 ? "warning" : currentIndex > 2 ? "completed" : "pending" },
                                    new { Id = "repairing", Label = "Sửa chữa", Desc = "Đang xử lý", Icon = "bi-wrench", Status = currentIndex == 3 ? "current" : currentIndex > 3 ? "completed" : "pending" },
                                    new { Id = "done", Label = "Hoàn tất", Desc = "Sẵn sàng trả", Icon = "bi-box-seam", Status = currentIndex >= 4 ? "completed" : "pending" }
                                };
                            }
                            
                            @foreach (var step in steps)
                            {
                                <div class="col-6 col-md timeline-step">
                                    <div class="step-icon @step.Status">
                                        @if (step.Status == "completed")
                                        {
                                            <i class="bi bi-check"></i>
                                        }
                                        else
                                        {
                                            <i class="bi @step.Icon"></i>
                                        }
                                    </div>
                                    <div class="fw-bold text-uppercase small @(step.Status == "pending" ? "text-muted" : step.Status == "current" || step.Status == "warning" ? "text-primary" : "text-dark")">
                                        @step.Label
                                    </div>
                                    <div class="text-muted small d-none d-md-block mt-1">@step.Desc</div>
                                </div>
                            }
                        </div>
                    </div>
                </div>

                <!-- Info Grid -->
                <div class="row g-4">
                    <!-- Left: Device & Problem -->
                    <div class="col-md-6">
                        <div class="info-card animate-slide-in-right" style="animation-delay: 0.3s;">
                            <div class="d-flex align-items-center gap-3 border-bottom pb-3 mb-4">
                                <div class="bg-light rounded-circle p-2">
                                    <i class="bi bi-file-text text-primary"></i>
                                </div>
                                <h3 class="fw-bold text-dark mb-0 fs-5">Thông tin chi tiết</h3>
                            </div>
                            
                            <div class="d-flex flex-column gap-4">
                                <div>
                                    <label class="text-uppercase small text-muted fw-bold">Khách hàng</label>
                                    <p class="fw-bold text-dark fs-5 mb-1">@Model.TenKhachHang</p>
                                    <p class="text-muted font-monospace small bg-light d-inline-block px-2 py-1 rounded">
                                        @Model.SoDienThoai.Substring(0, Math.Min(3, Model.SoDienThoai.Length))*****@Model.SoDienThoai.Substring(Math.Max(0, Model.SoDienThoai.Length - 2))
                                    </p>
                                </div>
                                <div>
                                    <label class="text-uppercase small text-muted fw-bold">Mô tả lỗi</label>
                                    <div class="mt-2 p-3 bg-light rounded border-start border-primary border-3">
                                        <p class="text-dark fst-italic mb-0">"@(Model.MoTaLoi ?? "Chưa có mô tả")"</p>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Right: Action / Quote -->
                    <div class="col-md-6">
                        @if (isWaitingQuote)
                        {
                            <div class="quote-card animate-slide-in-right" style="animation-delay: 0.4s;">
                                <div class="d-flex align-items-center gap-3 border-bottom border-warning pb-3 mb-4 position-relative">
                                    <div class="bg-warning bg-opacity-25 rounded-circle p-2">
                                        <i class="bi bi-receipt text-warning"></i>
                                    </div>
                                    <h3 class="fw-bold text-dark mb-0 fs-5">Chi phí & Dịch vụ</h3>
                                </div>

                                <div class="alert alert-warning d-flex gap-3 mb-4">
                                    <i class="bi bi-exclamation-triangle fs-4"></i>
                                    <div>
                                        <h4 class="fw-bold text-warning mb-1">Yêu cầu xác nhận</h4>
                                        <p class="text-dark small mb-0">
                                            Kỹ thuật viên đã kiểm tra và báo giá. Vui lòng xác nhận để chúng tôi tiến hành sửa chữa.
                                        </p>
                                    </div>
                                </div>
                                
                                @{
                                    var partsList = ViewBag.PartsList as IEnumerable<dynamic> ?? new List<dynamic>();
                                    var partsCost = ViewBag.PartsCost as decimal? ?? 0;
                                    var serviceFee = ViewBag.ServiceFee as decimal? ?? 0;
                                    var totalCost = ViewBag.TotalCost as decimal? ?? 0;
                                }
                                
                                <div class="bg-white rounded p-3 mb-4">
                                    @foreach (var part in partsList)
                                    {
                                        <div class="d-flex justify-content-between text-dark small mb-2">
                                            <span>@part.Name @(part.Quantity > 1 ? $"x{part.Quantity}" : "")</span>
                                            <span class="fw-bold">@((part.Price * part.Quantity).ToString("N0")) ₫</span>
                                        </div>
                                    }
                                    @if (partsCost > 0 || serviceFee > 0)
                                    {
                                        @if (partsCost > 0)
                                        {
                                            <div class="d-flex justify-content-between text-dark small mb-2">
                                                <span>Tổng linh kiện</span>
                                                <span class="fw-bold">@partsCost.ToString("N0") ₫</span>
                                            </div>
                                        }
                                        @if (serviceFee > 0)
                                        {
                                            <div class="d-flex justify-content-between text-dark small mb-2">
                                                <span>Công thợ & Bảo hành</span>
                                                <span class="fw-bold">@serviceFee.ToString("N0") ₫</span>
                                            </div>
                                        }
                                        <hr class="my-2">
                                        <div class="d-flex justify-content-between fs-5 fw-bold">
                                            <span class="text-dark">Tổng cộng</span>
                                            <span class="text-primary">@totalCost.ToString("N0") ₫</span>
                                        </div>
                                    }
                                    else
                                    {
                                        <div class="text-center text-muted py-3">
                                            <i class="bi bi-info-circle d-block mb-2 fs-4"></i>
                                            <small>Chưa có báo giá</small>
                                        </div>
                                    }
                                </div>

                                <button class="btn-confirm w-100 d-flex align-items-center justify-content-center gap-2" onclick="xacNhanBaoGia('@Model.Id')">
                                    <span>Đồng ý sửa chữa ngay</span>
                                    <i class="bi bi-arrow-right"></i>
                                </button>
                            </div>
                        }
                        else
                        {
                            <div class="info-card animate-slide-in-right" style="animation-delay: 0.4s;">
                                <div class="d-flex align-items-center gap-3 border-bottom pb-3 mb-4">
                                    <div class="bg-light rounded-circle p-2">
                                        <i class="bi bi-receipt text-primary"></i>
                                    </div>
                                    <h3 class="fw-bold text-dark mb-0 fs-5">Trạng thái</h3>
                                </div>
                                
                                <div class="text-center py-5">
                                    <div class="bg-@(Model.TrangThai == "done" ? "success" : "primary") bg-opacity-10 rounded-circle d-inline-flex align-items-center justify-content-center mb-4" style="width: 100px; height: 100px;">
                                        <i class="bi bi-@(Model.TrangThai == "done" ? "box-seam" : "wrench") text-@(Model.TrangThai == "done" ? "success" : "primary")" style="font-size: 3rem;"></i>
                                    </div>
                                    <h4 class="fw-bold text-dark fs-4 mb-2">
                                        @(Model.TrangThai == "done" ? "Đã hoàn tất!" : "Đang xử lý")
                                    </h4>
                                    <p class="text-muted">
                                        @(Model.TrangThai == "done" ? "Thiết bị của bạn đã sẵn sàng. Mời quý khách đến cửa hàng nhận máy." : "Kỹ thuật viên đang làm việc chăm chỉ để sớm hoàn thành.")
                                    </p>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
    }
    else
    {
        <div class="min-vh-100 d-flex align-items-center justify-content-center">
            <div class="text-center">
                <i class="bi bi-exclamation-triangle text-warning" style="font-size: 4rem;"></i>
                <h2 class="fw-bold text-dark mt-3 mb-2">Không tìm thấy phiếu</h2>
                <p class="text-muted mb-4">Không tìm thấy thông tin phiếu sửa chữa với mã hoặc số điện thoại này.</p>
                <a href="/" class="btn btn-primary">Quay lại trang chủ</a>
            </div>
        </div>
    }

    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.js"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.css" />
    <script>
        toastr.options = {
            "closeButton": true,
            "positionClass": "toast-top-right",
            "timeOut": "3000"
        };

        function xacNhanBaoGia(ticketId) {
            if (!confirm('Xác nhận đồng ý với báo giá và tiến hành sửa chữa?')) {
                return;
            }

            $.ajax({
                url: '/Home/XacNhanBaoGia',
                type: 'POST',
                data: { ticketId: ticketId },
                success: function(response) {
                    if (response.success) {
                        toastr.success('Đã xác nhận báo giá. Chúng tôi sẽ tiến hành sửa chữa ngay!');
                        setTimeout(() => location.reload(), 1500);
                    } else {
                        toastr.error(response.message || 'Có lỗi xảy ra.');
                    }
                },
                error: function() {
                    toastr.error('Có lỗi xảy ra khi xác nhận.');
                }
            });
        }
    </script>
</body>
</html>
