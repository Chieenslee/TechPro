@model PhieuSuaChua
@{
    ViewData["Title"] = "Tra cứu trạng thái sửa chữa";
    Layout = "_Layout";
}

<div class="tracking-wrap min-vh-100 position-relative py-5">
    <!-- Animated SVG Background -->
    <div class="position-absolute w-100 h-100 top-0 start-0 overflow-hidden" style="z-index: -1;">
        <svg class="bg-shape" viewBox="0 0 100 100" preserveAspectRatio="none">
            <path fill="rgba(79, 70, 229, 0.03)" d="M0,0 Q50,100 100,0 L100,100 L0,100 Z" />
        </svg>
        <div class="blob blob-1"></div>
        <div class="blob blob-2"></div>
    </div>

    @if (Model != null)
    {
        var currentIndex = Model.TrangThai switch
        {
            "pending" => 0,
            "waiting_parts" => 1,
            "repairing" => 2,
            "done" => 3,
            "delivered" => 4,
            _ => 0
        };
        
        var isWaitingQuote = Model.TrangThai == "waiting_parts";
        var statusClass = Model.TrangThai == "done" ? "done" : Model.TrangThai == "delivered" ? "delivered" : isWaitingQuote ? "warning" : "active";
        var statusText = Model.TrangThai == "done" ? "Hoàn tất sửa chữa, Sẵn sàng giao trả" : 
                         Model.TrangThai == "delivered" ? "Đã Giao Khách" : 
                        Model.TrangThai == "waiting_parts" ? "Chờ khách xác nhận báo giá" :
                        Model.TrangThai == "repairing" ? "Kỹ thuật đang khắc phục" : "Đã tiếp nhận thiết bị";

        <div class="container mt-4 mb-5">
            <div class="row justify-content-center">
                <div class="col-lg-10">
                    <div class="d-flex align-items-center mb-4 fade-in-up" style="animation-delay: 0.1s">
                        <a href="/" class="btn btn-light rounded-circle shadow-sm me-3" style="width: 48px; height: 48px; display: inline-flex; align-items: center; justify-content: center;">
                            <i class="bi bi-arrow-left fs-5"></i>
                        </a>
                        <div>
                            <h2 class="fw-bolder text-slate-800 mb-0">Tiến Độ Sửa Chữa</h2>
                            <p class="text-slate-500 mb-0">Mã phiếu: <span class="fw-bold text-primary font-monospace">@Model.Id</span></p>
                        </div>
                    </div>

                    <!-- Hero Device Card -->
                    <div class="card glass-card border-0 rounded-4 overflow-hidden shadow-lg mb-5 fade-in-up" style="animation-delay: 0.2s">
                        <div class="card-body p-4 p-md-5 position-relative">
                            <div class="row align-items-center">
                                <div class="col-md-7 z-1">
                                    <div class="badge bg-indigo-50 text-indigo-600 rounded-pill px-3 py-2 mb-3 fw-bold border border-indigo-100">
                                        <i class="bi bi-phone me-1"></i> Thiết Bị Sửa Chữa
                                    </div>
                                    <h1 class="display-5 fw-bold text-slate-900 mb-2">@Model.TenThietBi</h1>
                                    <div class="d-flex align-items-center text-slate-500 mb-4 font-monospace">
                                        <i class="bi bi-upc-scan me-2"></i> SNR: @(Model.SerialNumber ?? "Không xác định")
                                    </div>
                                    
                                    <div class="status-banner @statusClass p-3 rounded-3 d-inline-flex align-items-center">
                                        <div class="status-pulse me-3"></div>
                                        <div>
                                            <div class="small fw-bold text-uppercase opacity-75">Trạng thái hiện tại</div>
                                            <div class="fs-5 fw-bold">@statusText</div>
                                        </div>
                                    </div>
                                </div>
                                <div class="col-md-5 d-none d-md-block position-relative h-100 z-1 text-center">
                                    <img src="https://cdni.iconscout.com/illustration/premium/thumb/repair-service-illustration-download-in-svg-png-gif-file-formats--technician-fixing-repairing-maintenance-pack-business-illustrations-1786568.png" 
                                         alt="Repair Device" class="img-fluid floating-img" style="max-height: 250px; filter: drop-shadow(0 20px 30px rgba(0,0,0,0.1));" />
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Progress Stepper -->
                    <div class="card glass-card border-0 rounded-4 p-4 p-md-5 mb-5 shadow-sm fade-in-up" style="animation-delay: 0.3s">
                        <h4 class="fw-bold text-slate-800 mb-5 d-flex align-items-center">
                            <i class="bi bi-layers text-primary me-2"></i> Lộ Trình Phục Hồi
                        </h4>

                        <div class="stepper-wrapper">
                            @{
                                var steps = new[]
                                {
                                    new { Label = "Tiếp Nhận", Desc = "Nhận máy", Icon = "bi-clipboard-check", Status = currentIndex >= 0 ? "completed" : "pending" },
                                    new { Label = "Chẩn Đoán", Desc = "Báo giá", Icon = "bi-search", Status = currentIndex == 1 ? (isWaitingQuote ? "warning" : "current") : currentIndex > 1 ? "completed" : "pending" },
                                    new { Label = "Sửa Chữa", Desc = "Xử lý", Icon = "bi-tools", Status = currentIndex == 2 ? "current" : currentIndex > 2 ? "completed" : "pending" },
                                    new { Label = "Test Lỗi", Desc = "QC done", Icon = "bi-shield-check", Status = currentIndex == 3 ? "current" : currentIndex > 3 ? "completed" : "pending" },
                                    new { Label = "Bàn Giao", Desc = "Hoàn tất", Icon = "bi-box-seam", Status = currentIndex >= 4 ? "completed" : "pending" }
                                };
                            }

                            @for (int i = 0; i < steps.Length; i++)
                            {
                                var step = steps[i];
                                <div class="stepper-item @step.Status">
                                    <div class="step-counter">
                                        @if (step.Status == "completed") { <i class="bi bi-check-lg text-white fs-5"></i> }
                                        else { <i class="bi @step.Icon fs-5"></i> }
                                    </div>
                                    <div class="step-name text-uppercase fw-bold mt-3">@step.Label</div>
                                    <div class="step-desc text-muted small mt-1">@step.Desc</div>
                                </div>
                            }
                        </div>
                    </div>

                    <!-- Details Row -->
                    <div class="row g-4 mb-5 fade-in-up" style="animation-delay: 0.4s">
                        <!-- Left Details -->
                        <div class="col-md-7">
                            <div class="card glass-card border-0 rounded-4 h-100 shadow-sm p-4 p-md-5">
                                <h5 class="fw-bold text-slate-800 mb-4 border-bottom border-slate-200 pb-3">
                                    <i class="bi bi-file-earmark-text text-primary me-2"></i> Hồ Sơ Kỹ Thuật
                                </h5>
                                
                                <div class="mb-4">
                                    <label class="text-uppercase text-slate-400 fw-bold small mb-1" style="letter-spacing: 1px;">Khách Hàng</label>
                                    <p class="fs-5 fw-bold text-slate-800 mb-1">@Model.TenKhachHang</p>
                                    <p class="text-slate-500 font-monospace bg-slate-50 d-inline-block px-3 py-1 rounded-pill">
                                        <i class="bi bi-telephone-fill opacity-50 me-1"></i>
                                        @Model.SoDienThoai.Substring(0, Math.Min(3, Model.SoDienThoai.Length))****@Model.SoDienThoai.Substring(Math.Max(0, Model.SoDienThoai.Length - 3))
                                    </p>
                                </div>

                                <div>
                                    <label class="text-uppercase text-slate-400 fw-bold small mb-2" style="letter-spacing: 1px;">Lời Khai Lỗi / Vấn Đề</label>
                                    <div class="bg-red-50 border-start border-red-500 border-4 rounded-end p-3 text-red-900 fw-medium">
                                        "@(Model.MoTaLoi ?? "Chưa có ghi chú mô tả lỗi.")"
                                    </div>
                                </div>
                                
                                @if(!string.IsNullOrEmpty(Model.KetQuaKiemTra))
                                {
                                    <div class="mt-4">
                                        <label class="text-uppercase text-slate-400 fw-bold small mb-2" style="letter-spacing: 1px;">Kết Luận Của Kỹ Thuật Viên</label>
                                        <div class="bg-blue-50 border-start border-blue-500 border-4 rounded-end p-3 text-blue-900 fw-medium font-monospace">
                                            @Html.Raw(Model.KetQuaKiemTra.Replace("\n", "<br/>"))
                                        </div>
                                    </div>
                                }
                            </div>
                        </div>

                        <!-- Right Actions / Quote -->
                        <div class="col-md-5">
                            @if (isWaitingQuote)
                            {
                                <div class="card glass-card border-0 rounded-4 shadow-lg quote-glow h-100">
                                    <div class="card-body p-4 p-md-5 position-relative flex-column d-flex">
                                        <div class="bg-warning-subtle text-warning-emphasis rounded-circle d-inline-flex align-items-center justify-content-center mb-4 mx-auto" style="width: 80px; height: 80px;">
                                            <i class="bi bi-receipt" style="font-size: 2.5rem;"></i>
                                        </div>
                                        
                                        <h4 class="fw-bold text-center text-slate-800 mb-2">Báo Giá Sửa Chữa</h4>
                                        <p class="text-center text-slate-500 small mb-4">Vui lòng xem và xác nhận chi phí để chúng tôi tiến hành cấp linh kiện & sửa chữa.</p>
                                        
                                        <div class="bg-white rounded-4 p-3 mb-4 shadow-sm border border-slate-100 flex-grow-1">
                                            @{
                                                var partsList = ViewBag.PartsList as IEnumerable<dynamic> ?? new List<dynamic>();
                                                var partsCost = ViewBag.PartsCost as decimal? ?? 0;
                                                var serviceFee = ViewBag.ServiceFee as decimal? ?? 0;
                                                var totalCost = ViewBag.TotalCost as decimal? ?? 0;
                                            }
                                            
                                            @foreach (var part in partsList)
                                            {
                                                <div class="d-flex justify-content-between align-items-center text-slate-700 mb-3 border-bottom border-slate-50 pb-2">
                                                    <span class="fs-6"><i class="bi bi-cpu text-slate-400 me-2"></i> @part.Name @(part.Quantity > 1 ? $"x{part.Quantity}" : "")</span>
                                                    <span class="fw-bold font-monospace">@((part.Price * part.Quantity).ToString("N0"))₫</span>
                                                </div>
                                            }
                                            
                                            <div class="d-flex flex-column gap-2 mt-3 pt-3">
                                                <div class="d-flex justify-content-between align-items-center text-slate-500 small">
                                                    <span>Tổng phí linh kiện</span>
                                                    <span>@partsCost.ToString("N0")₫</span>
                                                </div>
                                                <div class="d-flex justify-content-between align-items-center text-slate-500 small">
                                                    <span>Công thay & Bảo hành</span>
                                                    <span>@(Model.CoBaoHanh == true ? "Miễn phí" : serviceFee.ToString("N0") + "₫")</span>
                                                </div>
                                            </div>
                                            
                                            <div class="mt-4 pt-3 border-top border-slate-200 d-flex justify-content-between align-items-center">
                                                <span class="fw-bold text-slate-600">TỔNG CỘNG</span>
                                                <span class="fs-4 fw-bolder text-primary font-monospace">@totalCost.ToString("N0")₫</span>
                                            </div>
                                        </div>

                                        <button class="btn btn-primary rounded-pill py-3 fw-bold w-100 hover-lift shadow d-flex justify-content-center align-items-center gap-2" onclick="xacNhanBaoGia('@Model.Id')">
                                            <i class="bi bi-shield-check fs-5"></i>
                                            Đồng Ý Duyệt Báo Giá
                                        </button>
                                        @Html.AntiForgeryToken()
                                    </div>
                                </div>
                            }
                            else
                            {
                                <div class="card glass-card border-0 rounded-4 shadow-sm h-100 d-flex flex-column align-items-center justify-content-center p-5 text-center">
                                    <div class="status-big-icon mb-4 @statusClass">
                                        @if(Model.TrangThai == "done" || Model.TrangThai == "delivered") {
                                            <i class="bi bi-box-seam fill-current"></i>
                                        } else if (Model.TrangThai == "repairing") {
                                            <i class="bi bi-tools fill-current spinning"></i>
                                        } else {
                                            <i class="bi bi-hourglass-split fill-current spinning-slow"></i>
                                        }
                                    </div>
                                    <h4 class="fw-bold text-slate-800 mb-2">@statusText</h4>
                                    <p class="text-slate-500 mb-4">
                                        @if (Model.TrangThai == "done") {
                                            @:Chiến binh công nghệ của bạn đã hồi sinh. Hãy mang biên nhận đến cửa hàng để rước máy về nhé!
                                        } else if (Model.TrangThai == "delivered") {
                                            @:Máy đã được xuất trả. Cảm ơn quý khách đã tin tưởng và sử dụng dịch vụ tại TechPro!
                                        } else if (Model.TrangThai == "repairing") {
                                            @:Các y bác sĩ linh kiện đang thao tác phẫu thuật. Vui lòng quay lại sau ít phút để xem kết quả.
                                        } else {
                                            @:Thiết bị đang nằm trong hàng đợi để được kỹ thuật viên mở máy kiểm tra.
                                        }
                                    </p>
                                    
                                    @if(Model.TrangThai == "done") {
                                        <div class="bg-green-50 text-green-700 py-3 px-4 rounded-4 w-100 text-center border border-green-200 shadow-sm fw-bold">
                                            <i class="bi bi-wallet2 me-2"></i> Vui lòng thanh toán tại quầy
                                        </div>
                                    }
                                </div>
                            }
                        </div>
                    </div>
                </div>
            </div>
        </div>
    }
    else
    {
        <div class="container h-100 d-flex align-items-center justify-content-center" style="min-height: 80vh;">
            <div class="text-center fade-in-up">
                <div class="bg-red-50 text-red-500 rounded-circle d-inline-flex align-items-center justify-content-center mb-4" style="width: 120px; height: 120px;">
                    <i class="bi bi-search text-danger" style="font-size: 3rem;"></i>
                </div>
                <h2 class="display-6 fw-bold text-slate-800 mb-3">Mất Dấu Vết</h2>
                <p class="text-slate-500 fs-5 mb-5 mx-auto" style="max-width: 500px;">
                    Cỗ máy của bạn dường như không tồn tại trong hệ thống. Vui lòng kiểm tra lại số SĐT hoặc Mã phiếu.
                </p>
                <a href="/" class="btn btn-primary rounded-pill px-5 py-3 fw-bold hover-lift shadow-sm">
                    <i class="bi bi-house me-2"></i> Quay Lại Trang Chủ
                </a>
            </div>
        </div>
    }
</div>

@section Styles {
    <style>
        /* Modern Fonts & Utility Core */
        @@import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=JetBrains+Mono:wght@400;700&display=swap');
        body { background-color: #f8fafc; font-family: 'Inter', sans-serif; }
        .font-monospace { font-family: 'JetBrains Mono', monospace; }
        
        .text-slate-400 { color: #94a3b8; }
        .text-slate-500 { color: #64748b; }
        .text-slate-600 { color: #475569; }
        .text-slate-700 { color: #334155; }
        .text-slate-800 { color: #1e293b; }
        .text-slate-900 { color: #0f172a; }
        
        .bg-slate-50 { background-color: #f8fafc; }
        .border-slate-50 { border-color: #f8fafc!important; }
        .border-slate-100 { border-color: #f1f5f9!important; }
        .border-slate-200 { border-color: #e2e8f0!important; }
        
        .bg-indigo-50 { background-color: #eef2ff; }
        .text-indigo-600 { color: #4f46e5; }
        .border-indigo-100 { border-color: #e0e7ff!important; }
        
        .bg-red-50 { background-color: #fef2f2; }
        .text-red-500 { color: #ef4444; }
        .text-red-900 { color: #7f1d1d; }
        .border-red-500 { border-color: #ef4444!important; }
        
        .bg-blue-50 { background-color: #eff6ff; }
        .text-blue-900 { color: #1e3a8a; }
        .border-blue-500 { border-color: #3b82f6!important; }

        .bg-green-50 { background-color: #f0fdf4; }
        .text-green-700 { color: #15803d; }
        .border-green-200 { border-color: #bbf7d0!important; }

        /* Background SVGs & Blobs */
        .bg-shape { position: absolute; width: 100%; height: 600px; bottom: 0; left: 0; transform: translateY(50%); z-index: -1; }
        .blob { position: absolute; filter: blur(80px); opacity: 0.6; z-index: -1; border-radius: 50%; }
        .blob-1 { top: -10%; left: -10%; width: 500px; height: 500px; background: rgba(168, 85, 247, 0.15); animation: float 10s ease-in-out infinite; }
        .blob-2 { bottom: 10%; right: -5%; width: 400px; height: 400px; background: rgba(59, 130, 246, 0.15); animation: float 12s ease-in-out infinite reverse; }
        
        @@keyframes float {
            0%, 100% { transform: translateY(0) scale(1); }
            50% { transform: translateY(-30px) scale(1.05); }
        }

        /* Glassmorphism Cards */
        .glass-card {
            background: rgba(255, 255, 255, 0.85);
            backdrop-filter: blur(12px);
            -webkit-backdrop-filter: blur(12px);
            border: 1px solid rgba(255, 255, 255, 0.3) !important;
        }

        /* Status Banners */
        .status-banner { color: white; transition: all 0.3s ease; }
        .status-banner.active { background: linear-gradient(135deg, #3b82f6, #2563eb); box-shadow: 0 10px 20px -5px rgba(59,130,246,0.3); }
        .status-banner.warning { background: linear-gradient(135deg, #f59e0b, #d97706); box-shadow: 0 10px 20px -5px rgba(245,158,11,0.3); }
        .status-banner.done { background: linear-gradient(135deg, #10b981, #059669); box-shadow: 0 10px 20px -5px rgba(16,185,129,0.3); }
        .status-banner.delivered { background: linear-gradient(135deg, #64748b, #475569); box-shadow: 0 10px 20px -5px rgba(100,116,139,0.3); }
        
        .status-pulse {
            width: 14px; height: 14px; border-radius: 50%;
            background-color: white; box-shadow: 0 0 0 0 rgba(255,255,255,1);
            animation: pulsing 2s infinite;
        }
        @@keyframes pulsing {
            0% { transform: scale(0.95); box-shadow: 0 0 0 0 rgba(255, 255, 255, 0.7); }
            70% { transform: scale(1); box-shadow: 0 0 0 10px rgba(255, 255, 255, 0); }
            100% { transform: scale(0.95); box-shadow: 0 0 0 0 rgba(255, 255, 255, 0); }
        }

        .status-big-icon { width: 120px; height: 120px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 3.5rem; }
        .status-big-icon.active { background: #eff6ff; color: #3b82f6; }
        .status-big-icon.warning { background: #fffbeb; color: #f59e0b; }
        .status-big-icon.done { background: #f0fdf4; color: #10b981; }
        .status-big-icon.delivered { background: #f8fafc; color: #64748b; }
        .spinning { animation: spin 3s linear infinite; }
        .spinning-slow { animation: spin 8s linear infinite; }
        @@keyframes spin { 100% { transform: rotate(360deg); } }

        /* Progress Stepper */
        .stepper-wrapper {
            display: flex; position: relative; justify-content: space-between; align-items: flex-start;
        }
        .stepper-wrapper::before {
            content: ''; position: absolute; height: 4px; background: #e2e8f0; width: 100%; top: 22px; left: 0; z-index: 1; border-radius: 2px;
        }
        .stepper-item {
            position: relative; display: flex; flex-direction: column; align-items: center; flex: 1; z-index: 2; text-align: center;
        }
        .step-counter {
            width: 48px; height: 48px; border-radius: 50%; display: flex; align-items: center; justify-content: center;
            background: #f8fafc; border: 4px solid #e2e8f0; color: #cbd5e1; transition: all 0.4s ease;
        }
        
        .stepper-item.completed .step-counter { background: #10b981; border-color: #10b981; color: white; box-shadow: 0 0 0 4px rgba(16,185,129,0.2); }
        .stepper-item.completed ~ .stepper-item::after { content: ''; position: absolute; height: 4px; background: #10b981; width: 100%; top: 22px; left: -50%; z-index: -1; transition: all 0.5s ease; }
        
        .stepper-item.current .step-counter { background: #3b82f6; border-color: white; color: white; box-shadow: 0 0 0 4px #3b82f6; transform: scale(1.15); animation: pulseCurrent 2s infinite; }
        .stepper-item.current .step-name { color: #3b82f6; }
        
        .stepper-item.warning .step-counter { background: #f59e0b; border-color: white; color: white; box-shadow: 0 0 0 4px #f59e0b; transform: scale(1.15); animation: pulseWarning 2s infinite; }
        .stepper-item.warning .step-name { color: #f59e0b; }
        
        @@keyframes pulseCurrent { 0% { box-shadow: 0 0 0 0 rgba(59, 130, 246, 0.4); } 70% { box-shadow: 0 0 0 10px rgba(59, 130, 246, 0); } 100% { box-shadow: 0 0 0 0 rgba(59, 130, 246, 0); } }
        @@keyframes pulseWarning { 0% { box-shadow: 0 0 0 0 rgba(245, 158, 11, 0.4); } 70% { box-shadow: 0 0 0 10px rgba(245, 158, 11, 0); } 100% { box-shadow: 0 0 0 0 rgba(245, 158, 11, 0); } }

        /* Quotes & Cards */
        .quote-glow { position: relative; }
        .quote-glow::after { content: ""; position: absolute; top: -2px; left: -2px; right: -2px; bottom: -2px; background: linear-gradient(45deg, #f59e0b, #fbbf24, #f59e0b); z-index: -1; border-radius: 17px; animation: gradientMove 3s ease infinite; background-size: 200% 200%; }
        @@keyframes gradientMove { 0% { background-position: 0% 50%; } 50% { background-position: 100% 50%; } 100% { background-position: 0% 50%; } }

        .hover-lift { transition: transform 0.2s cubic-bezier(0.34, 1.56, 0.64, 1), box-shadow 0.2s; }
        .hover-lift:hover { transform: translateY(-4px); box-shadow: 0 15px 30px -5px rgba(0, 0, 0, 0.1) !important; }
        .floating-img { animation: floatImage 4s ease-in-out infinite; }
        @@keyframes floatImage { 0%, 100% { transform: translateY(0); } 50% { transform: translateY(-15px); } }

        /* In animations */
        .fade-in-up { opacity: 0; transform: translateY(30px); animation: fadeInUp 0.8s cubic-bezier(0.16, 1, 0.3, 1) forwards; }
        @@keyframes fadeInUp { to { opacity: 1; transform: translateY(0); } }

        @@media (max-width: 768px) {
            .stepper-wrapper { flex-direction: column; align-items: flex-start; padding-left: 24px; gap: 24px; }
            .stepper-wrapper::before { width: 4px; height: 100%; left: 46px; top: 0; }
            .stepper-item { flex-direction: row; align-items: flex-start; text-align: left; }
            .step-name { margin-top: 0 !important; margin-left: 1rem; align-self: center;}
            .step-desc { display: none; }
            .stepper-item.completed ~ .stepper-item::after { display: none; }
        }
    </style>
}

@section Scripts {
    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.js"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.css" />
    <script>
        toastr.options = { "closeButton": true, "positionClass": "toast-top-right", "timeOut": "3000" };

        function xacNhanBaoGia(ticketId) {
            if (!confirm('Xác nhận đồng ý với báo giá và tiến hành sửa chữa?')) return;

            var token = $('input[name="__RequestVerificationToken"]').val();

            const btn = document.querySelector('.btn-primary');
            const originalContent = btn.innerHTML;
            btn.innerHTML = '<span class="spinner-border spinner-border-sm me-2" role="status" aria-hidden="true"></span> Đang xử lý...';
            btn.disabled = true;

            $.ajax({
                url: '/Home/XacNhanBaoGia',
                type: 'POST',
                data: { ticketId: ticketId, __RequestVerificationToken: token },
                success: function(response) {
                    if (response.success) {
                        toastr.success('Hệ thống đã nhận lệnh! Kỹ thuật viên sẽ mổ máy ngay bây giờ.');
                        setTimeout(() => location.reload(), 1500);
                    } else {
                        toastr.error(response.message || 'Lỗi bất ngờ.');
                        btn.innerHTML = originalContent;
                        btn.disabled = false;
                    }
                },
                error: function() {
                    toastr.error('Mất kết nối với máy chủ.');
                    btn.innerHTML = originalContent;
                    btn.disabled = false;
                }
            });
        }
    </script>
}
