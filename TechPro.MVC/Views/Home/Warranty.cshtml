@model TechPro.Models.ViewModels.WarrantyCheckViewModel
@{
    ViewData["Title"] = "Kết Quả Tra Cứu Bảo Hành";
    Layout = "_Layout";
}

<div class="warranty-wrap min-vh-100 position-relative py-5">
    <!-- Animated SVG Background -->
    <div class="position-absolute w-100 h-100 top-0 start-0 overflow-hidden" style="z-index: -1;">
        <svg class="bg-shape" viewBox="0 0 100 100" preserveAspectRatio="none">
            <path fill="rgba(16, 185, 129, 0.03)" d="M0,100 C20,0 50,0 100,100 Z" />
        </svg>
        <div class="blob blob-1"></div>
        <div class="blob blob-2"></div>
    </div>

    <div class="container mt-4 mb-5">
        <div class="row justify-content-center">
            <div class="col-lg-8">
                <div class="d-flex align-items-center mb-5 fade-in-up" style="animation-delay: 0.1s">
                    <a href="/" class="btn btn-light rounded-circle shadow-sm me-3" style="width: 48px; height: 48px; display: inline-flex; align-items: center; justify-content: center;">
                        <i class="bi bi-arrow-left fs-5"></i>
                    </a>
                    <div>
                        <h2 class="fw-bolder text-slate-800 mb-0">Tra Cứu Bảo Hành</h2>
                        <p class="text-slate-500 mb-0">Hệ Thống Trung Tâm Bảo Hành Ủy Quyền</p>
                    </div>
                </div>

                @if (Model != null)
                {
                    <div class="card glass-card border-0 rounded-4 overflow-hidden shadow-lg fade-in-up" style="animation-delay: 0.2s">
                        <!-- Top Banner Banner -->
                        <div class="position-relative p-5 text-center overflow-hidden @(Model.IsValid ? "bg-gradient-success" : "bg-gradient-danger")">
                            <div class="z-1 relative">
                                <div class="bg-white rounded-circle d-inline-flex align-items-center justify-content-center shadow-lg mb-4 icon-pulse" style="width: 100px; height: 100px;">
                                    <i class="bi bi-@(Model.IsValid ? "shield-check text-success" : "shield-x text-danger")" style="font-size: 3.5rem;"></i>
                                </div>
                                <h1 class="display-6 fw-bold text-white mb-2 text-shadow">@Model.Model</h1>
                                <div class="badge bg-white text-dark rounded-pill px-4 py-2 fs-6 shadow-sm font-monospace">
                                    <i class="bi bi-upc-scan me-2 text-muted"></i>@Model.SerialNumber
                                </div>
                            </div>
                            <!-- Background Pattern Decals -->
                            <i class="bi bi-@(Model.IsValid ? "patch-check" : "patch-exclamation") position-absolute text-white opacity-10" style="font-size: 15rem; right: -20px; top: -50px; transform: rotate(15deg);"></i>
                        </div>

                        <!-- Info Grid -->
                        <div class="card-body p-4 p-md-5 bg-white bg-opacity-75">
                            <div class="text-center mb-5">
                                @if (Model.IsValid)
                                {
                                    <h3 class="fw-bold text-success mb-2 d-flex align-items-center justify-content-center gap-2">
                                        <i class="bi bi-check-circle-fill"></i> THIẾT BỊ CÒN HẠN BẢO HÀNH
                                    </h3>
                                    <p class="text-slate-500">Thiết bị của bạn được áp dụng chính sách sửa chữa, thay thế linh kiện miễn phí đối với các lỗi từ nhà sản xuất.</p>
                                }
                                else
                                {
                                    <h3 class="fw-bold text-danger mb-2 d-flex align-items-center justify-content-center gap-2">
                                        <i class="bi bi-x-circle-fill"></i> THIẾT BỊ ĐÃ HẾT HẠN BẢO HÀNH
                                    </h3>
                                    <p class="text-slate-500">Rất tiếc, thiết bị của bạn đã vượt quá thời hạn bảo hành tiêu chuẩn. Vui lòng tham khảo bảng giá dịch vụ ưu đãi.</p>
                                }
                            </div>

                            <div class="row g-4 mb-5">
                                <div class="col-md-6">
                                    <div class="bg-slate-50 border border-slate-100 rounded-4 p-4 h-100 d-flex flex-column align-items-center justify-content-center hover-lift transition-all">
                                        <i class="bi bi-calendar2-check text-primary fs-2 mb-2"></i>
                                        <span class="text-uppercase small fw-bold text-slate-400 mb-1" style="letter-spacing: 1px;">Ngày Mua Hàng</span>
                                        <h4 class="fw-bold text-slate-800 mb-0">@Model.PurchaseDate</h4>
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <div class="bg-slate-50 border border-slate-100 rounded-4 p-4 h-100 d-flex flex-column align-items-center justify-content-center hover-lift transition-all">
                                        <i class="bi bi-calendar2-x @(Model.IsValid ? "text-success" : "text-danger") fs-2 mb-2"></i>
                                        <span class="text-uppercase small fw-bold text-slate-400 mb-1" style="letter-spacing: 1px;">Ngày Hết Hạn</span>
                                        <h4 class="fw-bold @(Model.IsValid ? "text-success" : "text-danger") mb-0">@Model.EndDate</h4>
                                    </div>
                                </div>
                            </div>
                            
                            <hr class="border-slate-200 mb-4">

                            <!-- Call to Actions -->
                            <div class="d-flex flex-column flex-sm-row gap-3">
                                <a href="/Home/DatLich" class="btn btn-primary rounded-pill py-3 px-4 fw-bold flex-fill hover-lift shadow-sm d-flex justify-content-center align-items-center gap-2">
                                    <i class="bi bi-calendar-plus fs-5"></i> Đặt Lịch Sửa Chữa Trực Tuyến
                                </a>
                                <a href="tel:19006868" class="btn btn-outline-primary rounded-pill py-3 px-4 fw-bold flex-fill hover-lift d-flex justify-content-center align-items-center gap-2 bg-white">
                                    <i class="bi bi-telephone fs-5"></i> Gọi Tổng Đài: 1900 6868
                                </a>
                            </div>
                        </div>
                    </div>
                }
                else
                {
                    <div class="card glass-card border-0 rounded-4 shadow-sm h-100 d-flex flex-column align-items-center justify-content-center p-5 text-center mt-5 fade-in-up">
                        <div class="bg-red-50 text-red-500 rounded-circle d-inline-flex align-items-center justify-content-center mb-4" style="width: 120px; height: 120px;">
                            <i class="bi bi-shield-slash text-danger" style="font-size: 3.5rem;"></i>
                        </div>
                        <h2 class="display-6 fw-bold text-slate-800 mb-3">Không Tìm Thấy Data</h2>
                        <p class="text-slate-500 fs-5 mb-5 mx-auto" style="max-width: 500px;">
                            Số Serial Number hoặc IMEI này không tồn tại trong hệ thống lịch sử bán hàng. Vui lòng kiểm tra lại thật kỹ.
                        </p>
                        <a href="/" class="btn btn-primary rounded-pill px-5 py-3 fw-bold hover-lift shadow-sm text-uppercase" style="letter-spacing: 1px;">
                            <i class="bi bi-house me-2"></i> Thử Lại Ngay
                        </a>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

@section Styles {
    <style>
        /* Core Typeface & Palette */
        @@import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=JetBrains+Mono:wght@400;700&display=swap');
        body { background-color: #f8fafc; font-family: 'Inter', sans-serif; }
        .font-monospace { font-family: 'JetBrains Mono', monospace; }
        
        .text-slate-400 { color: #94a3b8; }
        .text-slate-500 { color: #64748b; }
        .text-slate-600 { color: #475569; }
        .text-slate-700 { color: #334155; }
        .text-slate-800 { color: #1e293b; }
        .text-slate-900 { color: #0f172a; }
        
        .bg-slate-50 { background-color: #f8fafc; }
        .border-slate-50 { border-color: #f8fafc!important; }
        .border-slate-100 { border-color: #f1f5f9!important; }
        .border-slate-200 { border-color: #e2e8f0!important; }
        
        .bg-gradient-success { background: linear-gradient(135deg, #10b981 0%, #059669 100%); }
        .bg-gradient-danger { background: linear-gradient(135deg, #ef4444 0%, #dc2626 100%); }
        .text-shadow { text-shadow: 0 4px 10px rgba(0,0,0,0.15); }
        .z-1 { z-index: 1; }
        .relative { position: relative; }

        .bg-red-50 { background-color: #fef2f2; }
        .text-red-500 { color: #ef4444; }

        /* Background Art */
        .bg-shape { position: absolute; width: 100%; height: 600px; top: 0; left: 0; transform: translateY(-30%); z-index: -1; }
        .blob { position: absolute; filter: blur(90px); opacity: 0.5; z-index: -1; border-radius: 50%; mix-blend-mode: multiply; }
        .blob-1 { top: -10%; left: -10%; width: 400px; height: 400px; background: rgba(16, 185, 129, 0.2); animation: float 14s ease-in-out infinite; }
        .blob-2 { bottom: -20%; right: -10%; width: 500px; height: 500px; background: rgba(59, 130, 246, 0.15); animation: float 18s ease-in-out infinite reverse; }
        
        @@keyframes float {
            0%, 100% { transform: translate(0, 0) scale(1); }
            33% { transform: translate(30px, -50px) scale(1.1); }
            66% { transform: translate(-20px, 20px) scale(0.9); }
        }

        /* Glassmorphism */
        .glass-card {
            background: rgba(255, 255, 255, 0.9);
            backdrop-filter: blur(20px);
            -webkit-backdrop-filter: blur(20px);
            border: 1px solid rgba(255, 255, 255, 0.5) !important;
        }

        /* Hover Physics */
        .hover-lift { transition: transform 0.25s cubic-bezier(0.34, 1.56, 0.64, 1), box-shadow 0.25s; }
        .hover-lift:hover { transform: translateY(-5px); box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.1), 0 10px 10px -5px rgba(0, 0, 0, 0.04) !important; }
        
        .transition-all { transition: all 0.3s ease; }

        .icon-pulse { animation: pulsingLight 2.5s infinite; }
        @@keyframes pulsingLight {
            0% { box-shadow: 0 0 0 0 rgba(255, 255, 255, 0.6); }
            70% { box-shadow: 0 0 0 15px rgba(255, 255, 255, 0); }
            100% { box-shadow: 0 0 0 0 rgba(255, 255, 255, 0); }
        }

        /* Start Sequences */
        .fade-in-up { opacity: 0; transform: translateY(40px); animation: fadeInUp 0.9s cubic-bezier(0.16, 1, 0.3, 1) forwards; }
        @@keyframes fadeInUp { to { opacity: 1; transform: translateY(0); } }
    </style>
}
