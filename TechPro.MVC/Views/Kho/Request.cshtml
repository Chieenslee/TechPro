@using TechPro.Models
@{
    ViewData["Title"] = "Yêu Cầu Linh Kiện";
    var myPartRequests = ViewBag.MyPartRequests as IEnumerable<YeuCauLinhKien> ?? Enumerable.Empty<YeuCauLinhKien>();
    var pendingCount  = myPartRequests.Count(r => r.TrangThai == "pending");
    var approvedCount = myPartRequests.Count(r => r.TrangThai == "approved");
    var rejectedCount = myPartRequests.Count(r => r.TrangThai == "rejected");
}

<div class="mb-4 d-flex align-items-center gap-3">
    <div class="rounded-3 p-2" style="background:#eff6ff;">
        <i class="bi bi-box-arrow-in-down-right text-primary fs-5"></i>
    </div>
    <div>
        <h4 class="fw-bold mb-0">Yêu Cầu Linh Kiện Của Tôi</h4>
        <p class="text-muted small mb-0">Theo dõi trạng thái linh kiện bạn đã yêu cầu từ Kho</p>
    </div>
    <a href="/Technician/KyThuat" class="btn btn-outline-primary btn-sm ms-auto rounded-pill px-3">
        <i class="bi bi-kanban me-1"></i>Quay về Kanban
    </a>
</div>

<!-- Stats -->
<div class="row g-3 mb-4">
    <div class="col-4">
        <div class="card border-0 shadow-sm rounded-4 text-center p-3" style="border-left: 4px solid #f59e0b !important;">
            <div class="fw-bolder fs-2 text-warning">@pendingCount</div>
            <div class="text-muted small">⏳ Chờ duyệt</div>
        </div>
    </div>
    <div class="col-4">
        <div class="card border-0 shadow-sm rounded-4 text-center p-3" style="border-left: 4px solid #22c55e !important;">
            <div class="fw-bolder fs-2 text-success">@approvedCount</div>
            <div class="text-muted small">✅ Đã xuất kho</div>
        </div>
    </div>
    <div class="col-4">
        <div class="card border-0 shadow-sm rounded-4 text-center p-3" style="border-left: 4px solid #ef4444 !important;">
            <div class="fw-bolder fs-2 text-danger">@rejectedCount</div>
            <div class="text-muted small">❌ Bị từ chối</div>
        </div>
    </div>
</div>

<!-- Table -->
<div class="card border-0 shadow-sm rounded-4 overflow-hidden">
    <div class="card-header bg-white border-bottom d-flex align-items-center gap-2 py-3">
        <i class="bi bi-list-check text-primary"></i>
        <span class="fw-bold">Lịch sử yêu cầu linh kiện</span>
        @if (pendingCount > 0)
        {
            <span class="badge bg-warning text-dark rounded-pill ms-1">@pendingCount đang chờ</span>
        }
    </div>

    @if (!myPartRequests.Any())
    {
        <div class="p-5 text-center text-muted">
            <i class="bi bi-inbox fs-1 text-secondary opacity-50 d-block mb-2"></i>
            <p class="mb-0">Bạn chưa có yêu cầu linh kiện nào.</p>
            <p class="small">Tạo yêu cầu từ trang <a href="/Technician/KyThuat" class="text-primary">chi tiết phiếu sửa</a>.</p>
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead style="background:#f8fafc;">
                    <tr class="text-muted small text-uppercase" style="font-size: 0.72rem; letter-spacing: 0.05em;">
                        <th class="py-3 px-4 border-0">Mã Phiếu</th>
                        <th class="py-3 px-4 border-0">Linh Kiện Yêu Cầu</th>
                        <th class="py-3 px-4 border-0 text-center">Số Lượng</th>
                        <th class="py-3 px-4 border-0">Ngày Yêu Cầu</th>
                        <th class="py-3 px-4 border-0 text-center">Trạng Thái</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var req in myPartRequests.OrderByDescending(r => r.NgayYeuCau))
                    {
                        var (badgeClass, icon, label) = req.TrangThai switch
                        {
                            "approved" => ("bg-success bg-opacity-10 text-success", "bi-check-circle-fill", "Đã xuất kho"),
                            "rejected" => ("bg-danger bg-opacity-10 text-danger",   "bi-x-circle-fill",     "Bị từ chối"),
                            _ =>          ("bg-warning bg-opacity-10 text-warning", "bi-hourglass-split",   "Chờ duyệt")
                        };
                        <tr>
                            <td class="px-4 py-3">
                                <a href="/Technician/KyThuat/ChiTiet/@req.PhieuSuaChuaId" class="fw-semibold text-primary text-decoration-none small">
                                    @req.PhieuSuaChuaId
                                    <i class="bi bi-arrow-up-right ms-1" style="font-size:0.7rem;"></i>
                                </a>
                            </td>
                            <td class="px-4 py-3 fw-medium">@(req.LinhKien?.TenLinhKien ?? $"ID: {req.LinhKienId}")</td>
                            <td class="px-4 py-3 text-center">
                                <span class="badge bg-secondary bg-opacity-10 text-secondary rounded-pill px-3">@req.SoLuong</span>
                            </td>
                            <td class="px-4 py-3 text-muted small">@req.NgayYeuCau.ToString("dd/MM/yyyy HH:mm")</td>
                            <td class="px-4 py-3 text-center">
                                <span class="badge @badgeClass rounded-pill px-3 py-2">
                                    <i class="bi @icon me-1"></i>@label
                                </span>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>
