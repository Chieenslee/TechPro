@{
    ViewData["Title"] = "Quản lý kho vận";
    var activeTab = ViewBag.ActiveTab as string ?? "inventory";
    var inventory = ViewBag.Inventory as IEnumerable<KhoLinhKien> ?? new List<KhoLinhKien>();
    var partRequests = ViewBag.PartRequests as IEnumerable<YeuCauLinhKien> ?? new List<YeuCauLinhKien>();
    var wasteReturns = ViewBag.WasteReturns as IEnumerable<TraXac> ?? new List<TraXac>();
    var pendingRequestsCount = ViewBag.PendingRequestsCount as int? ?? 0;
    var pendingWasteCount = ViewBag.PendingWasteCount as int? ?? 0;
}

<div class="mb-4">
    <h2 class="fw-bold">Quản lý kho vận</h2>
    <p class="text-muted mb-0">Theo dõi tồn kho, xuất nhập và trả xác linh kiện.</p>
</div>

<!-- Tabs -->
<ul class="nav nav-tabs mb-4">
    <li class="nav-item">
        <a class="nav-link @(activeTab == "inventory" ? "active" : "")" href="@Url.Action("Index", new { tab = "inventory" })">
            <i class="bi bi-box me-2"></i>Danh sách tồn kho
        </a>
    </li>
    @if (User.IsInRole("StoreAdmin") || User.IsInRole("SystemAdmin"))
    {
        <li class="nav-item">
            <a class="nav-link @(activeTab == "requests" ? "active" : "") position-relative" href="@Url.Action("Index", new { tab = "requests" })">
                <i class="bi bi-clock-history me-2"></i>Yêu cầu xuất kho
                @if (pendingRequestsCount > 0)
                {
                    <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger" style="font-size: 0.6rem;">@pendingRequestsCount</span>
                }
            </a>
        </li>
        <li class="nav-item">
            <a class="nav-link @(activeTab == "waste" ? "active" : "") position-relative" href="@Url.Action("Index", new { tab = "waste" })">
                <i class="bi bi-recycle me-2"></i>Trả xác linh kiện
                @if (pendingWasteCount > 0)
                {
                    <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-warning" style="font-size: 0.6rem;">@pendingWasteCount</span>
                }
            </a>
        </li>
    }
</ul>

<div class="card shadow-sm">
    <div class="card-body">
        <!-- INVENTORY TAB -->
        @if (activeTab == "inventory")
        {
            <form method="get" class="mb-4">
                <input type="hidden" name="tab" value="inventory" />
                <div class="input-group bg-slate-50 border border-slate-200 rounded-pill overflow-hidden shadow-sm custom-focus-ring" style="max-width: 400px;">
                    <span class="input-group-text bg-transparent border-0 text-slate-400 pe-1"><i class="bi bi-search"></i></span>
                    <input type="text" class="form-control border-0 bg-transparent shadow-none custom-input" name="searchTerm" 
                           value="@ViewBag.SearchTerm" placeholder="Tìm tên linh kiện, mã..." />
                    <button type="submit" class="btn btn-primary px-3 rounded-pill hover-lift shadow-sm m-1 fw-medium" style="font-size: 0.9rem;">Tìm</button>
                </div>
            </form>

            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0 pos-table">
                    <thead class="bg-slate-50 text-uppercase small fw-bold" style="letter-spacing: 0.5px; color: #64748b;">
                        <tr>
                            <th>Tên linh kiện</th>
                            <th>Danh mục</th>
                            <th>Tương thích</th>
                            <th class="text-end">Đơn giá</th>
                            <th class="text-center">Tồn kho</th>
                            <th class="text-center">Trạng thái</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in inventory)
                        {
                            <tr>
                                <td class="fw-medium">@item.TenLinhKien</td>
                                <td class="text-muted">@(item.DanhMuc ?? "N/A")</td>
                                <td class="text-muted small">@(item.DanhSachModelTuongThich ?? "N/A")</td>
                                <td class="text-end font-monospace">@item.GiaBan.ToString("N0")đ</td>
                                <td class="text-center fw-bold">@item.SoLuongTon</td>
                                <td class="text-center">
                                    @if (item.SoLuongTon == 0)
                                    {
                                        <span class="badge bg-danger">
                                            <i class="bi bi-exclamation-triangle me-1"></i>Hết hàng
                                        </span>
                                    }
                                    else if (item.SoLuongTon < 5)
                                    {
                                        <span class="badge bg-warning">
                                            <i class="bi bi-exclamation-triangle me-1"></i>Sắp hết
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-success">Sẵn sàng</span>
                                    }
                                </td>
                            </tr>
                        }
                        @if (!inventory.Any())
                        {
                            <tr>
                                <td colspan="6" class="text-center py-5 text-muted">Không tìm thấy linh kiện nào.</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }

        <!-- REQUESTS TAB -->
        @if (activeTab == "requests")
        {
            @await Html.PartialAsync("_PartRequestList", partRequests)
        }

        <!-- WASTE TAB -->
        @if (activeTab == "waste")
        {
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0 pos-table">
                    <thead class="bg-slate-50 text-uppercase small fw-bold" style="letter-spacing: 0.5px; color: #64748b;">
                        <tr>
                            <th>Mã phiếu</th>
                            <th>Kỹ thuật viên</th>
                            <th>Linh kiện trả về (Xác)</th>
                            <th>Thời gian</th>
                            <th class="text-end">Hành động</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var waste in wasteReturns)
                        {
                            <tr>
                                <td><span class="badge bg-primary">@waste.PhieuSuaChuaId</span></td>
                                <td>@waste.TenKyThuatVien</td>
                                <td class="fw-medium">@waste.TenLinhKien</td>
                                <td>@waste.NgayTra.ToString("dd/MM/yyyy HH:mm")</td>
                                <td class="text-end">
                                    @if (waste.TrangThai == "pending" && (User.IsInRole("Support") || User.IsInRole("StoreAdmin")))
                                    {
                                        <button class="btn btn-sm btn-primary" onclick="xacNhanTraXac('@waste.Id')">
                                            <i class="bi bi-recycle me-1"></i>Xác nhận đã nhận
                                        </button>
                                    }
                                    else if (waste.TrangThai == "returned")
                                    {
                                        <span class="badge bg-success">
                                            <i class="bi bi-check-circle me-1"></i>Đã nhập kho xác
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="text-muted small">Chờ xác nhận</span>
                                    }
                                </td>
                            </tr>
                        }
                        @if (!wasteReturns.Any())
                        {
                            <tr>
                                <td colspan="5" class="text-center py-5 text-muted">Chưa có linh kiện hỏng nào cần trả về.</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>

@Html.AntiForgeryToken()

@section Styles {
    <style>
        .custom-focus-ring:focus-within {
            box-shadow: 0 0 0 0.25rem rgba(13, 110, 253, 0.15) !important;
            border-color: #86b7fe !important;
        }
        .pos-table th { font-weight: 700; white-space: nowrap; color: #64748b; }
        .hover-lift { transition: transform 0.2s; }
        .hover-lift:hover { transform: translateY(-2px); }
    </style>
    <link rel="stylesheet" href="~/css/warehouse.css" asp-append-version="true" />
}

@section Scripts {
    <script src="~/js/warehouse.js" asp-append-version="true"></script>
}

