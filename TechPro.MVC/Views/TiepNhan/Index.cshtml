@model IEnumerable<PhieuSuaChua>
@{
    ViewData["Title"] = "TechPro POS - Lễ Tân";
    // Tính toán một số thống kê tạm thời
    var waitingList = Model?.Where(t => t.TrangThai == "pending" || t.TrangThai == "waiting_parts").ToList() ?? new List<PhieuSuaChua>();
    var inProgressList = Model?.Where(t => t.TrangThai == "repairing").ToList() ?? new List<PhieuSuaChua>();
    var readyList = Model?.Where(t => t.TrangThai == "done").ToList() ?? new List<PhieuSuaChua>();
}

<div class="container-fluid py-3 px-2 px-md-4" style="background-color: #f8fafc; min-height: calc(100vh - 64px);">
    <!-- POS Header & Stats -->
    <div class="row g-3 mb-4">
        <div class="col-12 col-sm-6 col-xl-3">
            <div class="card border-0 shadow-sm rounded-4 h-100" style="background: linear-gradient(135deg, #0f172a, #334155); color: white;">
                <div class="card-body p-4 d-flex flex-column justify-content-center">
                    <h6 class="text-uppercase fw-bold opacity-75 mb-2 small" style="letter-spacing: 1px;"><i class="bi bi-person-badge-fill me-2"></i>Trạm Điều Phối</h6>
                    <h3 class="fw-bolder mb-0 text-truncate">TechPro Care</h3>
                    <div class="d-flex align-items-center mt-3">
                        <span class="d-inline-block bg-success rounded-circle me-2" style="width: 10px; height: 10px; box-shadow: 0 0 8px #22c55e;"></span>
                        <span class="small opacity-75 fw-medium">Ca trực sáng - Đang mở cửa</span>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-12 col-sm-6 col-xl-3">
            <div class="card border-0 shadow-sm rounded-4 h-100 bg-white hover-up transition-all">
                <div class="card-body p-4">
                    <div class="d-flex justify-content-between align-items-start">
                        <div>
                            <h6 class="text-uppercase fw-bold text-slate-500 mb-2 small" style="letter-spacing: 0.5px;">Khách Đang Đợi</h6>
                            <h2 class="fw-bolder text-warning mb-0 display-6">@waitingList.Count</h2>
                        </div>
                        <div class="p-3 bg-warning bg-opacity-10 text-warning rounded-circle">
                            <i data-lucide="clock" class="icon" style="width: 28px; height: 28px;"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-12 col-sm-6 col-xl-3">
            <div class="card border-0 shadow-sm rounded-4 h-100 bg-white hover-up transition-all">
                <div class="card-body p-4">
                    <div class="d-flex justify-content-between align-items-start">
                        <div>
                            <h6 class="text-uppercase fw-bold text-slate-500 mb-2 small" style="letter-spacing: 0.5px;">Đã Xong - Chờ Trả</h6>
                            <h2 class="fw-bolder text-success mb-0 display-6">@readyList.Count</h2>
                        </div>
                        <div class="p-3 bg-success bg-opacity-10 text-success rounded-circle">
                            <i data-lucide="check-circle" class="icon" style="width: 28px; height: 28px;"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-12 col-sm-6 col-xl-3">
            <div class="card border-0 shadow-sm rounded-4 h-100 bg-indigo-50 border-start border-4 border-indigo-600">
                <div class="card-body p-4 d-flex justify-content-between align-items-center">
                    <div>
                        <h6 class="text-uppercase fw-bold text-indigo-600 mb-2 small" style="letter-spacing: 0.5px;">Tiền Mặt Tại Quầy</h6>
                        <h3 class="fw-bolder text-indigo-900 mb-0">12.500.000đ</h3>
                    </div>
                    <button class="btn btn-indigo text-white rounded-circle p-3 shadow-sm d-flex align-items-center justify-content-center" style="width: 52px; height: 52px; background-color: #4f46e5; border-color: #4f46e5;" title="Chốt ca ngay">
                        <i data-lucide="wallet" class="icon" style="width: 24px; height: 24px;"></i>
                    </button>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-4">
        <!-- QUICK CHECK-IN FORM (Left Side) -->
        <div class="col-12 col-lg-5 mb-4 mb-lg-0">
            <div class="card border-0 shadow-sm rounded-4 overflow-hidden h-100 sticky-lg-top" style="top: 80px; z-index: 5;">
                <div class="card-header bg-white border-bottom-0 p-4 pb-2">
                    <h5 class="fw-bolder text-slate-800 mb-0 d-flex align-items-center">
                        <i data-lucide="file-plus-2" class="text-primary me-2"></i> Trạm Tạo Phiếu Nhanh
                    </h5>
                    <p class="text-muted small mt-1 mb-0">Hỗ trợ tra cứu nhanh SĐT Khách hàng</p>
                </div>
                <div class="card-body p-4 pt-2">
                    <form id="checkInForm" asp-action="TaoPhieu" asp-controller="TiepNhan" method="post">
                        @Html.AntiForgeryToken()
                        
                        <!-- Thông tin khách -->
                        <div class="mb-4">
                            <div class="input-group input-group-lg mb-3 shadow-sm rounded-3 overflow-hidden">
                                <span class="input-group-text bg-white border-end-0 text-primary"><i class="bi bi-telephone-fill"></i></span>
                                <input type="tel" class="form-control border-start-0 border-end-0 ps-0 fw-bold" name="SoDienThoai" id="phoneNumber" placeholder="09..." required style="box-shadow: none;" />
                                <button class="btn btn-primary" type="button" style="width: 60px;"><i class="bi bi-search"></i></button>
                            </div>
                            <div class="form-floating shadow-sm rounded-3">
                                <input type="text" class="form-control" name="TenKhachHang" id="customerName" placeholder="Tên khách hàng" required />
                                <label for="customerName"><i class="bi bi-person me-1 text-slate-400"></i> Họ và Tên Khách Hàng</label>
                            </div>
                        </div>

                        <!-- Thông tin thiết bị -->
                        <div class="bg-slate-50 p-3 p-md-4 rounded-4 mb-4 border border-slate-100">
                            <h6 class="fw-bold text-slate-700 mb-3"><i class="bi bi-phone me-2"></i>Tình trạng lúc tiếp nhận</h6>
                            
                            <div class="form-floating mb-3">
                                <input type="text" class="form-control bg-white" name="TenThietBi" id="deviceModel" placeholder="VD: iPhone 14 Pro Max" required />
                                <label for="deviceModel">Model Thiết Bị (VD: iPhone 14 Pro Max)</label>
                            </div>
                            
                            <div class="row g-3 mb-3">
                                <div class="col-12 col-sm-6">
                                    <div class="input-group">
                                        <span class="input-group-text bg-white text-slate-500"><i class="bi bi-upc-scan"></i></span>
                                        <input type="text" class="form-control bg-white" name="SerialNumber" id="serialNumber" placeholder="Nhập IMEI/Serial" />
                                    </div>
                                </div>
                                <div class="col-12 col-sm-6">
                                    <div class="input-group">
                                        <span class="input-group-text bg-white text-slate-500"><i class="bi bi-key"></i></span>
                                        <input type="text" class="form-control bg-white" name="MatKhauManHinh" id="passcode" placeholder="Mật khẩu máy" />
                                    </div>
                                </div>
                            </div>

                            <div class="form-floating mb-3 position-relative">
                                <textarea class="form-control bg-white" name="MoTaLoi" id="problemDescription" style="height: 100px" required placeholder="Máy bị rơi vỡ..."></textarea>
                                <label for="problemDescription">Mô tả chi tiết lỗi / Tình trạng máy</label>
                            </div>
                            
                            <button type="button" class="btn btn-outline-primary w-100 fw-bold rounded-3 d-flex justify-content-center align-items-center py-2" id="btnAiQuote" onclick="analyzeQuote()">
                                <i data-lucide="sparkles" class="me-2" style="width: 18px; height: 18px;"></i>
                                Kích Hoạt AI Chẩn Đoán Lỗi & Báo Giá
                            </button>
                            
                            <!-- AI Quote Result -->
                            <div id="aiQuoteResult" class="mt-3 p-3 rounded-3 bg-indigo-50 border border-indigo-100 d-none shadow-sm transition-all text-center">
                                <div class="badge bg-indigo-100 text-indigo-800 mb-2 px-3 py-1 rounded-pill">🤖 Trợ lý AI Đề Xuất</div>
                                <p id="aiSuggestion" class="text-indigo-900 fw-medium mb-3 lh-sm"></p>
                                <div class="d-flex justify-content-between align-items-center bg-white p-3 rounded-3 shadow-sm border border-indigo-50">
                                    <span class="fw-bold text-slate-600">Chi phí dự kiến:</span>
                                    <span id="aiTotal" class="fw-bolder text-danger fs-5">0đ</span>
                                </div>
                            </div>
                        </div>

                        <button type="submit" class="btn btn-primary w-100 py-3 rounded-4 fw-bolder shadow d-flex justify-content-center align-items-center h5 mb-0 text-uppercase" id="submitCheckInBtn" style="letter-spacing: 1px;">
                            <i data-lucide="printer" class="me-2" style="width: 24px; height: 24px;"></i> LƯU & TRUYỀN PHIẾU
                        </button>
                    </form>
                </div>
            </div>
        </div>

        <!-- LIVE QUEUE (Right Side) -->
        <div class="col-12 col-lg-7">
            <div class="card border-0 shadow-sm rounded-4 h-100 d-flex flex-column">
                <div class="card-header bg-white border-bottom p-4 d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-3">
                    <h5 class="fw-bolder text-slate-800 mb-0 d-flex align-items-center">
                        <i data-lucide="list-todo" class="text-primary me-2"></i> Danh Sách Công Việc Hôm Nay
                    </h5>
                    
                    <form id="searchForm" class="d-flex w-100" style="max-width: 350px;">
                        <div class="input-group bg-slate-50 border border-slate-200 rounded-pill overflow-hidden shadow-sm">
                            <span class="input-group-text bg-transparent border-0 pe-1 text-slate-400">
                                <i class="bi bi-search"></i>
                            </span>
                            <input type="text" class="form-control border-0 bg-transparent shadow-none" name="searchTerm" value="@ViewBag.SearchTerm" placeholder="Tra nhanh Tên KH, SĐT..." />
                            <button class="btn btn-primary rounded-pill m-1 px-3 d-none d-sm-block" type="submit">Tìm</button>
                        </div>
                    </form>
                </div>
                
                <div class="card-body p-0 flex-grow-1 overflow-auto">
                    <div class="table-responsive h-100">
                        <table class="table table-hover align-middle mb-0 pos-table" style="min-width: 800px;">
                            <thead class="bg-slate-50 text-uppercase text-slate-500 small fw-bold" style="letter-spacing: 0.5px;">
                                <tr>
                                    <th class="py-3 px-4 border-0">Mã Số</th>
                                    <th class="py-3 px-4 border-0">Khách Hàng (SĐT)</th>
                                    <th class="py-3 px-4 border-0">Tình Trạng Thiết Bị</th>
                                    <th class="py-3 px-4 border-0">Tiến Độ</th>
                                    <th class="py-3 px-4 border-0 text-end">Thao Tác</th>
                                </tr>
                            </thead>
                            <tbody class="border-top-0">
                                @if (Model != null && Model.Any())
                                {
                                    @foreach (var ticket in Model)
                                    {
                                        var isRecent = (DateTime.UtcNow - ticket.NgayNhan).TotalMinutes < 30;
                                        <tr class="transition-colors group" style="cursor: pointer;" onclick="event.stopPropagation(); window.location.href='@Url.Action("ChiTiet", "KyThuat", new { id = ticket.Id })'">
                                            <td class="py-3 px-4">
                                                <div class="d-flex flex-column">
                                                    <span class="fw-bolder text-primary">@ticket.Id</span>
                                                    <span class="text-muted small" style="font-size: 0.7rem;">@ticket.NgayNhan.ToString("HH:mm")</span>
                                                </div>
                                            </td>
                                            <td class="py-3 px-4">
                                                <div class="fw-bold text-slate-800 text-truncate" style="max-width: 150px;">@ticket.TenKhachHang</div>
                                                <div class="text-slate-500 small font-monospace"><i class="bi bi-telephone-fill me-1 text-slate-300"></i>@ticket.SoDienThoai</div>
                                            </td>
                                            <td class="py-3 px-4">
                                                <div class="d-flex align-items-center">
                                                    <div class="bg-slate-100 p-2 rounded-3 me-3 d-none d-sm-block">
                                                        <i data-lucide="smartphone" class="text-slate-500" style="width: 24px; height: 24px;"></i>
                                                    </div>
                                                    <div>
                                                        <span class="text-slate-700 fw-bold d-block text-truncate" style="max-width: 200px;">@ticket.TenThietBi</span>
                                                        <span class="text-slate-500 small d-inline-block text-truncate" style="max-width: 200px;" title="@ticket.MoTaLoi">@ticket.MoTaLoi</span>
                                                    </div>
                                                </div>
                                            </td>
                                            <td class="py-3 px-4">
                                                @{
                                                    var badgeBaseClass = "badge px-3 py-2 rounded-pill fw-bold d-inline-flex align-items-center justify-content-center text-nowrap";
                                                    var badgeStyle = "width: 160px; height: 36px; font-size: 0.85rem;";
                                                    
                                                    var statusBadge = ticket.TrangThai switch
                                                    {
                                                        "pending" => $"<span class='{badgeBaseClass} bg-warning bg-opacity-10 text-warning border border-warning border-opacity-25' style='{badgeStyle}'><i class='bi bi-hourglass-split me-2'></i>Chờ Khám</span>",
                                                        "repairing" => $"<span class='{badgeBaseClass} bg-primary bg-opacity-10 text-primary border border-primary border-opacity-25' style='{badgeStyle}'><i class='bi bi-tools me-2'></i>Đang Mổ Máy</span>",
                                                        "waiting_parts" => $"<span class='{badgeBaseClass} bg-danger bg-opacity-10 text-danger border border-danger border-opacity-25' style='{badgeStyle}'><i class='bi bi-box me-2'></i>Chờ Đồ</span>",
                                                        "done" => $"<span class='{badgeBaseClass} bg-success text-white shadow-sm border border-success' style='{badgeStyle}'><i class='bi bi-check-circle-fill me-2'></i>Sẵn Sàng Trả K/H</span>",
                                                        "delivered" => $"<span class='{badgeBaseClass} bg-slate-100 text-slate-500 border border-slate-200' style='{badgeStyle}'>Đã Hoàn Tất</span>",
                                                        _ => $"<span class='{badgeBaseClass} bg-secondary text-white' style='{badgeStyle}'>{ticket.TrangThai}</span>"
                                                    };
                                                }
                                                @Html.Raw(statusBadge)
                                            </td>
                                            <td class="py-3 px-4 text-end" onclick="event.stopPropagation();">
                                                <div class="d-flex gap-2 justify-content-end align-items-center">
                                                    @if (ticket.TrangThai == "done")
                                                    {
                                                        <button class="btn btn-sm btn-success fw-bold d-inline-flex align-items-center justify-content-center text-nowrap px-3 shadow-sm" style="height: 36px;" onclick="alert('Đang mở màn chốt bill & thu tiền!')"><i class="bi bi-cash-stack me-2"></i> Trả Máy</button>
                                                    }
                                                    else if (ticket.TrangThai == "pending" && isRecent)
                                                    {
                                                        <button class="btn btn-sm btn-outline-danger d-inline-flex align-items-center justify-content-center text-nowrap px-3" style="height: 36px;" onclick="cancelTicket('@ticket.Id')" title="Hủy phiếu gấp (Chỉ Lễ Tân)"><i class="bi bi-x-circle me-2"></i> Hủy</button>
                                                    }
                                                    <a href="@Url.Action("ChiTiet", "KyThuat", new { id = ticket.Id })" class="btn btn-sm btn-light border bg-white d-inline-flex align-items-center justify-content-center" style="height: 36px; width: 36px;" title="Chi tiết"><i class="bi bi-chevron-right text-slate-500"></i></a>
                                                </div>
                                            </td>
                                        </tr>
                                    }
                                }
                                else
                                {
                                    <tr>
                                        <td colspan="5" class="text-center py-5">
                                            <div class="text-slate-400 py-4">
                                                <i data-lucide="inbox" class="mb-3 d-inline-block opacity-50" style="width: 64px; height: 64px;"></i>
                                                <h5 class="fw-bold text-slate-500 mb-1">Khay chứa trống</h5>
                                                <p class="mb-0">Chưa có phiếu máy nào được nhận trong hôm nay.</p>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Styles {
    <style>
        .hover-up { transition: transform 0.2s, box-shadow 0.2s; }
        .hover-up:hover { transform: translateY(-3px); box-shadow: 0 .5rem 1rem rgba(0,0,0,.08)!important; }
        .text-slate-300 { color: #cbd5e1; }
        .text-slate-400 { color: #94a3b8; }
        .text-slate-500 { color: #64748b; }
        .text-slate-600 { color: #475569; }
        .text-slate-700 { color: #334155; }
        .text-slate-800 { color: #1e293b; }
        .bg-slate-50 { background-color: #f8fafc; }
        .bg-slate-100 { background-color: #f1f5f9; }
        .border-slate-100 { border-color: #f1f5f9; }
        .border-slate-200 { border-color: #e2e8f0; }
        
        .bg-indigo-50 { background-color: #eef2ff; }
        .bg-indigo-100 { background-color: #e0e7ff; }
        .text-indigo-600 { color: #4f46e5; }
        .text-indigo-800 { color: #3730a3; }
        .text-indigo-900 { color: #312e81; }
        .border-indigo-50 { border-color: #eef2ff; }
        .border-indigo-100 { border-color: #e0e7ff; }
        .border-indigo-600 { border-color: #4f46e5; }
        
        .transition-all { transition: all 0.3s ease; }
        
        .pos-table th { font-weight: 700; white-space: nowrap; }
        .pos-table td { vertical-align: middle; }
        .pos-table tbody tr:hover { background-color: rgba(241, 245, 249, 0.7) !important; }
        
        /* Custom scrollbar cho Live Queue */
        .table-responsive::-webkit-scrollbar { width: 8px; height: 8px; }
        .table-responsive::-webkit-scrollbar-track { background: #f1f5f9; border-radius: 4px; }
        .table-responsive::-webkit-scrollbar-thumb { background: #cbd5e1; border-radius: 4px; }
        .table-responsive::-webkit-scrollbar-thumb:hover { background: #94a3b8; }
    </style>
}

@section Scripts {
    <script>
        // AI Quote (Cải tiến giao diện)
        async function analyzeQuote() {
            const btn = document.getElementById('btnAiQuote');
            const desc = document.getElementById('problemDescription').value;
            const model = document.getElementById('deviceModel').value;
            const resultBox = document.getElementById('aiQuoteResult');

            if (!desc || !model) {
                toastr.warning('Để AI chẩn đoán, xin điền Tên Model và Mô tả lỗi.', 'Thiếu dữ liệu');
                return;
            }

            btn.disabled = true;
            btn.innerHTML = '<span class="spinner-border spinner-border-sm me-2"></span>AI Đang quét database...';
            resultBox.classList.add('d-none');

            try {
                const response = await fetch('/TiepNhan/AnalyzeQuote', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]')?.value || ''
                    },
                    body: JSON.stringify({ moTaLoi: desc, tenThietBi: model })
                });
                
                const data = await response.json();
                if (data && data.success === false) {
                     toastr.error(data.message, 'Lỗi AI');
                } else {
                    document.getElementById('aiSuggestion').textContent = data.giaiPhap || 'Yêu cầu mở máy kiểm tra thực tế phần cứng.';
                    document.getElementById('aiTotal').textContent = data.tongTienTamTinh ? data.tongTienTamTinh.toLocaleString('vi-VN') + 'đ' : 'Báo giá sau KT';
                    
                    // Add animation effect
                    resultBox.classList.remove('d-none');
                    resultBox.style.opacity = 0;
                    setTimeout(() => { resultBox.style.opacity = 1; }, 50);
                }
            } catch (e) {
                toastr.error('Lỗi kết nối Máy chủ AI.', 'Mất kết nối');
            } finally {
                btn.disabled = false;
                btn.innerHTML = '<i data-lucide="sparkles" class="me-2" style="width: 18px; height: 18px;"></i> Cập Nhật Lại Báo Giá AI';
                if (typeof lucide !== 'undefined') lucide.createIcons();
            }
        }

        // Tạo phiếu Submit Hook
        document.getElementById('checkInForm')?.addEventListener('submit', function(e) {
            e.preventDefault();
            const form = this;
            const formData = new FormData(form);
            const submitBtn = document.getElementById('submitCheckInBtn');
            const originalBtnHtml = submitBtn.innerHTML;
            
            submitBtn.disabled = true;
            submitBtn.innerHTML = '<span class="spinner-border spinner-border-sm me-2" style="width: 24px; height: 24px;"></span> ĐANG IN PHIẾU...';
            
            fetch(form.action, {
                method: 'POST',
                body: formData,
                headers: {
                    'RequestVerificationToken': form.querySelector('input[name="__RequestVerificationToken"]')?.value || ''
                }
            })
            .then(response => response.json())
            .then(data => {
                if (data.success) {
                    toastr.success('Hồ sơ số ' + (data.id || '') + ' đã đẩy xuống Phòng Kỹ Thuật!', 'Tạo Phiếu Thành Công');
                    setTimeout(() => location.reload(), 1500);
                } else {
                    toastr.error(data.message || 'Có lỗi trong quá trình lưu dữ liệu', 'Lỗi Hệ Thống');
                    submitBtn.disabled = false;
                    submitBtn.innerHTML = originalBtnHtml;
                }
            });
        });

        function cancelTicket(id) {
            if(confirm('Chú ý: Hành động này sẽ Hủy bỏ hoàn toàn biên nhận sửa chữa.\n\nChỉ áp dụng cho trường hợp Khách đổi ý (trong vòng 30p sau khi lên đơn).\n\nXác nhận Hủy?')) {
                toastr.info('Đang gửi Request hủy đơn ' + id + ' tới Server...');
            }
        }
    </script>
}
