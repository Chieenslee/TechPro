@model PhieuSuaChua
@{
    ViewData["Title"] = "TechPro POS - Chi Tiết Phiếu";
    Layout = "_Layout";
    
    var progressStatus = Model.TrangThai switch {
        "pending" => 20,
        "repairing" => 50,
        "waiting_parts" => 50,
        "done" => 80,
        "delivered" => 100,
        _ => 0
    };
    
    var ticketRequests = Model.YeuCauLinhKiens?.Where(r => r.TrangThai == "approved").ToList() ?? new List<YeuCauLinhKien>();
    var totalPartsCost = ticketRequests.Sum(r => (r.GiaTaiThoiDiemYeuCau ?? 0) * r.SoLuong);
    var serviceFee = 200000;
    var totalBill = Model.CoBaoHanh == true ? 0 : totalPartsCost + serviceFee;
}

<div class="container-fluid py-4 px-3 px-md-5 font-inter" style="background-color: #f8fafc; min-height: calc(100vh - 64px);">
    <!-- Breadcrumb & Actions -->
    <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center mb-4 gap-3">
        <div class="d-flex align-items-center gap-3">
            <button onclick="history.back()" class="btn btn-white bg-white shadow-sm border border-slate-200 rounded-circle d-flex align-items-center justify-content-center hover-lift" style="width: 44px; height: 44px;">
                <i class="bi bi-arrow-left text-slate-700 fs-5"></i>
            </button>
            <div>
                <nav aria-label="breadcrumb">
                    <ol class="breadcrumb mb-1 small">
                        <li class="breadcrumb-item"><a href="javascript:history.back()" class="text-slate-500 text-decoration-none">Danh sách ca</a></li>
                        <li class="breadcrumb-item active fw-semibold text-primary" aria-current="page">Chi tiết: @Model.Id</li>
                    </ol>
                </nav>
                <h4 class="fw-bolder text-slate-800 mb-0 d-flex align-items-center gap-2">
                    BIÊN NHẬN SỬA CHỮA
                    @if (Model.CoBaoHanh == true) {
                        <span class="badge bg-success-subtle text-success border border-success-subtle rounded-pill px-3 py-1 fs-6 fw-bold"><i class="bi bi-shield-check me-1"></i> Gói Bảo Hành VIP</span>
                    }
                </h4>
            </div>
        </div>
        
        <div class="d-flex gap-2 mt-2 mt-md-0">
            <button class="btn btn-white bg-white border border-slate-200 shadow-sm rounded-pill px-4 fw-bold hover-lift text-slate-700 d-inline-flex align-items-center">
                <i data-lucide="printer" class="me-2 text-primary" style="width: 18px; height: 18px;"></i> In Biên Nhận Mới
            </button>
            @if(Model.TrangThai != "done" && Model.TrangThai != "delivered") {
                 <button class="btn btn-outline-danger shadow-sm rounded-pill px-4 fw-bold hover-lift d-inline-flex align-items-center" onclick="cancelTicket('@Model.Id')">
                    Hủy Đơn Này
                </button>
            }
        </div>
    </div>

    <!-- Timeline Banner -->
    <div class="card border-0 shadow-sm rounded-4 overflow-hidden mb-4 bg-white">
        <div class="card-body p-4 p-md-5">
            <h6 class="text-uppercase text-slate-500 fw-bold mb-4" style="letter-spacing: 1px;"><i class="bi bi-activity text-indigo-500 me-2"></i>Tiến Độ Sửa Chữa Trực Tiếp</h6>
            <div class="position-relative">
                <div class="progress" style="height: 6px; background-color: #f1f5f9; border-radius: 10px;">
                    <div class="progress-bar bg-primary progress-bar-striped progress-bar-animated" role="progressbar" style="width: @progressStatus%" aria-valuenow="@progressStatus" aria-valuemin="0" aria-valuemax="100"></div>
                </div>
                
                <div class="d-flex justify-content-between position-absolute top-0 w-100" style="margin-top: -16px;">
                    <!-- Step 1: Nhận máy -->
                    <div class="text-center" style="width: 60px; margin-left: -30px;">
                        <div class="rounded-circle d-flex align-items-center justify-content-center mx-auto mb-2 custom-shadow" style="width: 38px; height: 38px; background-color: @(progressStatus >= 20 ? "#3b82f6" : "#e2e8f0"); color: white; transition: all 0.3s;">
                            <i data-lucide="inbox"></i>
                        </div>
                        <span class="small fw-bold @(progressStatus >= 20 ? "text-primary" : "text-slate-400")">Nhận máy</span>
                    </div>
                    
                    <!-- Step 2: Chẩn đoán & Sửa -->
                    <div class="text-center" style="width: 60px; margin-left: -30px;">
                        <div class="rounded-circle d-flex align-items-center justify-content-center mx-auto mb-2 custom-shadow" style="width: 38px; height: 38px; background-color: @(progressStatus >= 50 ? "#3b82f6" : "#e2e8f0"); color: white; transition: all 0.3s;">
                            <i data-lucide="wrench"></i>
                        </div>
                        <span class="small fw-bold @(progressStatus >= 50 ? "text-primary" : "text-slate-400")">Bắt Bệnh<br />Sửa Chữa</span>
                    </div>

                    <!-- Step 3: Kiểm thử hoàn tất -->
                    <div class="text-center" style="width: 60px; margin-left: -30px;">
                        <div class="rounded-circle d-flex align-items-center justify-content-center mx-auto mb-2 custom-shadow" style="width: 38px; height: 38px; background-color: @(progressStatus >= 80 ? "#22c55e" : "#e2e8f0"); color: white; transition: all 0.3s;">
                            <i data-lucide="check-circle-2"></i>
                        </div>
                        <span class="small fw-bold @(progressStatus >= 80 ? "text-success" : "text-slate-400")">Done!<br />Sẵn Sàng</span>
                    </div>

                    <!-- Step 4: Trả Máy -->
                    <div class="text-center" style="width: 60px; margin-right: -30px;">
                        <div class="rounded-circle d-flex align-items-center justify-content-center mx-auto mb-2 custom-shadow" style="width: 38px; height: 38px; background-color: @(progressStatus >= 100 ? "#64748b" : "#e2e8f0"); color: white; transition: all 0.3s;">
                            <i data-lucide="package-check"></i>
                        </div>
                        <span class="small fw-bold @(progressStatus >= 100 ? "text-slate-600" : "text-slate-400")">Đã Trả Khách</span>
                    </div>
                </div>
            </div>
            
            <div class="mt-5 bg-slate-50 border border-slate-100 rounded-4 p-3 d-flex align-items-center">
                <div class="bg-primary-subtle p-2 rounded-circle me-3">
                    <i class="bi bi-info-circle-fill text-primary" style="font-size: 1.25rem;"></i>
                </div>
                <div>
                    <h6 class="fw-bold mb-1 text-slate-700">Trạng thái hệ thống:</h6>
                    <p class="mb-0 text-slate-500 small fw-medium">
                        @{
                            var textStatus = Model.TrangThai switch {
                                "pending" => "Máy đang nằm tại Giỏ Đợi Khám. Chưa có kỹ thuật viên tiếp nhận phân tích.",
                                "repairing" => "Đang được chuyên gia kỹ thuật bung máy sửa chữa. Xin quý khách/thu ngân kiên nhẫn đợi thêm.",
                                "waiting_parts" => "Thiếu linh kiện nghiêm trọng. Đang gián đoạn chờ bộ phận Kho điều phối hàng. Có thể trễ tiến độ hoàn thành.",
                                "done" => "Tuyệt vời, Máy đã sửa xong! Giờ máy đang ở Quầy Trả Máy. Bạn có thể gọi Điện Thoại/SMS Báo Khách Đến Lấy Hàng.",
                                "delivered" => "Phiếu sửa chữa đã khép lại vòng đời thành công. Máy đã trao trả tận tay khách.",
                                _ => "Đang xử lý nghiệp vụ..."
                            };
                            @textStatus
                        }
                    </p>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-4 mb-4">
        <!-- Thông Tin Khách & Hồ Sơ Máy -->
        <div class="col-lg-7">
            <div class="card border-0 shadow-sm rounded-4 h-100 bg-white">
                <div class="card-header bg-transparent border-bottom p-4">
                    <h5 class="fw-bolder text-slate-800 mb-0 d-flex align-items-center">
                        <i data-lucide="file-user" class="text-indigo-500 me-2" style="width: 22px; height: 22px;"></i> Hồ Sơ Thiết Bị Này
                    </h5>
                </div>
                <div class="card-body p-4">
                    <!-- Customer Data -->
                    <div class="row mb-4">
                        <div class="col-sm-6 mb-3 mb-sm-0">
                            <label class="text-uppercase text-slate-400 small fw-bold mb-1" style="letter-spacing: 0.5px;">Khách Hàng</label>
                            <div class="d-flex align-items-center">
                                <div class="bg-indigo-50 text-indigo-600 rounded-circle fw-bolder d-flex align-items-center justify-content-center me-3 shadow-sm" style="width: 48px; height: 48px; font-size: 1.25rem;">
                                    @((string.IsNullOrEmpty(Model.TenKhachHang) ? "?" : Model.TenKhachHang.Substring(0,1).ToUpper()))
                                </div>
                                <div>
                                    <h5 class="fw-bold text-slate-800 mb-0">@Model.TenKhachHang</h5>
                                    <div class="text-slate-500 mt-1 d-flex align-items-center font-monospace">
                                        <i class="bi bi-telephone-fill text-slate-400 mx-1"></i> @Model.SoDienThoai 
                                        <button class="btn btn-sm btn-link p-0 ms-2 text-decoration-none text-success" onclick="toastr.success('Gọi khách ngay!')"><i class="bi bi-telephone-outbound"></i> Call</button>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="col-sm-6 border-start border-slate-100 ps-sm-4">
                            <label class="text-uppercase text-slate-400 small fw-bold mb-1" style="letter-spacing: 0.5px;">Thiết bị tiếp nhận</label>
                            <div class="d-flex align-items-center mt-1">
                                <div class="p-2 bg-slate-50 border border-slate-200 rounded-3 me-3">
                                    <i data-lucide="smartphone" class="text-slate-500" style="width: 24px; height: 24px;"></i>
                                </div>
                                <div>
                                    <h6 class="fw-bold text-slate-800 mb-1">@Model.TenThietBi</h6>
                                    <div class="text-slate-500 small font-monospace d-flex align-items-center">
                                        <i class="bi bi-upc-scan text-slate-400 me-1"></i> SN: @(Model.SerialNumber ?? "Không Rõ")
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Problem details -->
                    <div class="p-3 bg-red-50 border border-red-100 rounded-3 mb-4">
                        <label class="text-uppercase text-red-400 small fw-bold mb-2 d-flex align-items-center" style="letter-spacing: 0.5px;">
                            <i class="bi bi-megaphone-fill me-1"></i> Lời Khai Lỗi (Từ Khách Hàng)
                        </label>
                        <p class="mb-0 text-red-900 fw-medium">@Model.MoTaLoi</p>
                    </div>

                    <!-- Tech Output -->
                    <div class="p-3 bg-slate-50 border border-slate-200 rounded-3">
                        <div class="d-flex justify-content-between align-items-center mb-2">
                            <label class="text-uppercase text-slate-500 small fw-bold d-flex align-items-center" style="letter-spacing: 0.5px;">
                                <i class="bi bi-wrench-adjustable text-slate-400 me-2"></i> Kết Luận Kỹ Thuật View
                            </label>
                            @if(Model.TrangThai == "done") {
                                <span class="badge bg-success-subtle text-success border border-success-subtle rounded-pill">Đã Kết Luận Lỗi Xong</span>
                            } else {
                                <span class="badge bg-warning-subtle text-warning-emphasis border border-warning-subtle rounded-pill">Đang phân tích dở...</span>
                            }
                        </div>
                        <div class="bg-white border border-slate-200 p-3 rounded text-slate-700 mt-2" style="min-height: 80px; font-family: 'Courier New', monospace; font-size: 0.95rem; line-height: 1.5;">
                            @(string.IsNullOrEmpty(Model.KetQuaKiemTra) ? "Kỹ thuật chuyên khoa chưa chốt hạ bệnh án gì trên phiếu này..." : Html.Raw(Model.KetQuaKiemTra.Replace("\n", "<br/>")))
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Receipt & Finances -->
        <div class="col-lg-5">
            <div class="card border-0 shadow-sm rounded-4 h-100 bg-white" style="background: linear-gradient(to bottom, #ffffff, #f8fafc);">
                <div class="card-header bg-transparent border-bottom p-4">
                    <h5 class="fw-bolder text-slate-800 mb-0 d-flex align-items-center">
                        <i data-lucide="receipt" class="text-emerald-500 me-2" style="width: 22px; height: 22px;"></i> Bảng Kê Thu Ngân
                    </h5>
                </div>
                <div class="card-body p-4 d-flex flex-column h-100">
                    <div class="flex-grow-1">
                        <h6 class="fw-bold text-slate-600 mb-3 small text-uppercase" style="letter-spacing: 0.5px;">Linh kiện Đã Chốt Xài <span class="badge bg-secondary ms-1">@(ticketRequests.Count) Món</span></h6>
                        
                        <div class="table-responsive">
                            <table class="table table-borderless table-sm mb-4">
                                <thead class="border-bottom border-slate-200 text-slate-400 small fw-normal">
                                    <tr>
                                        <th class="ps-0 pb-2">Hạng mục / Tên thiết bị</th>
                                        <th class="text-center pb-2">SL</th>
                                        <th class="text-end pe-0 pb-2">Đơn Giá</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach(var req in ticketRequests) {
                                        <tr class="align-middle fw-medium">
                                            <td class="ps-0 py-2 text-slate-700">@req.LinhKien?.TenLinhKien</td>
                                            <td class="text-center py-2 text-slate-500 font-monospace">@req.SoLuong</td>
                                            <td class="text-end pe-0 py-2 text-slate-700 font-monospace">@((req.GiaTaiThoiDiemYeuCau ?? 0).ToString("N0"))đ</td>
                                        </tr>
                                    }
                                    @if(ticketRequests.Count == 0) {
                                        <tr>
                                            <td colspan="3" class="text-center py-4 text-slate-400 fst-italic opacity-75">
                                                (Không phát sinh linh kiện vật tư ngoài, chỉ chạy lại phần mềm/vệ sinh)
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>

                    <!-- Total box -->
                    <div class="mt-auto bg-slate-800 rounded-4 p-4 text-white shadow-sm position-relative overflow-hidden">
                        <div class="position-absolute end-0 bottom-0 opacity-10" style="transform: translate(20%, 30%);">
                            <i data-lucide="wallet" style="width: 120px; height: 120px;"></i>
                        </div>
                        
                        <div class="position-relative z-1">
                            <div class="d-flex justify-content-between align-items-center mb-2">
                                <span class="text-slate-300 small">Cộng tiền linh kiện:</span>
                                <span class="fw-medium font-monospace">@totalPartsCost.ToString("N0")đ</span>
                            </div>
                            <div class="d-flex justify-content-between align-items-center mb-3">
                                <span class="text-slate-300 small">Công thao tác (Thợ):</span>
                                <span class="fw-medium font-monospace">@(Model.CoBaoHanh == true ? "0đ" : serviceFee.ToString("N0") + "đ")</span>
                            </div>
                            
                            <hr class="border-slate-600 my-3" />
                            
                            <div class="d-flex justify-content-between align-items-end">
                                <div>
                                    <span class="d-block text-slate-400 text-uppercase fw-bold small mb-1" style="letter-spacing: 1px;">Tổng Yêu Cầu Thu</span>
                                    @if(Model.CoBaoHanh == true) {
                                        <span class="badge bg-emerald-500 bg-opacity-25 text-emerald-400 border border-emerald-500 rounded-pill px-2 py-1 small">Đã Cấn Trừ Bảo Hành</span>
                                    }
                                </div>
                                <h2 class="fw-bolder mb-0 text-emerald-400 font-monospace" style="letter-spacing: -1px;">@totalBill.ToString("N0") <span class="fs-5 fw-bold text-slate-500">VNĐ</span></h2>
                            </div>
                        </div>
                    </div>
                    
                    @if(Model.TrangThai == "done") {
                         <button class="btn btn-emerald w-100 fw-bold rounded-pill p-3 mt-4 text-white hover-lift shadow d-flex align-items-center justify-content-center" style="background-color: #10b981; font-size: 1.1rem;" onclick="toastr.success('Khởi tạo thanh toán máy tự động!', 'Xác nhận thu tiền')">
                            <i class="bi bi-credit-card-fill me-2 fs-5"></i> THỰC HIỆN THU TIỀN NGAY
                        </button>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

@section Styles {
    <style>
        @@import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap');
        .font-inter { font-family: 'Inter', system-ui, -apple-system, sans-serif; }
        .text-slate-300 { color: #cbd5e1; }
        .text-slate-400 { color: #94a3b8; }
        .text-slate-500 { color: #64748b; }
        .text-slate-600 { color: #475569; }
        .text-slate-700 { color: #334155; }
        .text-slate-800 { color: #1e293b; }
        .bg-slate-50 { background-color: #f8fafc; }
        .bg-slate-800 { background-color: #1e293b; }
        .border-slate-100 { border-color: #f1f5f9 !important; }
        .border-slate-200 { border-color: #e2e8f0 !important; }
        .bg-red-50 { background-color: #fef2f2; }
        .text-red-400 { color: #f87171; }
        .text-red-900 { color: #7f1d1d; }
        .border-red-100 { border-color: #fee2e2 !important; }
        .bg-indigo-50 { background-color: #eef2ff; }
        .text-indigo-500 { color: #6366f1; }
        .text-indigo-600 { color: #4f46e5; }
        .text-emerald-400 { color: #34d399; }
        .text-emerald-500 { color: #10b981; }
        .hover-lift { transition: transform 0.2s; }
        .hover-lift:hover { transform: translateY(-3px); }
        .custom-shadow { box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1), 0 2px 4px -1px rgba(0, 0, 0, 0.06); }
    </style>
}

@section Scripts {
    <script>
        if (typeof lucide !== 'undefined') {
            lucide.createIcons();
        }

        function cancelTicket(id) {
            if(confirm('Hành động này sẽ Hủy bỏ biên nhận.\n\nXác nhận Hủy đơn ' + id + '?')) {
                toastr.info('Đang duyệt hệ thống, Vui lòng đợi...');
                fetch('@Url.Action("HuyPhieu", "TiepNhan")', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/x-www-form-urlencoded',
                        'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]')?.value || ''
                    },
                    body: `id=${encodeURIComponent(id)}`
                })
                .then(r => r.json())
                .then(data => {
                    if(data.success) {
                        toastr.warning('Vé đã được hủy vĩnh viễn', 'Done!');
                        setTimeout(() => history.back(), 1500); 
                    } else toastr.error('Lỗi khi hủy biên nhận.');
                }).catch(e => toastr.error('Lỗi mạng.'));
            }
        }
    </script>
}
