@{
    ViewData["Title"] = "TechPro POS - Chat Nội Bộ Toàn Hệ Thống";
    Layout = "_Layout";
}

<div class="container-fluid py-4 px-3 px-md-5 font-inter" style="background-color: #f8fafc; min-height: calc(100vh - 64px);">
    <div class="d-flex align-items-center mb-4 gap-3">
        <div class="bg-indigo-50 text-indigo-600 rounded-circle text-center shadow-sm d-flex align-items-center justify-content-center" style="width: 48px; height: 48px;">
            <i class="bi bi-headset fs-4"></i>
        </div>
        <div>
            <h4 class="fw-bolder text-slate-800 mb-0">Mạng Truyền Tin Nội Bộ</h4>
            <div class="text-slate-500 small">Kênh giao tiếp trực tiếp giữa các phòng ban. Luôn giữ lịch sự và chuyên nghiệp bạn nhé!</div>
        </div>
    </div>

    <div class="card border-0 shadow-sm rounded-4 overflow-hidden mb-4 bg-white" style="height: 65vh;">
        <div class="row g-0 h-100">
            <!-- Channel List -->
            <div class="col-md-3 border-end border-slate-200 bg-slate-50 h-100 d-none d-md-flex flex-column">
                <div class="p-3 border-bottom border-slate-200 bg-white">
                    <div class="input-group input-group-sm">
                        <span class="input-group-text bg-white border-end-0"><i class="bi bi-search text-slate-400"></i></span>
                        <input type="text" class="form-control border-start-0 ps-0 shadow-none border-slate-200" placeholder="Tìm người / phòng ban...">
                    </div>
                </div>
                <div class="flex-grow-1 overflow-auto p-2">
                    <div class="small fw-bold text-slate-400 text-uppercase mb-2 mt-2 px-2" style="letter-spacing: 0.5px;">Channels Đặc Quyền</div>
                    
                    <a href="#" class="d-flex align-items-center gap-3 p-2 rounded-3 text-decoration-none hover-bg-slate-100 mb-1 active-channel" style="background-color: #e0e7ff;">
                        <div class="position-relative">
                            <div class="rounded-circle text-white d-flex align-items-center justify-content-center" style="width: 40px; height: 40px; background-color: #6366f1;">
                                <i class="bi bi-megaphone-fill"></i>
                            </div>
                        </div>
                        <div class="flex-grow-1 min-width-0">
                            <div class="d-flex justify-content-between align-items-baseline mb-1">
                                <h6 class="mb-0 fw-bold text-slate-800 text-truncate">Kênh Tổng Nhóm Kỹ Thuật & Lễ Tân</h6>
                            </div>
                            <p class="mb-0 text-slate-500 small text-truncate text-indigo-500 fw-medium">Lễ tân ơi, báo giá hộ tớ ca 14 Pro Max...</p>
                        </div>
                    </a>

                    <a href="#" class="d-flex align-items-center gap-3 p-2 rounded-3 text-decoration-none hover-bg-slate-100 mb-1">
                        <div class="position-relative">
                            <div class="rounded-circle text-white d-flex align-items-center justify-content-center bg-danger" style="width: 40px; height: 40px;">
                                <i class="bi bi-shield-lock-fill"></i>
                            </div>
                            <span class="position-absolute bottom-0 end-0 rounded-circle border border-white bg-success" style="width: 10px; height: 10px;"></span>
                        </div>
                        <div class="flex-grow-1 min-width-0">
                            <div class="d-flex justify-content-between align-items-baseline mb-1">
                                <h6 class="mb-0 fw-bold text-slate-700 text-truncate">Quản Lý - Phê duyệt gấp</h6>
                            </div>
                            <p class="mb-0 text-slate-500 small text-truncate">Gửi mình xem hóa đơn đỏ của phiếu #... nhé</p>
                        </div>
                    </a>
                    
                    <div class="small fw-bold text-slate-400 text-uppercase mb-2 mt-4 px-2" style="letter-spacing: 0.5px;">Direct Messages</div>
                    
                    <a href="#" class="d-flex align-items-center gap-3 p-2 rounded-3 text-decoration-none hover-bg-slate-100 mb-1">
                        <div class="position-relative">
                            <div class="rounded-circle text-white d-flex align-items-center justify-content-center bg-emerald-500" style="width: 40px; height: 40px;">
                                <i class="bi bi-person-fill"></i>
                            </div>
                            <span class="position-absolute bottom-0 end-0 rounded-circle border border-white bg-success" style="width: 10px; height: 10px;"></span>
                        </div>
                        <div class="flex-grow-1 min-width-0">
                            <div class="d-flex justify-content-between align-items-baseline mb-1">
                                <h6 class="mb-0 fw-bold text-slate-700 text-truncate">Thu Ngân (Ca Sáng)</h6>
                            </div>
                            <p class="mb-0 text-slate-500 small text-truncate">Khách Ck 500k rồi nhé</p>
                        </div>
                    </a>
                </div>
            </div>

            <!-- Chat Area -->
            <div class="col-12 col-md-9 h-100 d-flex flex-column">
                <div class="p-3 border-bottom border-slate-200 bg-white d-flex justify-content-between align-items-center shadow-sm z-1">
                    <div class="d-flex align-items-center gap-3">
                        <div class="rounded-circle text-white d-flex align-items-center justify-content-center shadow-sm" style="width: 42px; height: 42px; background-color: #6366f1;">
                            <i class="bi bi-megaphone-fill"></i>
                        </div>
                        <div>
                            <h6 class="mb-0 fw-bold text-slate-800">Kênh Tổng - Giao tiếp Kỹ Thuật & FO</h6>
                            <div class="text-emerald-500 small fw-medium"><i class="bi bi-circle-fill" style="font-size: 0.5rem; vertical-align: middle; margin-top: -2px;"></i> 14 thành viên Online</div>
                        </div>
                    </div>
                </div>

                <!-- Messages -->
                <div class="flex-grow-1 overflow-auto p-4 bg-slate-50" id="fullScreenChatArea" style="background-image: url('https://www.transparenttextures.com/patterns/cubes.png');">
                    
                    <div class="text-center small text-slate-400 my-3 font-monospace" style="font-size: 0.8rem;">
                        <span class="bg-slate-200 text-slate-600 px-3 py-1 rounded-pill">08 Tháng 11, 2026</span>
                    </div>

                    <div class="d-flex justify-content-start mb-3">
                        <div class="d-flex flex-column align-items-start" style="max-width: 70%;">
                            <div class="d-flex align-items-center mb-1 ms-1">
                                <span class="fw-bold text-indigo-600 small me-2">Quản Lý - Head Office</span>
                                <span class="text-slate-400 fw-normal" style="font-size: 0.75rem;">08:15</span>
                            </div>
                            <div class="p-3 bg-white rounded-4 shadow-sm text-slate-700 border border-slate-200" style="border-top-left-radius: 4px !important;">
                                Chào mọi người, anh em nhớ check inbox các ca khó và trao đổi trực tiếp ở đây nhé! Không cần chạy qua lại nữa, tiết kiệm thời gian đi lại chốt giá khách.
                            </div>
                        </div>
                    </div>

                    <div class="d-flex justify-content-start mb-3">
                        <div class="d-flex flex-column align-items-start" style="max-width: 70%;">
                            <div class="d-flex align-items-center mb-1 ms-1">
                                <span class="fw-bold text-emerald-600 small me-2" style="color: #059669;">Kỹ thuật viên 1</span>
                                <span class="text-slate-400 fw-normal" style="font-size: 0.75rem;">08:30</span>
                            </div>
                            <div class="p-3 bg-white rounded-4 shadow-sm text-slate-700 border border-slate-200" style="border-top-left-radius: 4px !important;">
                                Lễ tân ơi, báo giá hộ tớ ca 14 Pro Max lỗi hiển thị liệt cảm phần trên nhé! Màn bên mìn đang hết để mình đề xuất nhập kho gấp, khách có đồng ý chờ 2 hôm không?
                            </div>
                        </div>
                    </div>

                </div>

                <!-- Input box -->
                <div class="p-3 bg-white border-top border-slate-200">
                    <form class="d-flex gap-2" onsubmit="sendFullScreenChat(event)">
                        <button class="btn btn-light rounded-circle text-slate-500 d-flex align-items-center justify-content-center" style="width: 44px; height: 44px;" type="button" title="Gắn file đính kèm">
                            <i class="bi bi-paperclip fs-5"></i>
                        </button>
                        <input type="text" id="fullScreenChatInput" class="form-control rounded-pill border-slate-300 shadow-none ps-4 bg-slate-50" placeholder="Soạn tin nhắn tới nhóm Kỹ Thuật & FO..." style="font-size: 1rem;" required>
                        <button class="btn btn-indigo text-white rounded-circle d-flex justify-content-center align-items-center hover-lift shadow-sm" style="width: 44px; height: 44px; background-color: #4f46e5; border: none;" type="submit">
                            <i class="bi bi-send-fill fs-5"></i>
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Styles {
    <style>
        @@import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap');
        .font-inter { font-family: 'Inter', system-ui, -apple-system, sans-serif; }
        .bg-slate-50 { background-color: #f8fafc; }
        .text-slate-400 { color: #94a3b8; }
        .text-slate-500 { color: #64748b; }
        .text-slate-700 { color: #334155; }
        .text-slate-800 { color: #1e293b; }
        .border-slate-200 { border-color: #e2e8f0 !important; }
        .hover-bg-slate-100:hover { background-color: #f1f5f9; }
        .bg-indigo-50 { background-color: #eef2ff; }
        .text-indigo-600 { color: #4f46e5; }
        .text-indigo-500 { color: #6366f1; }
        .text-emerald-500 { color: #10b981; }
        .bg-emerald-500 { background-color: #10b981; }
        
        .hover-lift { transition: transform 0.2s; }
        .hover-lift:hover { transform: translateY(-2px); }
        .min-width-0 { min-width: 0; }
    </style>
}

@section Scripts {
    <script>
        function sendFullScreenChat(e) {
            e.preventDefault();
            const input = document.getElementById('fullScreenChatInput');
            const msg = input.value.trim();
            if(!msg) return;
            
            const area = document.getElementById('fullScreenChatArea');
            const now = new Date();
            const time = now.getHours().toString().padStart(2, '0') + ':' + now.getMinutes().toString().padStart(2, '0');
            const newMsgHtml = `
                <div class="d-flex justify-content-end mb-3 animate__animated animate__fadeInUp animate__faster">
                    <div class="d-flex flex-column align-items-end" style="max-width: 70%;">
                        <div class="d-flex align-items-center mb-1 me-1">
                            <span class="text-slate-400 fw-normal me-2" style="font-size: 0.75rem;">${time}</span>
                            <span class="fw-bold text-slate-700 small">Tôi (Bạn)</span>
                        </div>
                        <div class="p-3 rounded-4 shadow-sm text-white" style="background-color: #4f46e5; border-top-right-radius: 4px !important;">
                            ${msg}
                        </div>
                    </div>
                </div>`;
            area.insertAdjacentHTML('beforeend', newMsgHtml);
            input.value = '';
            area.scrollTop = area.scrollHeight;
        }
    </script>
}
