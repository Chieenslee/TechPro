@{
    ViewData["Title"] = "Chat nội bộ";
    Layout = "_Layout";
}

<div id="internalChatApp"
     data-user-name="@((User.FindFirst("FullName")?.Value ?? User.Identity?.Name ?? ""))"
     data-user-role="@((User.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value ?? "Support"))"
     class="chat-shell">
    <div class="chat-topbar">
        <div class="chat-brand">
            <span class="chat-brand__avatar"><i class="bi bi-chat-quote-fill"></i></span>
            <div class="chat-brand__meta">
                <div class="chat-brand__title">Chat nội bộ</div>
                <div class="chat-brand__subtitle">Giao tiếp nhanh giữa các bộ phận, có realtime và phân quyền theo vai trò</div>
            </div>
        </div>
        <div class="chat-actions">
            <div id="chatConnStatus" class="small fw-medium chat-status chat-status--muted">Đang kết nối...</div>
        </div>
    </div>

    <div class="chat-main">
        <aside class="chat-sidebar">
            <div class="chat-sidebar__search">
                <i class="bi bi-search"></i>
                <input id="chatChannelSearch" type="text" placeholder="Tìm kênh..." autocomplete="off" />
            </div>
            <div id="chatChannelList" class="chat-sidebar__list">
                <div class="p-3 text-center text-slate-500 small">Đang tải kênh...</div>
            </div>
        </aside>

        <section class="chat-panel">
            <div class="chat-panel__header">
                <div class="chat-panel__who">
                    <div id="chatActiveAvatar" class="chat-active-avatar" style="--ch:#4f46e5">
                        <i id="chatActiveIcon" class="bi bi-megaphone-fill"></i>
                    </div>
                    <div class="chat-panel__meta">
                        <div id="chatActiveName" class="chat-panel__title">Đang tải...</div>
                        <div class="chat-panel__sub">
                            <span class="dot dot--green"></span>
                            <span><span id="chatOnlineCount">0</span> online</span>
                            <span class="sep">•</span>
                            <span id="chatTyping" class="chat-typing d-none"></span>
                        </div>
                    </div>
                </div>
            </div>

            <div id="chatMessages" class="chat-panel__messages">
                <div class="p-3 text-center text-slate-500 small">Đang tải tin nhắn...</div>
            </div>

            <div class="chat-panel__composer">
                <form id="chatSendForm" class="chat-composer">
                    <input id="chatInput" type="text" placeholder="Nhập tin nhắn (Enter để gửi)..." autocomplete="off" />
                    <button id="chatSendBtn" type="submit" title="Gửi">
                        <i class="bi bi-send-fill"></i>
                    </button>
                </form>
                <div class="chat-hint">Mẹo: gõ nhanh, app tự reconnect khi mất mạng.</div>
            </div>
        </section>
    </div>
</div>

@section Styles {
    <style>
        :root {
            --slate-50: #f8fafc;
            --slate-100: #f1f5f9;
            --slate-200: #e2e8f0;
            --slate-500: #64748b;
            --slate-700: #334155;
            --slate-800: #1e293b;
            --indigo: #4f46e5;
            --emerald: #10b981;
            --rose: #e11d48;
            --amber: #f59e0b;
            --shadow: 0 10px 30px rgba(2, 6, 23, .08);
        }

        .text-slate-500 { color: var(--slate-500); }
        .text-slate-600 { color: #475569; }

        .chat-shell {
            min-height: calc(100vh - 64px);
            background: radial-gradient(1200px 500px at 10% 0%, rgba(79,70,229,.10), transparent 55%),
                        radial-gradient(1200px 500px at 90% 100%, rgba(16,185,129,.10), transparent 55%),
                        var(--slate-50);
            border-radius: 18px;
            overflow: hidden;
            box-shadow: var(--shadow);
            border: 1px solid var(--slate-200);
        }

        .chat-topbar {
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 16px 18px;
            background: rgba(255,255,255,.85);
            backdrop-filter: blur(10px);
            border-bottom: 1px solid var(--slate-200);
        }
        .chat-brand { display: flex; align-items: center; gap: 12px; min-width: 0; }
        .chat-brand__avatar {
            width: 44px; height: 44px; border-radius: 14px;
            display: grid; place-items: center;
            background: linear-gradient(135deg, #6366f1, #4f46e5);
            color: #fff;
            box-shadow: 0 12px 18px rgba(79,70,229,.25);
        }
        .chat-brand__title { font-weight: 800; color: var(--slate-800); line-height: 1.1; }
        .chat-brand__subtitle { font-size: 12px; color: var(--slate-500); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; max-width: 56vw; }

        .chat-status { padding: 6px 10px; border-radius: 999px; border: 1px solid var(--slate-200); background: #fff; }
        .chat-status--ok { color: #0f766e; border-color: rgba(16,185,129,.35); background: rgba(16,185,129,.10); }
        .chat-status--bad { color: #b91c1c; border-color: rgba(239,68,68,.35); background: rgba(239,68,68,.08); }
        .chat-status--muted { color: var(--slate-500); }

        .chat-main {
            display: grid;
            grid-template-columns: 320px 1fr;
            min-height: calc(100vh - 64px - 78px);
        }
        .chat-sidebar {
            background: rgba(255,255,255,.75);
            border-right: 1px solid var(--slate-200);
            backdrop-filter: blur(10px);
            display: flex;
            flex-direction: column;
            min-height: 0;
        }
        .chat-sidebar__search {
            display: flex;
            align-items: center;
            gap: 10px;
            padding: 14px 14px;
            border-bottom: 1px solid var(--slate-200);
        }
        .chat-sidebar__search i { color: #94a3b8; }
        .chat-sidebar__search input {
            width: 100%;
            border: 0;
            outline: none;
            background: transparent;
            font-size: 14px;
            color: var(--slate-800);
        }
        .chat-sidebar__list { padding: 10px; overflow: auto; min-height: 0; }

        .chat-channel-item {
            width: 100%;
            border: 1px solid transparent;
            background: transparent;
            padding: 10px 10px;
            border-radius: 14px;
            display: grid;
            grid-template-columns: 44px 1fr;
            gap: 12px;
            text-align: left;
            cursor: pointer;
            transition: all .15s ease;
        }
        .chat-channel-item:hover { background: rgba(241,245,249,.8); }
        .chat-channel-item.is-active {
            background: rgba(224,231,255,.70);
            border-color: rgba(79,70,229,.25);
        }
        .chat-channel-avatar {
            width: 44px; height: 44px; border-radius: 14px;
            display: grid; place-items: center;
            background: color-mix(in srgb, var(--ch) 18%, white);
            color: var(--ch);
            border: 1px solid color-mix(in srgb, var(--ch) 20%, var(--slate-200));
        }
        .chat-channel-meta { min-width: 0; display: flex; flex-direction: column; }
        .chat-channel-name { font-weight: 800; color: var(--slate-800); font-size: 14px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
        .chat-channel-sub { font-size: 12px; color: var(--slate-500); }

        .chat-panel { display: flex; flex-direction: column; min-height: 0; }
        .chat-panel__header {
            padding: 14px 16px;
            background: rgba(255,255,255,.85);
            border-bottom: 1px solid var(--slate-200);
            backdrop-filter: blur(10px);
        }
        .chat-panel__who { display: flex; align-items: center; justify-content: space-between; gap: 12px; }
        .chat-active-avatar {
            width: 44px; height: 44px; border-radius: 14px;
            display: grid; place-items: center;
            background: color-mix(in srgb, var(--ch) 18%, white);
            color: var(--ch);
            border: 1px solid color-mix(in srgb, var(--ch) 20%, var(--slate-200));
        }
        .chat-panel__meta { min-width: 0; }
        .chat-panel__title { font-weight: 900; color: var(--slate-800); }
        .chat-panel__sub { font-size: 12px; color: var(--slate-500); display: flex; align-items: center; gap: 10px; }
        .sep { opacity: .7; }
        .dot { width: 8px; height: 8px; border-radius: 999px; display: inline-block; }
        .dot--green { background: var(--emerald); box-shadow: 0 0 0 4px rgba(16,185,129,.12); }
        .chat-typing { color: #0f766e; }

        .chat-panel__messages {
            flex: 1;
            overflow: auto;
            padding: 18px 18px 10px;
            background:
                radial-gradient(600px 200px at 15% 0%, rgba(79,70,229,.07), transparent 70%),
                radial-gradient(600px 200px at 85% 100%, rgba(16,185,129,.07), transparent 70%),
                url('https://www.transparenttextures.com/patterns/cubes.png'),
                var(--slate-50);
        }

        .chat-msg { margin-bottom: 12px; max-width: 780px; }
        .chat-msg__meta { display: flex; align-items: baseline; gap: 8px; margin: 0 0 6px 6px; }
        .chat-msg__name { font-weight: 900; font-size: 12px; }
        .chat-msg__time { font-size: 11px; color: #94a3b8; }
        .chat-bubble {
            display: inline-block;
            padding: 12px 14px;
            border-radius: 16px;
            border-top-left-radius: 6px;
            background: rgba(255,255,255,.95);
            border: 1px solid var(--slate-200);
            box-shadow: 0 8px 16px rgba(2,6,23,.05);
            color: var(--slate-700);
            white-space: pre-wrap;
            word-break: break-word;
        }
        .chat-msg--me { margin-left: auto; text-align: right; }
        .chat-msg--me .chat-msg__meta { justify-content: flex-end; margin: 0 6px 6px 0; }
        .chat-bubble--me {
            background: linear-gradient(135deg, #6366f1, #4f46e5);
            color: #fff;
            border: 0;
            border-top-right-radius: 6px;
            border-top-left-radius: 16px;
        }

        .text-emerald-600 { color: #059669; }
        .text-indigo-600 { color: #4f46e5; }
        .text-rose-600 { color: #e11d48; }
        .text-amber-600 { color: #d97706; }

        .chat-panel__composer {
            padding: 12px 14px;
            background: rgba(255,255,255,.85);
            border-top: 1px solid var(--slate-200);
            backdrop-filter: blur(10px);
        }
        .chat-composer {
            display: grid;
            grid-template-columns: 1fr 44px;
            gap: 10px;
            align-items: center;
        }
        .chat-composer input {
            height: 44px;
            border-radius: 999px;
            border: 1px solid var(--slate-200);
            padding: 0 16px;
            background: rgba(248,250,252,.9);
            outline: none;
            font-size: 14px;
        }
        .chat-composer input:focus { border-color: rgba(79,70,229,.55); box-shadow: 0 0 0 4px rgba(79,70,229,.12); }
        .chat-composer button {
            width: 44px; height: 44px;
            border-radius: 999px;
            border: 0;
            background: linear-gradient(135deg, #6366f1, #4f46e5);
            color: #fff;
            box-shadow: 0 12px 18px rgba(79,70,229,.22);
        }
        .chat-composer button:disabled { opacity: .6; cursor: not-allowed; }
        .chat-hint { margin-top: 8px; font-size: 12px; color: var(--slate-500); }

        @@media (max-width: 992px) {
            .chat-main { grid-template-columns: 1fr; }
            .chat-sidebar { display: none; }
            .chat-brand__subtitle { max-width: 44vw; }
        }
    </style>
}

@section Scripts {
    <script src="~/js/internal-chat.js" asp-append-version="true"></script>
}
