@model IEnumerable<PhieuSuaChua>
@{
    ViewData["Title"] = "Điều phối kỹ thuật (Giám sát)";
    var searchTerm = ViewBag.SearchTerm as string ?? "";
    var status = ViewBag.StatusFilter as string ?? "all";

    var columns = new[]
    {
        new { Id = "pending", Title = "Chờ kiểm tra", Color = "warning", Icon = "clock" },
        new { Id = "repairing", Title = "Đang sửa", Color = "info", Icon = "tools" },
        new { Id = "waiting_parts", Title = "Chờ linh kiện", Color = "danger", Icon = "pause-circle" },
        new { Id = "done", Title = "Hoàn thành", Color = "success", Icon = "check-circle" },
        new { Id = "delivered", Title = "Đã trả", Color = "secondary", Icon = "box-arrow-right" },
    };
}

<div class="d-flex flex-wrap justify-content-between align-items-end gap-3 mb-3">
    <div>
        <h2 class="fw-bold mb-1">Điều phối Kỹ thuật</h2>
        <p class="text-muted mb-0">Chế độ giám sát: xem tiến độ theo trạng thái.</p>
    </div>
    <form class="d-flex flex-wrap gap-2" method="get" action="/StoreAdmin/KyThuat/Index">
        <input type="text" class="form-control form-control-sm" name="searchTerm" value="@searchTerm" placeholder="Tìm mã phiếu / SĐT / tên..." style="min-width: 240px;" />
        <select class="form-select form-select-sm" name="status" style="min-width: 180px;">
            <option value="all" selected="@(status=="all")">Tất cả</option>
            @foreach (var c in columns)
            {
                <option value="@c.Id" selected="@(status==c.Id)">@c.Id</option>
            }
        </select>
        <button type="submit" class="btn btn-primary btn-sm">
            <i class="bi bi-search me-1"></i>Lọc
        </button>
    </form>
</div>

<div class="d-flex flex-nowrap gap-3 overflow-auto pb-3">
    @foreach (var col in columns)
    {
        var items = (Model ?? Enumerable.Empty<PhieuSuaChua>()).Where(t => t.TrangThai == col.Id).OrderByDescending(t => t.NgayNhan).ToList();
        <div class="card border-0 shadow-sm rounded-4" style="min-width: 320px; width: 320px;">
            <div class="card-header bg-transparent border-0 pt-3 pb-2 px-3 d-flex justify-content-between align-items-center">
                <div class="d-flex align-items-center gap-2">
                    <div class="rounded-circle d-flex align-items-center justify-content-center bg-@col.Color bg-opacity-10 text-@col.Color" style="width:32px;height:32px;">
                        <i class="bi bi-@col.Icon"></i>
                    </div>
                    <div class="fw-bold">@col.Title</div>
                </div>
                <span class="badge bg-light text-dark border rounded-pill">@items.Count</span>
            </div>
            <div class="card-body px-2 py-2" style="max-height: calc(100vh - 260px); overflow:auto;">
                @if (items.Any())
                {
                    foreach (var t in items)
                    {
                        <a class="card border-0 shadow-sm rounded-3 mb-2 text-decoration-none text-dark"
                           href="/StoreAdmin/KyThuat/ChiTiet/@t.Id"
                           style="display:block;">
                            <div class="card-body p-3">
                                <div class="d-flex justify-content-between align-items-start mb-1">
                                    <span class="badge bg-primary bg-opacity-10 text-primary rounded-pill">@t.Id</span>
                                    <span class="text-muted small">@t.NgayNhan.ToString("dd/MM HH:mm")</span>
                                </div>
                                <div class="fw-bold text-truncate">@t.TenThietBi</div>
                                <div class="text-muted small text-truncate">@t.TenKhachHang • @t.SoDienThoai</div>
                                @if (t.KyThuatVien != null)
                                {
                                    <div class="mt-2 small">
                                        <span class="badge bg-info bg-opacity-10 text-info rounded-pill">KTV: @t.KyThuatVien.TenDayDu</span>
                                    </div>
                                }
                            </div>
                        </a>
                    }
                }
                else
                {
                    <div class="text-center text-muted small py-4">
                        <i class="bi bi-inbox opacity-50 d-block mb-2 fs-4"></i>
                        Trống
                    </div>
                }
            </div>
        </div>
    }
</div>

