@{
    ViewData["Title"] = "Báo cáo chi tiết";
}

<div class="mb-4">
    <h2 class="fw-bold">Báo cáo chi tiết</h2>
    <p class="text-muted mb-0">Phân tích dữ liệu và xuất báo cáo chi tiết.</p>
</div>

<div class="row g-4">
    <!-- Export Options -->
    <div class="col-12">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-light">
                <h5 class="mb-0">Xuất báo cáo</h5>
            </div>
            <div class="card-body">
                <div class="row g-3">
                    <div class="col-md-4">
                        <label class="form-label">Từ ngày</label>
                        <input type="date" class="form-control" id="fromDate" value="@DateTime.Now.AddDays(-30).ToString("yyyy-MM-dd")" />
                    </div>
                    <div class="col-md-4">
                        <label class="form-label">Đến ngày</label>
                        <input type="date" class="form-control" id="toDate" value="@DateTime.Now.ToString("yyyy-MM-dd")" />
                    </div>
                    <div class="col-md-4">
                        <label class="form-label">Loại báo cáo</label>
                        <select class="form-select" id="reportType">
                            <option value="tickets">Danh sách phiếu</option>
                            <option value="revenue">Doanh thu</option>
                            <option value="inventory">Kho linh kiện</option>
                        </select>
                    </div>
                </div>
                <div class="mt-3">
                    <button class="btn btn-primary" onclick="exportReport()">
                        <i class="bi bi-file-earmark-excel me-2"></i>Xuất Excel
                    </button>
                    <button class="btn btn-outline-secondary" onclick="printReport()">
                        <i class="bi bi-printer me-2"></i>In báo cáo
                    </button>
                </div>
            </div>
        </div>
    </div>

    <!-- Report Summary Cards -->
    <div class="col-md-4">
        <div class="card border-0 shadow-sm">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-start">
                    <div>
                        <p class="text-muted small mb-1">Tổng phiếu (30 ngày)</p>
                        <h3 class="fw-bold mb-0" id="totalTickets">-</h3>
                    </div>
                    <div class="bg-primary bg-opacity-10 p-3 rounded">
                        <i class="bi bi-file-text text-primary fs-4"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="col-md-4">
        <div class="card border-0 shadow-sm">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-start">
                    <div>
                        <p class="text-muted small mb-1">Tổng doanh thu (30 ngày)</p>
                        <h3 class="fw-bold mb-0" id="totalRevenue">-</h3>
                    </div>
                    <div class="bg-success bg-opacity-10 p-3 rounded">
                        <i class="bi bi-currency-dollar text-success fs-4"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="col-md-4">
        <div class="card border-0 shadow-sm">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-start">
                    <div>
                        <p class="text-muted small mb-1">Tỷ lệ hoàn thành</p>
                        <h3 class="fw-bold mb-0" id="completionRate">-</h3>
                    </div>
                    <div class="bg-info bg-opacity-10 p-3 rounded">
                        <i class="bi bi-check-circle text-info fs-4"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            loadReportSummary();
        });

        function loadReportSummary() {
            const fromDate = document.getElementById('fromDate').value;
            const toDate = document.getElementById('toDate').value;

            $.getJSON('/StoreAdmin/QuanLy/GetReportSummary', { fromDate, toDate }, function(response) {
                if (response.success) {
                    const d = response.data || {};
                    const totalTickets = d.totalTickets ?? d.TotalTickets ?? 0;
                    const totalRevenue = d.totalRevenue ?? d.TotalRevenue ?? 0;
                    const completionRate = d.completionRate ?? d.CompletionRate ?? 0;
                    document.getElementById('totalTickets').textContent = totalTickets;
                    document.getElementById('totalRevenue').textContent = (Number(totalRevenue) || 0).toLocaleString('vi-VN') + ' ₫';
                    document.getElementById('completionRate').textContent = (Number(completionRate) || 0).toFixed(1) + '%';
                }
            });
        }

        function exportReport() {
            const fromDate = document.getElementById('fromDate').value;
            const toDate = document.getElementById('toDate').value;
            const reportType = document.getElementById('reportType').value;

            let url = '';
            if (reportType === 'tickets') {
                url = `/StoreAdmin/Export/ExportTicketsCsv?fromDate=${fromDate}&toDate=${toDate}`;
            } else if (reportType === 'revenue') {
                url = `/StoreAdmin/Export/ExportRevenueCsv?fromDate=${fromDate}&toDate=${toDate}`;
            } else if (reportType === 'inventory') {
                url = `/StoreAdmin/Export/ExportInventoryCsv`;
            }

            window.location.href = url;
        }

        function printReport() {
            window.print();
        }

        // Reload summary when dates change
        document.getElementById('fromDate').addEventListener('change', loadReportSummary);
        document.getElementById('toDate').addEventListener('change', loadReportSummary);
    </script>
}

