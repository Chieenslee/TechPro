@model TechPro.Models.DashboardViewModel
@using System.Text.Json
@{
    ViewData["Title"] = "Báo cáo & Hiệu suất";
    var totalRevenue = Model.TotalRevenue;
    var revenueChange = Model.RevenueChange;
    var totalTickets = Model.TotalTickets;
    var thisMonthTickets = Model.ThisMonthTickets;
    var revenueData = Model.RevenueData;
    var statusData = Model.StatusData;
    var topParts = Model.TopParts;
    var techPerformance = Model.TechPerformance;

    int StatusCount(string key) => statusData?.FirstOrDefault(s => string.Equals(s.Status, key, StringComparison.OrdinalIgnoreCase))?.Count ?? 0;
    var pendingCount = StatusCount("pending");
    var repairingCount = StatusCount("repairing");
    var waitingPartsCount = StatusCount("waiting_parts");
    var doneCount = StatusCount("done");
    var deliveredCount = StatusCount("delivered");
    var completedCount = doneCount + deliveredCount;
    var completionRate = totalTickets > 0 ? (completedCount * 100.0 / totalTickets) : 0.0;
}

<div class="dashboard-shell">
    <!-- Header -->
    <div class="d-flex flex-wrap justify-content-between align-items-center mb-4 gap-3">
        <div>
            <h2 class="fw-bold mb-1">Báo cáo & Hiệu suất</h2>
            <p class="text-muted mb-0">Tổng quan doanh thu, lưu lượng phiếu và hiệu suất nhân sự tại cửa hàng.</p>
        </div>
        <div class="d-flex flex-wrap align-items-center gap-2">
            <a class="btn btn-outline-secondary btn-sm" href="/StoreAdmin/QuanLy/BaoCao">
                <i class="bi bi-graph-up-arrow me-1"></i>Báo cáo
            </a>
            <button class="btn btn-primary btn-sm d-flex align-items-center gap-1" onclick="exportRevenue()">
                <i class="bi bi-download"></i><span>Tải CSV</span>
            </button>
        </div>
    </div>

    <!-- KPI row -->
    <div class="row g-3 mb-4">
        <div class="col-6 col-xl-3">
            <div class="card border-0 shadow-sm kpi-card">
                <div class="card-body">
                    <div class="d-flex justify-content-between">
                        <div>
                            <p class="text-muted small mb-1">Doanh thu tháng</p>
                            <h4 class="fw-bold mb-1">@totalRevenue.ToString("N0") ₫</h4>
                            <small class="@(revenueChange >= 0 ? "text-success" : "text-danger") d-flex align-items-center gap-1">
                                <i class="bi @(revenueChange >= 0 ? "bi-arrow-up" : "bi-arrow-down")"></i>@revenueChange.ToString("F1")% vs tháng trước
                            </small>
                        </div>
                        <div class="kpi-icon bg-primary-subtle text-primary">
                            <i class="bi bi-currency-dollar"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-6 col-xl-3">
            <div class="card border-0 shadow-sm kpi-card">
                <div class="card-body">
                    <div class="d-flex justify-content-between">
                        <div>
                            <p class="text-muted small mb-1">Phiếu tháng này</p>
                            <h4 class="fw-bold mb-1">@thisMonthTickets</h4>
                            <small class="text-muted">Tổng phiếu: @totalTickets.ToString("N0")</small>
                        </div>
                        <div class="kpi-icon bg-info-subtle text-info">
                            <i class="bi bi-receipt"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-6 col-xl-3">
            <div class="card border-0 shadow-sm kpi-card">
                <div class="card-body">
                    <div class="d-flex justify-content-between">
                        <div>
                            <p class="text-muted small mb-1">Tỷ lệ hoàn thành</p>
                            <h4 class="fw-bold mb-1">@completionRate.ToString("F1")%</h4>
                            <small class="text-muted">Done/Delivered: @completedCount</small>
                        </div>
                        <div class="kpi-icon bg-warning-subtle text-warning">
                            <i class="bi bi-check2-circle"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-6 col-xl-3">
            <div class="card border-0 shadow-sm kpi-card">
                <div class="card-body">
                    <div class="d-flex justify-content-between">
                        <div>
                            <p class="text-muted small mb-1">Đang xử lý</p>
                            <h4 class="fw-bold mb-1">@((pendingCount + repairingCount + waitingPartsCount).ToString("N0"))</h4>
                            <small class="text-muted">Pending: @pendingCount • Repairing: @repairingCount • Chờ đồ: @waitingPartsCount</small>
                        </div>
                        <div class="kpi-icon bg-success-subtle text-success">
                            <i class="bi bi-hourglass-split"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Doanh thu + cảnh báo -->
    <div class="row g-3 mb-4">
        <div class="col-lg-8">
            <div class="card border-0 shadow-sm chart-card">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center mb-2">
                        <h5 class="fw-semibold mb-0">Xu hướng Doanh thu</h5>
                        <div class="btn-group btn-group-sm" role="group">
                            <button type="button" class="btn btn-outline-secondary active" onclick="changeChartPeriod('7days')">Theo ngày</button>
                            <button type="button" class="btn btn-outline-secondary" onclick="changeChartPeriod('30days')">Theo tuần</button>
                        </div>
                    </div>
                    <div class="chart-container-fixed">
                        <canvas id="revenueChart"></canvas>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-lg-4">
            <div class="card border-0 shadow-sm alert-card h-100">
                <div class="card-body">
                    <h6 class="fw-semibold mb-3">Tình trạng theo trạng thái</h6>
                    <div class="d-flex flex-wrap gap-2">
                        <span class="badge bg-warning bg-opacity-10 text-warning">Pending: @pendingCount</span>
                        <span class="badge bg-info bg-opacity-10 text-info">Repairing: @repairingCount</span>
                        <span class="badge bg-danger bg-opacity-10 text-danger">Chờ linh kiện: @waitingPartsCount</span>
                        <span class="badge bg-success bg-opacity-10 text-success">Hoàn tất: @completedCount</span>
                    </div>
                    <div class="mt-3 small text-muted">
                        Gợi ý: vào trang <a href="/StoreAdmin/QuanLy/BaoCao">Báo cáo</a> để xuất danh sách phiếu/doanh thu theo khoảng ngày.
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Cơ cấu + Top sản phẩm + Top nhân viên -->
    <div class="row g-3">
        <div class="col-lg-4">
            <div class="card border-0 shadow-sm">
                <div class="card-body">
                    <h6 class="fw-semibold mb-3">Cơ cấu Doanh thu</h6>
                    <div class="chart-container-doughnut">
                        <canvas id="statusChart"></canvas>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-lg-4">
            <div class="card border-0 shadow-sm">
                <div class="card-body">
                    <h6 class="fw-semibold mb-3">Top linh kiện bán chạy</h6>
                    <div class="chart-container-doughnut">
                        <canvas id="topPartsChart"></canvas>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-lg-4">
            <div class="card border-0 shadow-sm">
                <div class="card-body">
                    <h6 class="fw-semibold mb-3">Top nhân viên xuất sắc</h6>
                    <ul class="list-group list-group-flush small">
                        @foreach (var t in techPerformance.OrderByDescending(t => t.Completed).Take(3))
                        {
                            <li class="list-group-item d-flex justify-content-between align-items-center px-0">
                                <div class="d-flex align-items-center gap-2">
                                    <img src="https://ui-avatars.com/api/?name=@Uri.EscapeDataString(t.TechName)&background=2563eb&color=fff"
                                         class="rounded-circle" style="width:32px;height:32px;" />
                                    <div>
                                        <div class="fw-semibold">@t.TechName</div>
                                        <div class="text-muted">Hoàn thành @t.Completed / @t.Total</div>
                                    </div>
                                </div>
                                <div class="text-end">
                                    <div class="fw-bold text-success">@((t.Completed * 100.0 / Math.Max(t.Total,1)).ToString("F0"))%</div>
                                </div>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </div>
    </div>
</div>

@section Styles {
    <link rel="stylesheet" href="~/css/manager.css" asp-append-version="true" />
}

@section Scripts {
    <script src="~/js/manager.js" asp-append-version="true"></script>
    <script>
        const revenueData = @Html.Raw(JsonSerializer.Serialize(revenueData));
        const statusData = @Html.Raw(JsonSerializer.Serialize(statusData));
        const topParts = @Html.Raw(JsonSerializer.Serialize(topParts));
        const techPerformance = @Html.Raw(JsonSerializer.Serialize(techPerformance));
        // Giữ nguyên các hàm initRevenueChart, initStatusChart, initTopPartsChart, initTechnicianChart, exportRevenue, printReport
        // ở file js/manager.js để tránh vỡ logic.
    </script>
}