@using System.Security.Claims

@{
    var user = User;
    var userRole = User.FindFirst(ClaimTypes.Role)?.Value ?? "support";
    
    // Map ASP.NET roles to React roles
    var reactRole = userRole switch
    {
        "SystemAdmin" => "system_admin",
        "StoreAdmin" => "store_admin",
        "Technician" => "technician",
        "Support" => "support",
        _ => "support"
    };
    
    var menuItems = new List<dynamic>
    {
        // ─── SysAdmin Only ──────────────────────────────────────────────
        new { Label = "Trạm Master Admin", Path = "/SysAdmin", Icon = "globe", Roles = new[] { "SystemAdmin" }, ReactIcon = "Globe" },
        new { Label = "Tổng quan chuỗi", Path = "/SysAdmin/Chain", Icon = "globe", Roles = new[] { "SystemAdmin" }, ReactIcon = "Globe" },
        new { Label = "Quản lý cửa hàng", Path = "/SysAdmin/Chain?tab=stores", Icon = "shop", Roles = new[] { "SystemAdmin" }, ReactIcon = "Store" },
        new { Label = "Quản trị nhân sự", Path = "/SysAdmin/Chain?tab=staff", Icon = "people", Roles = new[] { "SystemAdmin" }, ReactIcon = "Users" },
        new { Label = "Kho tổng (Master)", Path = "/SysAdmin/Chain?tab=inventory", Icon = "box", Roles = new[] { "SystemAdmin" }, ReactIcon = "Package" },

        // ─── StoreAdmin Only ────────────────────────────────────────
        new { Label = "Trạm Quản Lý", Path = "/StoreAdmin", Icon = "person-badge-fill", Roles = new[] { "StoreAdmin" }, ReactIcon = "Briefcase" },
        new { Label = "Tổng quan doanh thu", Path = "/StoreAdmin/QuanLy", Icon = "speedometer2", Roles = new[] { "StoreAdmin" }, ReactIcon = "LayoutDashboard" },
        new { Label = "Báo cáo", Path = "/StoreAdmin/QuanLy/BaoCao", Icon = "graph-up", Roles = new[] { "StoreAdmin" }, ReactIcon = "BarChart3" },
        new { Label = "Kho & Duyệt linh kiện", Path = "/Support/Kho", Icon = "box", Roles = new[] { "StoreAdmin" }, ReactIcon = "Package" },
        new { Label = "Cấu hình cửa hàng", Path = "/StoreAdmin/QuanLy/CauHinh", Icon = "gear", Roles = new[] { "StoreAdmin" }, ReactIcon = "Settings" },
        new { Label = "Diều phối Kỹ Thuật", Path = "/Technician/KyThuat", Icon = "wrench", Roles = new[] { "StoreAdmin" }, ReactIcon = "Wrench" },
        new { Label = "Xem Lễ Tân", Path = "/Support/TiepNhan", Icon = "clipboard-check", Roles = new[] { "StoreAdmin" }, ReactIcon = "ClipboardList" },

        // ─── Technician Only ────────────────────────────────────────
        new { Label = "Trạm Kỹ Thuật", Path = "/Technician", Icon = "tools", Roles = new[] { "Technician" }, ReactIcon = "PenTool" },
        new { Label = "Giỏ máy của tôi", Path = "/Technician/KyThuat", Icon = "wrench", Roles = new[] { "Technician" }, ReactIcon = "Wrench" },
        new { Label = "Yêu cầu Linh Kiện", Path = "/Technician/KyThuat/LinhKien", Icon = "box", Roles = new[] { "Technician" }, ReactIcon = "Package" },

        // ─── Support (Lễ tân / FO) Only ─────────────────────────────
        new { Label = "Trạm Lễ Tân", Path = "/Support", Icon = "house", Roles = new[] { "Support" }, ReactIcon = "Home" },
        new { Label = "Tiếp nhận máy", Path = "/Support/TiepNhan", Icon = "clipboard-check", Roles = new[] { "Support" }, ReactIcon = "ClipboardList" },
        new { Label = "Trả máy & Thu ngân", Path = "/Support/TraMay", Icon = "arrow-counterclockwise", Roles = new[] { "Support" }, ReactIcon = "RotateCcw" },
        new { Label = "Kho linh kiện (xem)", Path = "/Support/Kho", Icon = "box", Roles = new[] { "Support" }, ReactIcon = "Package" },

        // ─── Chung mọi vai trò ────────────────────────────────────────
        new { Label = "Chat Nội Bộ", Path = "/Chat", Icon = "chat-quote", Roles = new[] { "SystemAdmin", "StoreAdmin", "Technician", "Support" }, ReactIcon = "MessageSquare" },
    };
    
    var filteredMenuItems = menuItems.Where(item => 
    {
        var rolesArray = item.Roles as string[];
        if (rolesArray == null) return false;
        return Array.Exists(rolesArray, r => string.Equals(r, userRole, StringComparison.OrdinalIgnoreCase));
    }).ToList();
    
    // Helper function to check active state
    bool IsActive(string itemPath, string currentPath, string currentQuery)
    {
        if (userRole != "SystemAdmin")
        {
            return currentPath.Equals(itemPath, StringComparison.OrdinalIgnoreCase);
        }
        
        // For System Admin using query params
        if (itemPath == "/Chain")
        {
            return currentPath.Equals("/Chain", StringComparison.OrdinalIgnoreCase) && 
                   (string.IsNullOrEmpty(currentQuery) || currentQuery.Contains("tab=overview"));
        }
        
        return (currentPath + currentQuery).Equals(itemPath, StringComparison.OrdinalIgnoreCase);
    }
    
    var currentPath = Context.Request.Path.Value ?? "";
    var currentQuery = Context.Request.QueryString.Value ?? "";
}

<aside class="sidebar" id="sidebar" onclick="event.stopPropagation()">
    <!-- Branding -->
    <div class="sidebar-header">
        <div class="sidebar-brand">
            <div class="brand-icon @(userRole == "SystemAdmin" ? "system-admin" : "store-admin")">
                <i data-lucide="@(userRole == "SystemAdmin" ? "network" : "store")" class="icon"></i>
            </div>
            <span class="brand-text">
                @(userRole == "SystemAdmin" ? "TechPro Central" : "TechPro Store")
            </span>
        </div>
    </div>
    
    <!-- Navigation -->
    <nav class="sidebar-nav">
        <div class="menu-section-label">Menu</div>
        
        @foreach (var item in filteredMenuItems)
        {
            var isActive = IsActive(item.Path, currentPath, currentQuery);
            var iconClass = item.Icon switch
            {
                "person-badge-fill" => "bi-person-badge-fill",
                "tools" => "bi-tools",
                "chat-quote" => "bi-chat-quote-fill",
                "house" => "bi-house-heart",
                "globe" => "bi-globe",
                "shop" => "bi-shop",
                "people" => "bi-people",
                "box" => "bi-box-seam",
                "speedometer2" => "bi-speedometer2",
                "clipboard-check" => "bi-clipboard-check",
                "arrow-counterclockwise" => "bi-arrow-counterclockwise",
                "wrench" => "bi-wrench",
                "graph-up" => "bi-graph-up-arrow",
                "gear" => "bi-gear",
                _ => "bi-circle"
            };
            <a 
                href="@item.Path" 
                class="nav-link @(isActive ? "active" : "") @(userRole == "SystemAdmin" && isActive ? "system-admin" : "")"
                onclick="toggleSidebar();"
            >
                <i class="bi @iconClass"></i>
                <span>@item.Label</span>
            </a>
        }
    </nav>
    
    <!-- Footer / Logout -->
    <div class="sidebar-footer">
        <form asp-controller="Account" asp-action="Logout" method="post" class="w-100">
            <button type="submit" class="logout-btn">
                <i data-lucide="log-out" class="icon"></i>
                <span>Đăng xuất</span>
            </button>
        </form>
    </div>
</aside>

<script>
    // Initialize icons in sidebar after DOM loads
    document.addEventListener('DOMContentLoaded', function() {
        if (typeof lucide !== 'undefined') {
            lucide.createIcons();
        }
    });
</script>
