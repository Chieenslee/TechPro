@model PhieuSuaChua
@{
    ViewData["Title"] = "Chi tiết trả máy";
    var isPrint = ViewBag.IsPrint as bool? ?? false;
    var totalCost = ViewBag.TotalCost as decimal? ?? 0;
    var partsCost = ViewBag.PartsCost as decimal? ?? 0;
    var serviceFee = ViewBag.ServiceFee as decimal? ?? 0;
}

@if (!isPrint)
{
    <div class="mb-4">
        <div class="d-flex justify-content-between align-items-center">
            <div>
                <a href="@Url.Action("Index")" class="btn btn-outline-secondary mb-2">
                    <i class="bi bi-arrow-left me-2"></i>Quay lại
                </a>
                <h2 class="fw-bold mb-0">Chi tiết trả máy: @Model.Id</h2>
            </div>
            <div class="d-flex gap-2">
                <button class="btn btn-outline-primary" onclick="window.print()">
                    <i class="bi bi-printer me-2"></i>In phiếu
                </button>
                @if (Model.TrangThai == "done")
                {
                    <button class="btn btn-success" onclick="xacNhanTra('@Model.Id')">
                        <i class="bi bi-check-circle me-2"></i>Xác nhận trả máy
                    </button>
                }
            </div>
        </div>
    </div>
}

<div class="row g-4">
    <div class="col-lg-8">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-light">
                <h5 class="mb-0">Thông tin phiếu sửa chữa</h5>
            </div>
            <div class="card-body">
                <div class="row g-3">
                    <div class="col-md-6">
                        <label class="text-muted small">Mã phiếu</label>
                        <div class="fw-bold">@Model.Id</div>
                    </div>
                    <div class="col-md-6">
                        <label class="text-muted small">Ngày nhận</label>
                        <div>@Model.NgayNhan.ToString("dd/MM/yyyy HH:mm")</div>
                    </div>
                    <div class="col-md-6">
                        <label class="text-muted small">Khách hàng</label>
                        <div class="fw-semibold">@Model.TenKhachHang</div>
                        <div class="text-muted">@Model.SoDienThoai</div>
                    </div>
                    <div class="col-md-6">
                        <label class="text-muted small">Thiết bị</label>
                        <div class="fw-semibold">@Model.TenThietBi</div>
                        @if (!string.IsNullOrEmpty(Model.SerialNumber))
                        {
                            <div class="text-muted">SN: @Model.SerialNumber</div>
                        }
                    </div>
                    <div class="col-12">
                        <label class="text-muted small">Mô tả lỗi</label>
                        <div class="bg-light p-3 rounded">@Model.MoTaLoi</div>
                    </div>
                    @if (!string.IsNullOrEmpty(Model.KetQuaKiemTra))
                    {
                        <div class="col-12">
                            <label class="text-muted small">Kết quả kiểm tra</label>
                            <div class="bg-info bg-opacity-10 p-3 rounded">@Model.KetQuaKiemTra</div>
                        </div>
                    }
                </div>
            </div>
        </div>

        <div class="card border-0 shadow-sm mt-4">
            <div class="card-header bg-light">
                <h5 class="mb-0">Linh kiện đã sử dụng</h5>
            </div>
            <div class="card-body">
                <div class="table-responsive">
                    <table class="table table-sm">
                        <thead>
                            <tr>
                                <th>Linh kiện</th>
                                <th class="text-center">Số lượng</th>
                                <th class="text-end">Đơn giá</th>
                                <th class="text-end">Thành tiền</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var req in Model.YeuCauLinhKiens?.Where(y => y.TrangThai == "approved") ?? new List<YeuCauLinhKien>())
                            {
                                <tr>
                                    <td>@req.LinhKien?.TenLinhKien</td>
                                    <td class="text-center">@req.SoLuong</td>
                                    <td class="text-end">@((req.GiaTaiThoiDiemYeuCau ?? 0).ToString("N0")) ₫</td>
                                    <td class="text-end fw-semibold">@(((req.GiaTaiThoiDiemYeuCau ?? 0) * req.SoLuong).ToString("N0")) ₫</td>
                                </tr>
                            }
                            @if (!Model.YeuCauLinhKiens?.Any(y => y.TrangThai == "approved") == true)
                            {
                                <tr>
                                    <td colspan="4" class="text-center text-muted py-3">Không có linh kiện nào</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>

    <div class="col-lg-4">
        <div class="card border-0 shadow-sm sticky-top" style="top: 20px;">
            <div class="card-header bg-primary text-white">
                <h5 class="mb-0">Hóa đơn thanh toán</h5>
            </div>
            <div class="card-body">
                <div class="mb-3">
                    <div class="d-flex justify-content-between mb-2">
                        <span class="text-muted">Tổng linh kiện:</span>
                        <span class="fw-semibold">@partsCost.ToString("N0") ₫</span>
                    </div>
                    <div class="d-flex justify-content-between mb-2">
                        <span class="text-muted">Phí dịch vụ:</span>
                        <span class="fw-semibold">@serviceFee.ToString("N0") ₫</span>
                    </div>
                    @if (Model.CoBaoHanh == true)
                    {
                        <div class="alert alert-success mb-2 py-2">
                            <i class="bi bi-check-circle me-1"></i>Miễn phí do còn bảo hành
                        </div>
                    }
                    <hr>
                    <div class="d-flex justify-content-between">
                        <span class="fw-bold fs-5">Tổng cộng:</span>
                        <span class="fw-bold fs-5 text-primary">@totalCost.ToString("N0") ₫</span>
                    </div>
                </div>

                <div class="mb-3">
                    <label class="text-muted small">Trạng thái</label>
                    <div>
                        <span class="badge bg-@(Model.TrangThai == "done" ? "success" : "info") fs-6">
                            @(Model.TrangThai == "done" ? "Hoàn thành - Sẵn sàng trả" : "Đã trả khách")
                        </span>
                    </div>
                </div>

                @if (!string.IsNullOrEmpty(Model.KyThuatVien?.TenDayDu))
                {
                    <div class="mb-3">
                        <label class="text-muted small">Kỹ thuật viên</label>
                        <div class="fw-semibold">@Model.KyThuatVien.TenDayDu</div>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

@Html.AntiForgeryToken()

@section Scripts {
    <script>
        function xacNhanTra(ticketId) {
            if (!confirm('Xác nhận trả máy cho khách hàng?')) {
                return;
            }

            $.ajax({
                url: '@Url.Action("XacNhanTra")',
                type: 'POST',
                data: { id: ticketId },
                headers: {
                    'RequestVerificationToken': $('input[name="__RequestVerificationToken"]').val()
                },
                success: function(response) {
                    if (response.success) {
                        toastr.success(response.message);
                        setTimeout(() => location.reload(), 1000);
                    } else {
                        toastr.error(response.message);
                    }
                },
                error: function() {
                    toastr.error('Có lỗi xảy ra.');
                }
            });
        }
    </script>
    
    @if (isPrint)
    {
        <style>
            @@media print {
                body * { visibility: hidden; }
                .card, .card * { visibility: visible; }
                .card { position: absolute; left: 0; top: 0; width: 100%; }
                .btn { display: none !important; }
            }
        </style>
    }
}

